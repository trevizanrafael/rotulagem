<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <%- include('../partials/_head') %>
  <title>Assistente IA — FoodTech</title>
  <!-- PDF.js para converter PDF em imagens no browser -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.3.136/pdf.min.mjs" type="module" id="pdfjs-script"></script>
  <style>
    /* ── Layout do chat ── */
    .chat-root {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background: linear-gradient(160deg, #f0f4f8 0%, #e6f2fb 100%);
    }

    /* Header do chat */
    .chat-header {
      background: linear-gradient(135deg, #013f70 0%, #036ec0 100%);
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 16px rgba(3,110,192,.25);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .chat-header-brand {
      display: flex;
      align-items: center;
      gap: .75rem;
    }

    .chat-header-brand img {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      object-fit: contain;
    }

    .chat-header-brand h1 {
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -.2px;
    }

    .chat-header-brand p {
      font-size: .75rem;
      color: rgba(255,255,255,.6);
      margin: 0;
    }

    .chat-header-info {
      display: flex;
      align-items: center;
      gap: .6rem;
      color: rgba(255,255,255,.85);
      font-size: .82rem;
    }

    .chat-header-avatar {
      width: 32px;
      height: 32px;
      background: rgba(255,255,255,.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: .8rem;
      color: #fff;
    }

    .ai-badge {
      background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.25);
      border-radius: 20px;
      padding: .25rem .75rem;
      font-size: .72rem;
      font-weight: 600;
      color: rgba(255,255,255,.9);
      letter-spacing: .3px;
      backdrop-filter: blur(8px);
    }

    /* Área de mensagens */
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      max-width: 860px;
      width: 100%;
      margin: 0 auto;
    }

    /* Estado inicial */
    .chat-welcome {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 3rem 2rem;
      text-align: center;
      gap: 1rem;
      animation: fadeUp .4s ease both;
    }

    .chat-welcome-icon {
      width: 72px;
      height: 72px;
      background: linear-gradient(135deg, #036ec0, #025aa0);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      box-shadow: 0 8px 24px rgba(3,110,192,.3);
      margin-bottom: .5rem;
    }

    .chat-welcome h2 {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--text);
    }

    .chat-welcome p {
      color: var(--text-muted);
      font-size: .9rem;
      max-width: 440px;
      line-height: 1.6;
    }

    .chat-suggestions {
      display: flex;
      flex-wrap: wrap;
      gap: .65rem;
      justify-content: center;
      margin-top: .75rem;
    }

    .chat-suggestion-chip {
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: 20px;
      padding: .45rem 1rem;
      font-size: .82rem;
      color: var(--text-muted);
      cursor: pointer;
      transition: all .18s;
      font-family: inherit;
    }

    .chat-suggestion-chip:hover {
      background: var(--blue-light);
      border-color: var(--blue);
      color: var(--blue);
    }

    /* Bolhas de mensagem */
    .msg-row {
      display: flex;
      gap: .75rem;
      animation: fadeUp .25s ease both;
    }

    .msg-row.user-row {
      flex-direction: row-reverse;
    }

    .msg-avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .8rem;
      font-weight: 700;
      flex-shrink: 0;
      align-self: flex-end;
    }

    .msg-avatar.ai-avatar {
      background: linear-gradient(135deg, #036ec0, #025aa0);
      color: #fff;
    }

    .msg-avatar.user-avatar {
      background: var(--blue-mid);
      color: var(--blue-deeper);
    }

    .msg-bubble {
      max-width: min(72%, 580px);
      padding: .85rem 1.1rem;
      border-radius: 18px;
      font-size: .9rem;
      line-height: 1.65;
      position: relative;
      box-shadow: var(--shadow-sm);
    }

    /* Usuário — azul, canto direito */
    .msg-row.user-row .msg-bubble {
      background: linear-gradient(135deg, #036ec0, #025aa0);
      color: #fff;
      border-bottom-right-radius: 4px;
    }

    /* IA — branco, canto esquerdo */
    .msg-row.ai-row .msg-bubble {
      background: #fff;
      color: var(--text);
      border: 1px solid var(--border);
      border-bottom-left-radius: 4px;
    }

    .msg-bubble .msg-image {
      max-width: 100%;
      border-radius: 10px;
      margin-bottom: .6rem;
      display: block;
    }

    /* Timestamp */
    .msg-time {
      font-size: .7rem;
      opacity: .55;
      margin-top: .35rem;
      display: block;
    }

    .msg-row.user-row .msg-time { text-align: right; }

    /* Indicador de "digitando..." */
    .typing-indicator {
      display: flex;
      gap: 4px;
      align-items: center;
      padding: .75rem 1rem;
    }

    .typing-indicator span {
      width: 7px;
      height: 7px;
      background: var(--blue);
      border-radius: 50%;
      display: inline-block;
      animation: typingBounce 1.2s infinite ease-in-out;
    }

    .typing-indicator span:nth-child(2) { animation-delay: .2s; }
    .typing-indicator span:nth-child(3) { animation-delay: .4s; }

    @keyframes typingBounce {
      0%, 80%, 100% { transform: scale(0.7); opacity: .4; }
      40% { transform: scale(1); opacity: 1; }
    }

    /* Markdown simples na resposta da IA */
    .msg-row.ai-row .msg-bubble p { margin-bottom: .6rem; }
    .msg-row.ai-row .msg-bubble p:last-child { margin-bottom: 0; }
    .msg-row.ai-row .msg-bubble strong { color: var(--blue-dark); }
    .msg-row.ai-row .msg-bubble ul,
    .msg-row.ai-row .msg-bubble ol { padding-left: 1.25rem; margin-bottom: .5rem; }
    .msg-row.ai-row .msg-bubble li { margin-bottom: .25rem; }
    .msg-row.ai-row .msg-bubble code {
      background: var(--blue-light);
      padding: .1em .35em;
      border-radius: 4px;
      font-size: .85em;
    }

    /* ── Input bar ── */
    .chat-inputbar {
      background: #fff;
      border-top: 1px solid var(--border);
      padding: 1rem 1rem 1.25rem;
      position: sticky;
      bottom: 0;
      z-index: 40;
    }

    .chat-inputbar-inner {
      max-width: 860px;
      margin: 0 auto;
    }

    /* Preview de arquivo (imagem ou PDF) */
    .file-preview-wrap {
      display: none;
      flex-direction: column;
      gap: .6rem;
      margin-bottom: .75rem;
      padding: .75rem 1rem;
      background: var(--blue-light);
      border: 1.5px solid var(--blue-mid);
      border-radius: var(--radius);
      animation: fadeUp .2s ease;
    }

    .file-preview-wrap.visible { display: flex; }

    .file-preview-header {
      display: flex;
      align-items: center;
      gap: .75rem;
    }

    .file-preview-icon {
      font-size: 1.4rem;
      flex-shrink: 0;
    }

    .file-preview-info {
      flex: 1;
      overflow: hidden;
    }

    .file-preview-name {
      font-size: .85rem;
      font-weight: 600;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .file-preview-meta {
      font-size: .75rem;
      color: var(--text-muted);
    }

    .file-preview-remove {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--text-light);
      font-size: 1.1rem;
      line-height: 1;
      padding: .25rem;
      border-radius: 50%;
      transition: color .15s, background .15s;
      flex-shrink: 0;
    }

    .file-preview-remove:hover { color: var(--danger); background: var(--danger-bg); }

    /* Barra de progresso PDF */
    .pdf-progress-bar {
      height: 4px;
      background: var(--blue-mid);
      border-radius: 4px;
      overflow: hidden;
    }

    .pdf-progress-fill {
      height: 100%;
      background: var(--blue);
      border-radius: 4px;
      transition: width .2s ease;
      width: 0%;
    }

    /* Grade de miniaturas das páginas do PDF */
    .pdf-thumbs {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
    }

    .pdf-thumb {
      width: 60px;
      height: 84px;
      object-fit: cover;
      border-radius: 4px;
      border: 1.5px solid var(--blue-mid);
      box-shadow: var(--shadow-sm);
      cursor: default;
    }

    /* Área de input */
    .chat-input-row {
      display: flex;
      align-items: flex-end;
      gap: .6rem;
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: 14px;
      padding: .6rem .6rem .6rem 1rem;
      transition: border-color .18s, box-shadow .18s;
    }

    .chat-input-row:focus-within {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(3,110,192,.1);
    }

    #chat-textarea {
      flex: 1;
      border: none;
      background: transparent;
      font-family: inherit;
      font-size: .92rem;
      color: var(--text);
      resize: none;
      outline: none;
      min-height: 22px;
      max-height: 160px;
      line-height: 1.55;
      padding: .2rem 0;
    }

    #chat-textarea::placeholder { color: var(--text-light); }

    .chat-input-actions {
      display: flex;
      align-items: center;
      gap: .35rem;
      flex-shrink: 0;
    }

    .btn-icon {
      width: 38px;
      height: 38px;
      border: none;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background .18s, color .18s, transform .15s;
      flex-shrink: 0;
    }

    .btn-icon:active { transform: scale(.93); }

    .btn-icon-upload {
      background: var(--blue-light);
      color: var(--blue);
    }

    .btn-icon-upload:hover { background: var(--blue-mid); }

    .btn-icon-send {
      background: var(--blue);
      color: #fff;
    }

    .btn-icon-send:hover { background: var(--blue-dark); box-shadow: 0 4px 12px rgba(3,110,192,.35); }

    .btn-icon-send:disabled {
      background: var(--border);
      color: var(--text-light);
      cursor: not-allowed;
    }

    .btn-icon-send:disabled:hover { box-shadow: none; }

    #file-input { display: none; }

    /* Hint de atalho */
    .input-hint {
      font-size: .7rem;
      color: var(--text-light);
      text-align: center;
      margin-top: .5rem;
    }

    /* Logout link no header */
    .btn-logout {
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.22);
      border-radius: 8px;
      padding: .4rem .8rem;
      color: rgba(255,255,255,.9);
      font-size: .8rem;
      font-family: inherit;
      cursor: pointer;
      transition: background .18s;
    }

    .btn-logout:hover { background: rgba(255,255,255,.22); }

    /* Mensagem de erro inline */
    .msg-error {
      background: var(--danger-bg);
      color: var(--danger);
      border: 1px solid #fca5a5;
    }
  </style>
</head>

<body>

<div class="chat-root">

  <!-- Header -->
  <header class="chat-header">
    <div class="chat-header-brand">
      <img src="/icons/logo.png" alt="FoodTech">
      <div>
        <h1>FoodTech · Assistente IA</h1>
        <p>Análise inteligente de rótulos lácteos</p>
      </div>
    </div>
    <div class="chat-header-info">
      <span class="ai-badge">🤖 IA Ativa</span>
      <div class="chat-header-avatar"><%= username.charAt(0).toUpperCase() %></div>
      <span><%= username %></span>
      <form action="/logout" method="POST" style="margin:0">
        <button type="submit" class="btn-logout">Sair</button>
      </form>
    </div>
  </header>

  <!-- Área de mensagens -->
  <div class="chat-messages" id="chat-messages">

    <!-- Estado inicial de boas-vindas -->
    <div class="chat-welcome" id="chat-welcome">
      <div class="chat-welcome-icon">🔍</div>
      <h2>Olá, <%= username %>!</h2>
      <p>
        Envie uma imagem do rótulo ou descreva sua dúvida sobre conformidade. 
        A IA irá analisar e responder com base nas normas de rotulagem de lácteos.
      </p>
      <div class="chat-suggestions">
        <button class="chat-suggestion-chip" onclick="useSuggestion(this)">📸 Analisar rótulo de queijo</button>
        <button class="chat-suggestion-chip" onclick="useSuggestion(this)">✅ Verificar informações nutricionais</button>
        <button class="chat-suggestion-chip" onclick="useSuggestion(this)">⚠️ Quais dados são obrigatórios no rótulo?</button>
        <button class="chat-suggestion-chip" onclick="useSuggestion(this)">📋 Lista de alérgenos exigidos</button>
      </div>
    </div>

  </div>

  <!-- Barra de input -->
  <div class="chat-inputbar">
    <div class="chat-inputbar-inner">

      <!-- Preview do arquivo (imagem ou PDF) -->
      <div class="file-preview-wrap" id="file-preview-wrap">
        <div class="file-preview-header">
          <span class="file-preview-icon" id="file-preview-icon">🖼️</span>
          <div class="file-preview-info">
            <div class="file-preview-name" id="file-preview-name">arquivo</div>
            <div class="file-preview-meta" id="file-preview-meta"></div>
          </div>
          <button class="file-preview-remove" title="Remover" onclick="removeFile()">✕</button>
        </div>
        <!-- Barra de progresso (só PDF) -->
        <div class="pdf-progress-bar" id="pdf-progress-bar" style="display:none">
          <div class="pdf-progress-fill" id="pdf-progress-fill"></div>
        </div>
        <!-- Miniaturas das páginas do PDF -->
        <div class="pdf-thumbs" id="pdf-thumbs"></div>
      </div>

      <!-- Input principal -->
      <div class="chat-input-row">
        <textarea
          id="chat-textarea"
          rows="1"
          placeholder="Digite sua mensagem ou envie uma imagem do rótulo..."
        ></textarea>

        <div class="chat-input-actions">
          <!-- Botão de upload -->
          <button class="btn-icon btn-icon-upload" title="Enviar imagem" onclick="document.getElementById('file-input').click()">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </button>

          <!-- Botão de enviar -->
          <button class="btn-icon btn-icon-send" id="btn-send" title="Enviar (Enter)" onclick="sendMessage()">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </div>
      </div>

      <input type="file" id="file-input" accept="image/*,.pdf" onchange="handleFileSelect(event)">
      <p class="input-hint">Enter para enviar · Shift+Enter para nova linha · Suporta JPG, PNG, WEBP, PDF</p>
    </div>
  </div>

</div>

<script>
  /* ── Estado ── */
  // Para imagem simples: selectedImages = [{ base64, mimeType, dataUrl }]
  // Para PDF: selectedImages = [{ base64, mimeType:'image/jpeg', dataUrl }, ...] (uma por página)
  let selectedImages = [];   // array de páginas/imagens
  let isSending = false;

  /* ── Textarea auto-resize ── */
  const textarea = document.getElementById('chat-textarea');
  textarea.addEventListener('input', () => {
    textarea.style.height = 'auto';
    textarea.style.height = Math.min(textarea.scrollHeight, 160) + 'px';
  });

  /* ── Enter para enviar (Shift+Enter = nova linha) ── */
  textarea.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  /* ── Sugestões de chip ── */
  function useSuggestion(el) {
    textarea.value = el.textContent.replace(/^[^\w]+/, '').trim();
    textarea.style.height = 'auto';
    textarea.style.height = Math.min(textarea.scrollHeight, 160) + 'px';
    textarea.focus();
  }

  /* ── Helpers de preview ── */
  function showPreview({ icon, name, meta }) {
    document.getElementById('file-preview-icon').textContent = icon;
    document.getElementById('file-preview-name').textContent = name;
    document.getElementById('file-preview-meta').textContent = meta;
    document.getElementById('file-preview-wrap').classList.add('visible');
  }

  function removeFile() {
    selectedImages = [];
    document.getElementById('file-preview-wrap').classList.remove('visible');
    document.getElementById('pdf-thumbs').innerHTML = '';
    document.getElementById('pdf-progress-bar').style.display = 'none';
    document.getElementById('pdf-progress-fill').style.width = '0%';
  }

  /* ── Upload de arquivo (imagem ou PDF) ── */
  async function handleFileSelect(event) {
    const file = event.target.files[0];
    event.target.value = '';
    if (!file) return;

    removeFile();

    if (file.type === 'application/pdf') {
      await handlePDF(file);
    } else if (file.type.startsWith('image/')) {
      if (file.size > 20 * 1024 * 1024) { alert('Imagem muito grande. Limite: 20MB.'); return; }
      await handleImage(file);
    } else {
      alert('Formato não suportado. Use JPG, PNG, WEBP ou PDF.');
    }
  }

  /* ── Imagem simples → base64 ── */
  function handleImage(file) {
    return new Promise((resolve) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const dataUrl = e.target.result;
        const base64 = dataUrl.split(',')[1];
        selectedImages = [{ base64, mimeType: file.type, dataUrl }];
        showPreview({ icon: '🖼️', name: file.name, meta: `${(file.size/1024).toFixed(0)} KB · 1 imagem` });
        resolve();
      };
      reader.readAsDataURL(file);
    });
  }

  /* ── PDF → páginas → canvas → base64 ── */
  async function handlePDF(file) {
    showPreview({ icon: '📄', name: file.name, meta: 'Processando páginas...' });
    document.getElementById('pdf-progress-bar').style.display = 'block';

    const thumbsEl = document.getElementById('pdf-thumbs');
    const fillEl   = document.getElementById('pdf-progress-fill');

    try {
      // Carrega PDF.js dinamicamente (ESM via CDN)
      const pdfjsLib = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.3.136/pdf.min.mjs');
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.3.136/pdf.worker.min.mjs';

      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      const total = pdf.numPages;

      selectedImages = [];
      thumbsEl.innerHTML = '';

      for (let i = 1; i <= total; i++) {
        const page = await pdf.getPage(i);
        const scale = 2.0; // resolução alta para a IA
        const viewport = page.getViewport({ scale });

        const canvas = document.createElement('canvas');
        canvas.width  = viewport.width;
        canvas.height = viewport.height;
        const ctx = canvas.getContext('2d');
        await page.render({ canvasContext: ctx, viewport }).promise;

        const dataUrl = canvas.toDataURL('image/jpeg', 0.90);
        const base64  = dataUrl.split(',')[1];
        selectedImages.push({ base64, mimeType: 'image/jpeg', dataUrl });

        // Miniatura
        const thumb = document.createElement('img');
        thumb.src   = canvas.toDataURL('image/jpeg', 0.5);
        thumb.className = 'pdf-thumb';
        thumb.title = `Página ${i}`;
        thumbsEl.appendChild(thumb);

        // Progresso
        fillEl.style.width = Math.round((i / total) * 100) + '%';
      }

      document.getElementById('file-preview-meta').textContent =
        `${total} página${total > 1 ? 's' : ''} · PDF convertido para imagem`;
      document.getElementById('pdf-progress-bar').style.display = 'none';

    } catch (err) {
      console.error('Erro ao processar PDF:', err);
      alert('Não foi possível processar o PDF. Tente outro arquivo.');
      removeFile();
    }
  }

  /* ── Formata hora ── */
  function nowTime() {
    return new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  }

  /* ── Oculta boas-vindas ── */
  function hideWelcome() {
    const w = document.getElementById('chat-welcome');
    if (w) w.remove();
  }

  /* ── Adiciona bolha de mensagem ── */
  // images: array de dataUrls para exibir no chat (miniaturas)
  function addMessage({ role, text, images }) {
    hideWelcome();
    const container = document.getElementById('chat-messages');

    const row = document.createElement('div');
    row.className = `msg-row ${role === 'user' ? 'user-row' : 'ai-row'}`;

    const avatar = document.createElement('div');
    avatar.className = `msg-avatar ${role === 'user' ? 'user-avatar' : 'ai-avatar'}`;
    avatar.textContent = role === 'user' ? '<%= username.charAt(0).toUpperCase() %>' : '🤖';

    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';

    // Exibe imagens (até 4 em grade; se mais, exibe todas em scroll)
    if (images && images.length > 0) {
      const grid = document.createElement('div');
      grid.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;';
      images.forEach((src, i) => {
        const img = document.createElement('img');
        img.src = src;
        img.className = 'msg-image';
        img.style.cssText = 'max-width:180px;max-height:130px;object-fit:cover;border-radius:8px;';
        img.alt = `Página ${i + 1}`;
        grid.appendChild(img);
      });
      bubble.appendChild(grid);
    }

    if (text) {
      if (role === 'ai') {
        bubble.innerHTML += renderMarkdown(text);
      } else {
        const p = document.createElement('p');
        p.style.margin = '0';
        p.textContent = text;
        bubble.appendChild(p);
      }
    }

    const time = document.createElement('span');
    time.className = 'msg-time';
    time.textContent = nowTime();
    bubble.appendChild(time);

    row.appendChild(avatar);
    row.appendChild(bubble);
    container.appendChild(row);

    scrollToBottom();
    return row;
  }

  /* ── Bolha de "digitando..." ── */
  function addTypingIndicator() {
    hideWelcome();
    const container = document.getElementById('chat-messages');

    const row = document.createElement('div');
    row.className = 'msg-row ai-row';
    row.id = 'typing-row';

    const avatar = document.createElement('div');
    avatar.className = 'msg-avatar ai-avatar';
    avatar.textContent = '🤖';

    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';
    bubble.innerHTML = `<div class="typing-indicator"><span></span><span></span><span></span></div>`;

    row.appendChild(avatar);
    row.appendChild(bubble);
    container.appendChild(row);
    scrollToBottom();
    return row;
  }

  function removeTypingIndicator() {
    const t = document.getElementById('typing-row');
    if (t) t.remove();
  }

  /* ── Scroll para baixo ── */
  function scrollToBottom() {
    const c = document.getElementById('chat-messages');
    c.scrollTop = c.scrollHeight;
  }

  /* ── Mini renderizador de Markdown ── */
  function renderMarkdown(text) {
    let html = text
      // Escape HTML
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      // Bold **texto**
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      // Itálico *texto*
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      // Código `inline`
      .replace(/`(.+?)`/g, '<code>$1</code>')
      // Título ### 
      .replace(/^### (.+)$/gm, '<strong>$1</strong>')
      .replace(/^## (.+)$/gm, '<strong>$1</strong>')
      .replace(/^# (.+)$/gm, '<strong>$1</strong>')
      // Lista - item
      .replace(/^[-•] (.+)$/gm, '<li>$1</li>')
      // Parágrafos (linhas duplas)
      .replace(/\n\n/g, '</p><p>')
      // Linha simples
      .replace(/\n/g, '<br>');

    // Envolver listas
    html = html.replace(/(<li>.*?<\/li>)/gs, '<ul>$1</ul>');
    // Envolver em parágrafo
    html = '<p>' + html + '</p>';
    return html;
  }

  /* ── Enviar mensagem ── */
  async function sendMessage() {
    if (isSending) return;

    const prompt = textarea.value.trim();
    const hasFiles = selectedImages.length > 0;

    if (!prompt && !hasFiles) {
      textarea.focus();
      return;
    }

    isSending = true;
    const sendBtn = document.getElementById('btn-send');
    sendBtn.disabled = true;

    // Exibir bolha do usuário com miniaturas das imagens
    const previewUrls = selectedImages.map(img => img.dataUrl);
    addMessage({ role: 'user', text: prompt, images: previewUrls });

    // Guardar e limpar estado
    const promptToSend = prompt;
    const imagesToSend = selectedImages.map(img => ({ base64: img.base64, mimeType: img.mimeType }));

    textarea.value = '';
    textarea.style.height = 'auto';
    removeFile();

    // Indicador de digitando
    addTypingIndicator();

    try {
      const res = await fetch('/chat/ia', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          prompt: promptToSend,
          images: imagesToSend,   // array de { base64, mimeType }
        }),
      });

      const data = await res.json();
      removeTypingIndicator();

      if (data.ok) {
        addMessage({ role: 'ai', text: data.resposta });
      } else {
        addMessage({ role: 'ai', text: '⚠️ ' + (data.mensagem || 'Erro desconhecido.') });
      }
    } catch (err) {
      removeTypingIndicator();
      addMessage({ role: 'ai', text: '⚠️ Não foi possível conectar com a IA. Verifique sua conexão.' });
    } finally {
      isSending = false;
      sendBtn.disabled = false;
      textarea.focus();
    }
  }
</script>

</body>
</html>
