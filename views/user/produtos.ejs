<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/_head') %>
  <title>Produtos — FoodTech</title>
  <style>
    /* ── Chips de checklist ── */
    .checklist-chips {
      display: flex;
      flex-wrap: wrap;
      gap: .45rem;
      margin-top: .6rem;
    }
    .checklist-chip {
      display: inline-flex;
      align-items: center;
      gap: .35rem;
      background: var(--blue-light);
      color: var(--blue);
      border: 1px solid var(--blue-mid);
      border-radius: 999px;
      padding: .2rem .7rem;
      font-size: .78rem;
      font-weight: 600;
    }
    .checklist-chip-icon { font-size: .85rem; }

    /* Aviso "sem checklists" */
    .no-checklists-hint {
      font-size: .8rem;
      color: var(--text-muted);
      font-style: italic;
      margin-top: .5rem;
    }

    /* ── Painel de checklists inline no formulário ── */
    #checklist-preview-wrap {
      background: var(--bg);
      border: 1.5px dashed var(--border);
      border-radius: var(--radius);
      padding: .75rem 1rem;
      min-height: 48px;
      transition: border-color var(--transition);
    }
    #checklist-preview-wrap.has-items {
      border-color: var(--blue-mid);
      background: var(--blue-light);
    }

    /* ── Tabela de produtos — coluna checklists ── */
    .chip-list {
      display: flex;
      flex-wrap: wrap;
      gap: .3rem;
    }
    .chip {
      background: var(--blue-light);
      color: var(--blue);
      border: 1px solid var(--blue-mid);
      border-radius: 999px;
      padding: .12rem .55rem;
      font-size: .72rem;
      font-weight: 600;
      white-space: nowrap;
    }

    /* ── Modal de edição ── */
    .edit-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(10,20,40,.45);
      backdrop-filter: blur(3px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 900;
      opacity: 0;
      pointer-events: none;
      transition: opacity .22s ease;
    }
    .edit-modal-overlay.open {
      opacity: 1;
      pointer-events: all;
    }
    .edit-modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: 0 20px 60px rgba(0,0,0,.18);
      padding: 2rem;
      width: 100%;
      max-width: 560px;
      margin: 1rem;
      transform: scale(.92) translateY(12px);
      transition: transform .22s cubic-bezier(.34,1.56,.64,1), opacity .22s ease;
      opacity: 0;
    }
    .edit-modal-overlay.open .edit-modal {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
    .edit-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }
    .edit-modal-header h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
    }
    .modal-close-btn {
      background: none;
      border: none;
      font-size: 1.25rem;
      cursor: pointer;
      color: var(--text-muted);
      padding: 0;
      line-height: 1;
    }
    .modal-close-btn:hover { color: var(--danger); }

    /* ── Separador de seção ── */
    .section-label {
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .6px;
      text-transform: uppercase;
      color: var(--text-light);
      margin-bottom: .5rem;
    }
  </style>
</head>
<body>

<%- include('../partials/_user-layout', { currentPage: 'produtos', username: username }) %>

<div class="app-content">

  <!-- Cabeçalho -->
  <div class="page-header fade-up" style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
    <div>
      <h1>Produtos</h1>
      <p>Gerencie os produtos associados à sua conta.</p>
    </div>
    <button class="btn btn-primary" onclick="abrirModalNovo()">
      <span style="font-size:1rem;">＋</span> Novo produto
    </button>
  </div>

  <!-- Alertas -->
  <% if (sucesso) { %>
  <div class="alert alert-success fade-up" id="alert-box">
    <span>✅</span>
    <% if (sucesso === 'criado')  { %> Produto cadastrado com sucesso! <% } %>
    <% if (sucesso === 'editado') { %> Produto atualizado com sucesso! <% } %>
    <% if (sucesso === 'deletado'){ %> Produto removido com sucesso!   <% } %>
  </div>
  <% } %>
  <% if (erro) { %>
  <div class="alert alert-error fade-up" id="alert-box">
    <span>❌</span>
    <% if (erro === 'erro_ao_criar')  { %> Erro ao cadastrar produto. Tente novamente. <% } %>
    <% if (erro === 'erro_ao_editar') { %> Erro ao atualizar produto. Tente novamente. <% } %>
    <% if (erro === 'erro_ao_deletar'){ %> Erro ao remover produto. Tente novamente.   <% } %>
    <% if (erro === 'nao_encontrado') { %> Produto não encontrado.                      <% } %>
  </div>
  <% } %>

  <!-- Tabela de produtos -->
  <div class="card fade-up d1">
    <div class="card-header">
      <h2>📦 Meus Produtos</h2>
      <span class="card-badge"><%= produtos.length %> produto<%= produtos.length !== 1 ? 's' : '' %></span>
    </div>

    <% if (produtos.length === 0) { %>
    <div class="card-body">
      <div class="empty-state">
        <div class="empty-state-icon">📦</div>
        <p style="font-weight:600; color:var(--text); margin-bottom:.4rem;">Nenhum produto cadastrado</p>
        <p>Clique em <strong>Novo produto</strong> para começar.</p>
      </div>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Marca</th>
            <th>Denominação de venda</th>
            <th>Categoria</th>
            <th>Subcategoria</th>
            <th>Checklists</th>
            <th style="text-align:right;">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% produtos.forEach((p, i) => { %>
          <tr>
            <td class="td-id"><%= p.id %></td>
            <td>
              <div style="font-weight:600; color:var(--text);"><%= p.marca %></div>
              <% if (p.descricao) { %>
              <div class="td-muted" style="max-width:220px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                <%= p.descricao %>
              </div>
              <% } %>
            </td>
            <td><%= p.denominacaoVenda %></td>
            <td class="td-muted"><%= p.categoria ? p.categoria.nome : '—' %></td>
            <td class="td-muted"><%= p.subcategoria ? p.subcategoria.nome : '—' %></td>
            <td>
              <div class="chip-list" id="chips-row-<%= p.id %>" data-subid="<%= p.subcategoriaId %>">
                <span class="td-muted" style="font-size:.78rem;">Carregando...</span>
              </div>
            </td>
            <td style="text-align:right; white-space:nowrap;">
              <button
                class="btn btn-secondary btn-sm"
                onclick="abrirModalEditar(<%= JSON.stringify(p) %>)"
                title="Editar">✏️</button>
              <button
                class="btn btn-danger btn-sm"
                onclick="confirmarDelete(<%= p.id %>, '<%= p.marca.replace(/'/g,"\\'") %>')"
                title="Excluir">🗑️</button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

</div>

<!-- ══════════════════════════════
     MODAL — Novo Produto
══════════════════════════════ -->
<div class="edit-modal-overlay" id="modal-novo" role="dialog" aria-modal="true" aria-labelledby="modal-novo-title">
  <div class="edit-modal">
    <div class="edit-modal-header">
      <h3 id="modal-novo-title">📦 Novo Produto</h3>
      <button class="modal-close-btn" onclick="fecharModalNovo()" aria-label="Fechar">✕</button>
    </div>

    <form action="/produtos" method="POST" id="form-novo">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:.9rem;">

        <!-- Marca -->
        <div class="form-group" style="grid-column:1/-1;">
          <label for="novo-marca">Marca *</label>
          <input type="text" id="novo-marca" name="marca" required placeholder="Ex: Nestlé">
        </div>

        <!-- Denominação de venda -->
        <div class="form-group" style="grid-column:1/-1;">
          <label for="novo-denominacao">Denominação de venda *</label>
          <input type="text" id="novo-denominacao" name="denominacaoVenda" required placeholder="Ex: Leite integral UHT">
        </div>

        <!-- Categoria -->
        <div class="form-group">
          <label for="novo-categoria">Categoria *</label>
          <select id="novo-categoria" name="categoriaId" required onchange="carregarSubcategorias('novo')">
            <option value="">Selecione...</option>
            <% categorias.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.nome %></option>
            <% }) %>
          </select>
        </div>

        <!-- Subcategoria -->
        <div class="form-group">
          <label for="novo-subcategoria">Subcategoria *</label>
          <select id="novo-subcategoria" name="subcategoriaId" required disabled onchange="carregarChecklists('novo', this.value)">
            <option value="">Selecione a categoria primeiro</option>
          </select>
        </div>

        <!-- Preview de checklists -->
        <div style="grid-column:1/-1;">
          <p class="section-label">🔍 Checklists aplicáveis à subcategoria</p>
          <div id="checklist-preview-novo" id-wrap="checklist-preview-wrap">
            <p style="font-size:.8rem; color:var(--text-muted);">Selecione uma subcategoria para ver os checklists associados.</p>
          </div>
        </div>

        <!-- Descrição -->
        <div class="form-group" style="grid-column:1/-1; margin-bottom:0;">
          <label for="novo-descricao">Descrição (opcional)</label>
          <textarea id="novo-descricao" name="descricao" rows="3"
            style="width:100%; padding:.65rem .9rem; font-family:inherit; font-size:.925rem; color:var(--text);
                   background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius);
                   outline:none; resize:vertical; transition:border-color var(--transition);"
            placeholder="Observações sobre o produto..."></textarea>
        </div>

      </div>

      <div style="display:flex; justify-content:flex-end; gap:.6rem; margin-top:1.5rem;">
        <button type="button" class="btn btn-ghost" onclick="fecharModalNovo()">Cancelar</button>
        <button type="submit" class="btn btn-primary">Salvar produto</button>
      </div>
    </form>
  </div>
</div>

<!-- ══════════════════════════════
     MODAL — Editar Produto
══════════════════════════════ -->
<div class="edit-modal-overlay" id="modal-editar" role="dialog" aria-modal="true" aria-labelledby="modal-editar-title">
  <div class="edit-modal">
    <div class="edit-modal-header">
      <h3 id="modal-editar-title">✏️ Editar Produto</h3>
      <button class="modal-close-btn" onclick="fecharModalEditar()" aria-label="Fechar">✕</button>
    </div>

    <form id="form-editar" method="POST">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:.9rem;">

        <!-- Marca -->
        <div class="form-group" style="grid-column:1/-1;">
          <label for="edit-marca">Marca *</label>
          <input type="text" id="edit-marca" name="marca" required placeholder="Ex: Nestlé">
        </div>

        <!-- Denominação de venda -->
        <div class="form-group" style="grid-column:1/-1;">
          <label for="edit-denominacao">Denominação de venda *</label>
          <input type="text" id="edit-denominacao" name="denominacaoVenda" required placeholder="Ex: Leite integral UHT">
        </div>

        <!-- Categoria -->
        <div class="form-group">
          <label for="edit-categoria">Categoria *</label>
          <select id="edit-categoria" name="categoriaId" required onchange="carregarSubcategorias('edit')">
            <option value="">Selecione...</option>
            <% categorias.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.nome %></option>
            <% }) %>
          </select>
        </div>

        <!-- Subcategoria -->
        <div class="form-group">
          <label for="edit-subcategoria">Subcategoria *</label>
          <select id="edit-subcategoria" name="subcategoriaId" required disabled onchange="carregarChecklists('edit', this.value)">
            <option value="">Selecione a categoria primeiro</option>
          </select>
        </div>

        <!-- Preview de checklists -->
        <div style="grid-column:1/-1;">
          <p class="section-label">🔍 Checklists aplicáveis à subcategoria</p>
          <div id="checklist-preview-edit" style="background:var(--bg); border:1.5px dashed var(--border); border-radius:var(--radius); padding:.75rem 1rem; min-height:48px;">
            <p style="font-size:.8rem; color:var(--text-muted);">Selecione uma subcategoria para ver os checklists associados.</p>
          </div>
        </div>

        <!-- Descrição -->
        <div class="form-group" style="grid-column:1/-1; margin-bottom:0;">
          <label for="edit-descricao">Descrição (opcional)</label>
          <textarea id="edit-descricao" name="descricao" rows="3"
            style="width:100%; padding:.65rem .9rem; font-family:inherit; font-size:.925rem; color:var(--text);
                   background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius);
                   outline:none; resize:vertical; transition:border-color var(--transition);"
            placeholder="Observações sobre o produto..."></textarea>
        </div>

      </div>

      <div style="display:flex; justify-content:flex-end; gap:.6rem; margin-top:1.5rem;">
        <button type="button" class="btn btn-ghost" onclick="fecharModalEditar()">Cancelar</button>
        <button type="submit" class="btn btn-primary">Salvar alterações</button>
      </div>
    </form>
  </div>
</div>

<!-- Form oculto para delete -->
<form id="form-delete" method="POST" style="display:none;"></form>

<!-- ══════════════════════════════
     SCRIPTS
══════════════════════════════ -->
<script>
/* ─── Utilitários ─── */
const $ = id => document.getElementById(id);

function fecharModalNovo()   { $('modal-novo').classList.remove('open');   }
function fecharModalEditar() { $('modal-editar').classList.remove('open'); }

function abrirModalNovo() {
  $('form-novo').reset();
  resetSubcategorias('novo');
  resetChecklists('novo');
  $('modal-novo').classList.add('open');
}

/* ─── Dropdown dinâmico: subcategorias ─── */
function resetSubcategorias(prefix) {
  const sel = $(`${prefix}-subcategoria`);
  sel.innerHTML = '<option value="">Selecione a categoria primeiro</option>';
  sel.disabled = true;
  resetChecklists(prefix);
}

async function carregarSubcategorias(prefix) {
  const categoriaId = $(`${prefix}-categoria`).value;
  const sel         = $(`${prefix}-subcategoria`);

  if (!categoriaId) { resetSubcategorias(prefix); return; }

  sel.innerHTML = '<option value="">Carregando...</option>';
  sel.disabled  = true;

  try {
    const res  = await fetch(`/api/subcategorias?categoriaId=${categoriaId}`);
    const subs = await res.json();

    sel.innerHTML = '<option value="">Selecione...</option>';
    if (subs.length === 0) {
      sel.innerHTML = '<option value="">Nenhuma subcategoria disponível</option>';
    } else {
      subs.forEach(s => {
        const opt = document.createElement('option');
        opt.value       = s.id;
        opt.textContent = s.nome;
        sel.appendChild(opt);
      });
      sel.disabled = false;
    }
  } catch(e) {
    sel.innerHTML = '<option value="">Erro ao carregar</option>';
  }
  resetChecklists(prefix);
}

/* ─── Preview de checklists ─── */
function resetChecklists(prefix) {
  const div = $(`checklist-preview-${prefix}`);
  div.innerHTML = '<p style="font-size:.8rem; color:var(--text-muted);">Selecione uma subcategoria para ver os checklists associados.</p>';
  div.style.background   = 'var(--bg)';
  div.style.borderColor  = 'var(--border)';
  div.style.borderStyle  = 'dashed';
}

async function carregarChecklists(prefix, subcategoriaId) {
  const div = $(`checklist-preview-${prefix}`);
  if (!subcategoriaId) { resetChecklists(prefix); return; }

  div.innerHTML = '<p style="font-size:.8rem; color:var(--text-muted);">Carregando checklists...</p>';

  try {
    const res    = await fetch(`/api/subcategorias/${subcategoriaId}/checklists`);
    const lista  = await res.json();

    if (lista.length === 0) {
      div.innerHTML = '<p style="font-size:.8rem; color:var(--text-muted); font-style:italic;">Nenhum checklist vinculado a esta subcategoria.</p>';
      div.style.background  = 'var(--bg)';
      div.style.borderColor = 'var(--border)';
      div.style.borderStyle = 'dashed';
    } else {
      div.style.background   = 'var(--blue-light)';
      div.style.borderColor  = 'var(--blue-mid)';
      div.style.borderStyle  = 'solid';

      div.innerHTML = `
        <p style="font-size:.75rem; font-weight:700; color:var(--blue); margin-bottom:.5rem; text-transform:uppercase; letter-spacing:.4px;">
          ✅ ${lista.length} checklist${lista.length !== 1 ? 's' : ''} aplicável${lista.length !== 1 ? 'is' : ''}
        </p>
        <div class="checklist-chips">
          ${lista.map(c => `
            <span class="checklist-chip">
              <span class="checklist-chip-icon">📋</span> ${c.codigo} — ${c.nome}
            </span>
          `).join('')}
        </div>`;
    }
  } catch(e) {
    div.innerHTML = '<p style="font-size:.8rem; color:var(--danger);">Erro ao buscar checklists.</p>';
  }
}

/* ─── Modal de Edição ─── */
async function abrirModalEditar(p) {
  // Preencher campos simples
  $('edit-marca').value        = p.marca;
  $('edit-denominacao').value  = p.denominacaoVenda;
  $('edit-descricao').value    = p.descricao || '';

  // Definir action do form
  $('form-editar').action = `/produtos/${p.id}/editar`;

  // Categoria
  const catSel = $('edit-categoria');
  catSel.value = p.categoriaId;

  // Carregar subcategorias dinamicamente e então selecionar a correta
  await carregarSubcategorias('edit');
  const subSel = $('edit-subcategoria');
  subSel.value = p.subcategoriaId;

  // Carregar checklists da subcategoria atual
  if (p.subcategoriaId) await carregarChecklists('edit', p.subcategoriaId);

  $('modal-editar').classList.add('open');
}

/* ─── Delete ─── */
function confirmarDelete(id, nome) {
  if (!confirm(`Tem certeza que deseja excluir o produto "${nome}"? Esta ação não pode ser desfeita.`)) return;
  const form = $('form-delete');
  form.action = `/produtos/${id}/deletar`;
  form.submit();
}

/* ─── Fechar modais com ESC ou clique no overlay ─── */
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { fecharModalNovo(); fecharModalEditar(); }
});
['modal-novo', 'modal-editar'].forEach(id => {
  $(id).addEventListener('click', e => {
    if (e.target === $(id)) {
      id === 'modal-novo' ? fecharModalNovo() : fecharModalEditar();
    }
  });
});

/* ─── Carregar checklists nas linhas da tabela ─── */
(async () => {
  const rows = document.querySelectorAll('[id^="chips-row-"]');
  await Promise.all(Array.from(rows).map(async container => {
    const subcategoriaId = container.getAttribute('data-subid');
    if (!subcategoriaId) {
      container.innerHTML = '<span class="td-muted" style="font-size:.78rem;">—</span>';
      return;
    }
    try {
      const res   = await fetch(`/api/subcategorias/${subcategoriaId}/checklists`);
      const lista = await res.json();
      if (lista.length === 0) {
        container.innerHTML = '<span class="td-muted" style="font-size:.78rem; font-style:italic;">Nenhum</span>';
      } else {
        container.innerHTML = lista.map(c =>
          `<span class="chip" title="${c.nome}">${c.codigo}</span>`
        ).join('');
      }
    } catch(e) {
      container.innerHTML = '<span class="td-muted">—</span>';
    }
  }));
})();

/* ─── Auto-esconder alertas ─── */
setTimeout(() => {
  const a = $('alert-box');
  if (a) { a.style.opacity = '0'; a.style.transition = 'opacity .4s'; }
}, 4000);
</script>

</body>
</html>
