<!-- ══════════════════════════════
     SCRIPTS
══════════════════════════════ -->
<script>
const produtoId    = <%= produto.id %>;
const rotulosData  = <%- JSON.stringify(rotulos || []) %>;
let clAtualId      = null;

/* ── Abas ── */
function trocarAba(id) {
  const ids = ['identificacao','rotulo','arquivos','analise'];
  document.querySelectorAll('.tab-btn').forEach((b, i) => b.classList.toggle('active', ids[i] === id));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('aba-' + id).classList.add('active');
  history.replaceState(null, '', `?tab=${id}`);
}

/* ── Exportar rótulos como JSON com imagens em base64 ── */
async function exportarRotulos() {
  const btn = document.getElementById('btn-exportar');
  btn.disabled = true;
  btn.innerHTML = '<span style="display:inline-block;animation:spin 1s linear infinite;">&#8635;</span> Exportando...';

  const exportData = {
    produtoId,
    exportadoEm: new Date().toISOString(),
    rotulos: [],
  };

  for (const r of rotulosData) {
    const rotuloExport = {
      id:                   r.id,
      conteudoLiquido:      r.conteudoLiquido,
      unidadeMedida:        r.unidadeMedida,
      fabricante:           r.fabricante,
      cnpjFabricante:       r.cnpjFabricante,
      servicoInspecao:      r.servicoInspecao,
      condicoesConservacao: r.condicoesConservacao,
      fotos: [],
    };

    for (const foto of (r.fotos || [])) {
      try {
        const resp   = await fetch(`/uploads/produtos/${foto.nomeSalvo}`);
        const blob   = await resp.blob();
        const base64 = await blobParaBase64(blob);
        rotuloExport.fotos.push({
          nome:       foto.nomeOriginal,
          nomeSalvo:  foto.nomeSalvo,
          mimeType:   foto.mimeType || blob.type || 'image/jpeg',
          base64,
        });
      } catch(e) {
        console.warn('Não foi possível converter foto:', foto.nomeOriginal, e);
      }
    }

    exportData.rotulos.push(rotuloExport);
  }

  // Gerar e baixar o JSON
  const json    = JSON.stringify(exportData, null, 2);
  const blob    = new Blob([json], { type: 'application/json' });
  const url     = URL.createObjectURL(blob);
  const anchor  = document.createElement('a');
  anchor.href     = url;
  anchor.download = `rotulos_produto_${produtoId}_${Date.now()}.json`;
  anchor.click();
  URL.revokeObjectURL(url);

  btn.disabled = false;
  btn.innerHTML = `
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
    </svg> Exportar`;
}

function blobParaBase64(blob) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload  = () => resolve(reader.result.split(',')[1]); // remove prefixo data:...;base64,
    reader.onerror = reject;
    reader.readAsDataURL(blob);
  });
}

/* ── Rótulos ────────────────────────────────────────── */
const UNIDADES = ['ml','L','g','kg','mg','un','pç','cx'];

function abrirFormRotulo(rotulo) {
  const wrap  = document.getElementById('rotulo-form-wrap');
  const titulo = document.getElementById('rotulo-form-titulo');

  // Limpar / preencher campos
  document.getElementById('rf-id').value           = rotulo ? rotulo.id : '';
  document.getElementById('rf-conteudo').value      = rotulo?.conteudoLiquido || '';
  document.getElementById('rf-unidade').value       = rotulo?.unidadeMedida   || '';
  document.getElementById('rf-fabricante').value    = rotulo?.fabricante       || '';
  document.getElementById('rf-cnpj').value          = rotulo?.cnpjFabricante   || '';
  document.getElementById('rf-inspecao').value      = rotulo?.servicoInspecao  || '';
  document.getElementById('rf-conservacao').value   = rotulo?.condicoesConservacao || '';
  titulo.textContent = rotulo ? 'Editar rótulo' : 'Novo rótulo';

  // Fotos
  const selectedIds = new Set((rotulo?.fotosIds || []).map(Number));
  document.querySelectorAll('.rf-foto-item').forEach(el => {
    const arqId = parseInt(el.dataset.id);
    if (selectedIds.has(arqId)) {
      el.classList.add('selected');
    } else {
      el.classList.remove('selected');
    }
  });

  wrap.style.display = 'block';
  wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  document.getElementById('rotulo-form-status').textContent = '';
}

function fecharFormRotulo() {
  document.getElementById('rotulo-form-wrap').style.display = 'none';
}

function toggleFotoSelect(id) {
  const el = document.querySelector(`.rf-foto-item[data-id="${id}"]`);
  if (!el) return;
  el.classList.toggle('selected');
}

async function salvarRotulo() {
  const status  = document.getElementById('rotulo-form-status');
  const rotuloId = document.getElementById('rf-id').value;
  const isEdit   = !!rotuloId;

  const fotosIds = Array.from(document.querySelectorAll('.rf-foto-item.selected'))
    .map(el => parseInt(el.dataset.id));

  const payload = {
    conteudoLiquido:      document.getElementById('rf-conteudo').value.trim(),
    unidadeMedida:        document.getElementById('rf-unidade').value,
    fabricante:           document.getElementById('rf-fabricante').value.trim(),
    cnpjFabricante:       document.getElementById('rf-cnpj').value.trim(),
    servicoInspecao:      document.getElementById('rf-inspecao').value.trim(),
    condicoesConservacao: document.getElementById('rf-conservacao').value.trim(),
    fotosIds,
  };

  status.textContent = 'Salvando...';

  const url = isEdit
    ? `/produtos/${produtoIdArq}/rotulos/${rotuloId}/editar`
    : `/produtos/${produtoIdArq}/rotulos`;

  try {
    const resp = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await resp.json();

    if (data.ok) {
      status.textContent = '✅ Salvo!';
      fecharFormRotulo();
      // Atualizar o card na lista
      const lista  = document.getElementById('rotulo-lista');
      const empty  = document.getElementById('rotulo-empty');
      const rotulos = lista.querySelectorAll('.rotulo-card');

      if (isEdit) {
        const old = document.getElementById(`rcard-${rotuloId}`);
        if (old) old.replaceWith(buildRotuloCard(data.rotulo, old.dataset.idx || 0));
      } else {
        empty.style.display = 'none';
        lista.appendChild(buildRotuloCard(data.rotulo, rotulos.length));
      }
    } else {
      status.textContent = `❌ ${data.erro}`;
    }
  } catch(e) {
    status.textContent = '❌ Erro de conexão.';
  }
}

async function deletarRotulo(id) {
  if (!confirm('Remover este rótulo?')) return;
  try {
    const resp = await fetch(`/produtos/${produtoIdArq}/rotulos/${id}/deletar`, { method: 'POST' });
    const data = await resp.json();
    if (data.ok) {
      document.getElementById(`rcard-${id}`)?.remove();
      const lista = document.getElementById('rotulo-lista');
      if (!lista.querySelector('.rotulo-card')) {
        document.getElementById('rotulo-empty').style.display = '';
      }
      // Renumerar
      lista.querySelectorAll('.rotulo-card .rcard-num').forEach((el, i) => el.textContent = `#${i+1}`);
    }
  } catch(e) { alert('Erro ao remover rótulo.'); }
}

function buildRotuloCard(r, idx) {
  const card = document.createElement('div');
  card.className = 'rotulo-card';
  card.id = `rcard-${r.id}`;
  card.dataset.idx = idx;

  const badge = r.conteudoLiquido
    ? `<span class="rcard-badge">${r.conteudoLiquido}${r.unidadeMedida ? ' '+r.unidadeMedida : ''}</span>`
    : '';

  let fieldsHtml = '';
  if (r.cnpjFabricante)      fieldsHtml += `<div class="rcard-field"><span>CNPJ</span><p>${r.cnpjFabricante}</p></div>`;
  if (r.servicoInspecao)     fieldsHtml += `<div class="rcard-field"><span>Inspeção</span><p>${r.servicoInspecao}</p></div>`;
  if (r.condicoesConservacao) fieldsHtml += `<div class="rcard-field" style="grid-column:1/-1"><span>Conservação</span><p>${r.condicoesConservacao}</p></div>`;

  let fotosHtml = '';
  if (r.fotos && r.fotos.length > 0) {
    fotosHtml = `<div class="rcard-fotos"><p class="rcard-fotos-label">Fotos do rótulo</p><div style="display:flex;flex-wrap:wrap;gap:.5rem;">`;
    r.fotos.forEach(f => {
      fotosHtml += `<div style="display:flex;align-items:center;gap:.4rem;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:.3rem .5rem;">
        <img src="/uploads/produtos/${f.nomeSalvo}" style="width:36px;height:36px;object-fit:cover;border-radius:4px;cursor:pointer;"
          onclick="abrirLightbox('/uploads/produtos/${f.nomeSalvo}')" title="${f.nomeOriginal}">
        <span style="font-size:.75rem;color:var(--text);max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${f.nomeOriginal}</span>
      </div>`;
    });
    fotosHtml += `</div></div>`;
  }

  card.innerHTML = `
    <div class="rcard-header">
      <div class="rcard-title">
        <span class="rcard-num">#${parseInt(idx)+1}</span>
        <strong>${r.fabricante || 'Sem fabricante'}</strong>
        ${badge}
      </div>
      <div style="display:flex;gap:.4rem;">
        <button class="btn btn-secondary btn-sm" onclick="abrirFormRotulo(${JSON.stringify(r).replace(/"/g,'&quot;')})">✏️ Editar</button>
        <button class="btn btn-danger btn-sm" onclick="deletarRotulo(${r.id})">🗑️</button>
      </div>
    </div>
    <div class="rcard-body">${fieldsHtml}</div>
    ${fotosHtml}`;

  return card;
}

/* ── Upload de arquivos ── */
const produtoIdArq = <%= produto.id %>;

function formatBytes(b) {
  return b < 1024*1024 ? `${Math.round(b/1024)} KB` : `${(b/1024/1024).toFixed(1)} MB`;
}

function buildArquivoCard(arq) {
  const div = document.createElement('div');
  div.className = 'arquivo-card';
  div.id = `arq-${arq.id}`;

  if (arq.tipo === 'image') {
    div.innerHTML = `
      <img class="arquivo-thumb" src="/uploads/produtos/${arq.nomeSalvo}"
        alt="${arq.nomeOriginal}" title="Clique para ampliar"
        onclick="abrirLightbox('/uploads/produtos/${arq.nomeSalvo}')">`;
  } else {
    div.innerHTML = `
      <div class="arquivo-pdf-thumb"
        onclick="window.open('/uploads/produtos/${arq.nomeSalvo}','_blank')"
        title="Abrir PDF">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none"
          stroke="#dc2626" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
      </div>`;
  }

  // Nome editável inline
  div.innerHTML += `
    <div class="arquivo-info">
      <div class="arquivo-nome-wrap">
        <span class="arquivo-nome" id="nome-txt-${arq.id}"
          title="Clique para renomear" onclick="iniciarRename(${arq.id})">${arq.nomeOriginal}</span>
        <input class="arquivo-nome-input" id="nome-inp-${arq.id}"
          style="display:none;" value="${arq.nomeOriginal}"
          onblur="salvarRename(${arq.id})"
          onkeydown="if(event.key==='Enter')salvarRename(${arq.id});if(event.key==='Escape')cancelarRename(${arq.id});">
      </div>
      <div class="arquivo-meta">${formatBytes(arq.tamanho || 0)}</div>
    </div>
    <button class="arquivo-del" onclick="deletarArquivo(${arq.id})" title="Remover">✕</button>`;

  return div;
}


/* ── PDF.js loader ── */
async function getPdfjsLib() {
  if (window._pdfjsLib) return window._pdfjsLib;
  // Aguarda o módulo ES carregar e expor globalmente
  const mod = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.min.mjs');
  mod.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.worker.min.mjs';
  window._pdfjsLib = mod;
  return mod;
}

/* ── Converte PDF em array de File (JPG por página) ── */
async function pdfParaJpgs(file, onPagina) {
  const pdfjsLib = await getPdfjsLib();
  const buffer   = await file.arrayBuffer();
  const pdf      = await pdfjsLib.getDocument({ data: buffer }).promise;
  const total    = pdf.numPages;
  const jpgFiles = [];

  for (let i = 1; i <= total; i++) {
    onPagina && onPagina(i, total);
    const page     = await pdf.getPage(i);
    const viewport = page.getViewport({ scale: 2.0 }); // 200% = boa qualidade
    const canvas   = document.createElement('canvas');
    canvas.width   = viewport.width;
    canvas.height  = viewport.height;
    await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.92));
    const baseName = file.name.replace(/\.pdf$/i, '');
    const jpgName  = total === 1 ? `${baseName}.jpg` : `${baseName}_p${i}.jpg`;
    jpgFiles.push(new File([blob], jpgName, { type: 'image/jpeg' }));
  }
  return jpgFiles;
}

async function processarArquivos(files) {
  if (!files || files.length === 0) return;

  const progress = document.getElementById('upload-progress');
  const fill     = document.getElementById('upload-progress-fill');
  const msg      = document.getElementById('upload-msg');
  const pct      = document.getElementById('upload-pct');
  const emptyDiv = document.getElementById('empty-arquivos');
  const grid     = document.getElementById('arquivo-grid');

  progress.classList.add('visible');

  // Separar PDFs de imagens e converter PDFs
  const filesFinais = [];
  const arr = Array.from(files);

  for (let i = 0; i < arr.length; i++) {
    const f = arr[i];
    if (f.type === 'application/pdf') {
      msg.textContent = `Convertendo PDF "${f.name}"...`;
      fill.style.width = '15%'; pct.textContent = '15%';
      try {
        const jpgs = await pdfParaJpgs(f, (pg, tot) => {
          const p = Math.round(15 + (pg/tot)*55);
          fill.style.width = p + '%'; pct.textContent = p + '%';
          msg.textContent = `Convertendo página ${pg}/${tot}...`;
        });
        filesFinais.push(...jpgs);
      } catch(e) {
        console.error(e);
        msg.textContent = `❌ Erro ao converter ${f.name}: ${e.message}`;
      }
    } else {
      filesFinais.push(f);
    }
  }

  if (filesFinais.length === 0) {
    setTimeout(() => progress.classList.remove('visible'), 3000);
    return;
  }

  msg.textContent = `Enviando ${filesFinais.length} arquivo(s)...`;
  fill.style.width = '70%'; pct.textContent = '70%';

  const fd = new FormData();
  filesFinais.forEach(f => fd.append('arquivos', f));

  try {
    const resp = await fetch(`/produtos/${produtoIdArq}/arquivos`, {
      method: 'POST',
      body: fd,
    });
    fill.style.width = '100%'; pct.textContent = '100%';

    const data = await resp.json();
    if (data.ok) {
      msg.textContent = `✅ ${data.arquivos.length} arquivo(s) enviado(s)!`;
      data.arquivos.forEach(arq => {
        grid.appendChild(buildArquivoCard(arq));
        emptyDiv.style.display = 'none';
      });
      atualizarBadgeAba();
    } else {
      msg.textContent = `❌ ${data.erro || 'Erro no envio'}`;
    }
  } catch(e) {
    msg.textContent = '❌ Erro de conexão.';
  }

  setTimeout(() => {
    progress.classList.remove('visible');
    fill.style.width = '0%';
    document.getElementById('upload-input').value = '';
  }, 3000);
}

async function deletarArquivo(id) {
  if (!confirm('Remover este arquivo?')) return;
  try {
    const resp = await fetch(`/produtos/${produtoIdArq}/arquivos/${id}/deletar`, { method: 'POST' });
    const data = await resp.json();
    if (data.ok) {
      document.getElementById(`arq-${id}`)?.remove();
      atualizarBadgeAba();
      const grid = document.getElementById('arquivo-grid');
      if (!grid.querySelector('.arquivo-card')) document.getElementById('empty-arquivos').style.display = '';
    }
  } catch(e) { alert('Erro ao remover arquivo.'); }
}

/* ── Renomear arquivo inline ── */
function iniciarRename(id) {
  document.getElementById(`nome-txt-${id}`).style.display = 'none';
  const inp = document.getElementById(`nome-inp-${id}`);
  inp.style.display = 'block';
  inp.focus();
  inp.select();
}

function cancelarRename(id) {
  const txt = document.getElementById(`nome-txt-${id}`);
  document.getElementById(`nome-inp-${id}`).style.display = 'none';
  txt.style.display = 'block';
}

async function salvarRename(id) {
  const inp  = document.getElementById(`nome-inp-${id}`);
  const txt  = document.getElementById(`nome-txt-${id}`);
  const nome = inp.value.trim();
  if (!nome) { cancelarRename(id); return; }

  try {
    const resp = await fetch(`/produtos/${produtoIdArq}/arquivos/${id}/renomear`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nomeOriginal: nome }),
    });
    const data = await resp.json();
    if (data.ok) {
      txt.textContent = data.nomeOriginal;
      txt.title = data.nomeOriginal;
      inp.value = data.nomeOriginal;
    }
  } catch(e) { /* silencioso */ }
  cancelarRename(id);
}

function atualizarBadgeAba() {
  const count = document.querySelectorAll('#arquivo-grid .arquivo-card').length;
  // O badge está no 3º tab-btn (index 2)
  const btn = document.querySelectorAll('.tab-btn')[2];
  let badge = btn.querySelector('span[data-badge]');
  if (count > 0) {
    if (!badge) {
      badge = document.createElement('span');
      badge.dataset.badge = '1';
      badge.style.cssText = 'background:var(--blue);color:#fff;border-radius:999px;font-size:.65rem;padding:.1rem .45rem;font-weight:700;margin-left:.2rem;';
      btn.appendChild(badge);
    }
    badge.textContent = count;
  } else {
    badge?.remove();
  }
}

/* ── Drag & Drop ── */
const uploadZone = document.getElementById('upload-zone');
if (uploadZone) {
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
  uploadZone.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.classList.remove('drag-over');
    processarArquivos(e.dataTransfer.files);
  });
}

/* ── Lightbox ── */
function abrirLightbox(src) {
  const lb = document.getElementById('lightbox');
  lb.querySelector('img').src = src;
  lb.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function fecharLightbox() {
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { fecharLightbox(); fecharChecklist(); }
});

/* ── Modal Checklist ── */
function abrirChecklist(cl, respostasMap) {
  clAtualId = cl.id;
  document.getElementById('cl-modal-title').textContent = `📋 ${cl.codigo} — ${cl.nome}`;
  document.getElementById('cl-save-status').textContent = '';

  const body = document.getElementById('cl-modal-body');
  let html = '';

  (cl.secoes || []).forEach(s => {
    const itens = s.itens || [];

    // Verifica se algum item aceita N/A para saber se exibe coluna
    const temNA = itens.some(it => it.aceitaNaoAplicavel);

    html += `<div class="cl-secao">`;
    html += `<div class="cl-secao-title">📂 ${s.titulo}</div>`;
    if (s.descricao) html += `<p class="cl-secao-desc">${s.descricao}</p>`;

    if (itens.length === 0) {
      html += `<p style="font-size:.8rem;color:var(--text-muted);padding:.5rem 0;">Nenhum item nesta seção.</p>`;
    } else {
      html += `<div style="overflow-x:auto;">`;
      html += `<table class="cl-table">`;
      html += `<thead><tr>`;
      html += `<th class="th-pergunta">Pergunta</th>`;
      html += `<th title="Conforme">✅<br><span style="font-size:.65rem;font-weight:600;">Conforme</span></th>`;
      html += `<th title="Não conforme">❌<br><span style="font-size:.65rem;font-weight:600;">Não conf.</span></th>`;
      if (temNA) html += `<th title="Não aplicável">➖<br><span style="font-size:.65rem;font-weight:600;">N/A</span></th>`;
      html += `<th title="Não avaliado">⬜<br><span style="font-size:.65rem;font-weight:600;">N/Aval.</span></th>`;
      html += `<th class="th-obs">Observação</th>`;
      html += `</tr></thead><tbody>`;

      itens.forEach(it => {
        const r     = respostasMap[it.id] || {};
        const atual = r.resultado || 'NAO_AVALIADO';
        const obs   = r.observacao || '';
        const cols  = ['CONFORME','NAO_CONFORME', ...(temNA ? ['NAO_APLICAVEL'] : []), 'NAO_AVALIADO'];

        html += `<tr data-item-id="${it.id}">`;

        // Pergunta (+ ajuda)
        html += `<td class="td-pergunta">${it.pergunta}`;
        if (it.descricaoAjuda) html += `<br><span class="td-ajuda" style="font-size:.73rem;color:var(--text-muted);font-style:italic;">${it.descricaoAjuda}</span>`;
        html += `</td>`;

        // Bolinhas
        cols.forEach(col => {
          html += `<td class="td-dot">`;
          html += `<input class="cl-radio" type="radio" data-col="${col}"
            name="item_${it.id}" id="r_${it.id}_${col}"
            value="${col}" ${atual === col ? 'checked' : ''}>`;
          html += `<label class="cl-dot-label" for="r_${it.id}_${col}" title="${col.replace(/_/g,' ')}"></label>`;
          html += `</td>`;
        });

        // Observação inline
        html += `<td><textarea class="cl-obs-inline" id="obs_${it.id}" rows="1"
          placeholder="Obs...">${obs}</textarea></td>`;

        html += `</tr>`;
      });

      html += `</tbody></table></div>`;
    }
    html += `</div>`;
  });

  if (!html) html = '<p style="color:var(--text-muted);font-size:.9rem;">Nenhum item nesta checklist.</p>';
  body.innerHTML = html;

  document.getElementById('cl-modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function fecharChecklist() {
  document.getElementById('cl-modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
  clAtualId = null;
}

async function salvarChecklist() {
  const status = document.getElementById('cl-save-status');
  status.textContent = 'Salvando...';

  const respostas = {};
  // Itens agora estão em <tr data-item-id>
  document.querySelectorAll('tr[data-item-id]').forEach(row => {
    const itemId  = row.dataset.itemId;
    const radioEl = row.querySelector(`input[name="item_${itemId}"]:checked`);
    const obsEl   = document.getElementById(`obs_${itemId}`);
    respostas[itemId] = {
      resultado:  radioEl ? radioEl.value : 'NAO_AVALIADO',
      observacao: obsEl ? obsEl.value : '',
    };
  });

  try {
    const resp = await fetch(`/produtos/${produtoId}/checklist/${clAtualId}/respostas`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ respostas }),
    });
    const data = await resp.json();
    if (data.ok) {
      status.textContent = '✅ Salvo!';
      status.style.color = 'var(--success)';
      setTimeout(() => { fecharChecklist(); location.reload(); }, 900);
    } else {
      status.textContent = '❌ Erro ao salvar.';
      status.style.color = 'var(--danger)';
    }
  } catch(e) {
    status.textContent = '❌ Erro de conexão.';
    status.style.color = 'var(--danger)';
  }
}

/* ── Fechar modais com ESC / overlay ── */
document.getElementById('cl-modal-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('cl-modal-overlay')) fecharChecklist();
});
document.getElementById('lightbox').addEventListener('click', e => {
  if (e.target === document.getElementById('lightbox')) fecharLightbox();
});

/* ── Auto-esconder alertas ── */
setTimeout(() => {
  const a = document.getElementById('alert-box');
  if (a) { a.style.transition = 'opacity .4s'; a.style.opacity = '0'; }
}, 4000);
</script>
<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" onclick="fecharLightbox()">✕</button>
  <img src="" alt="Preview">
</div>

</body>
</html>
