<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/_head') %>
  <title><%= produto.marca %> — FoodTech</title>
  <!-- PDF.js para conversão de PDF em imagens no browser -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.2.67/pdf.min.mjs" type="module" id="pdfjs-script"></script>
  <script>
    // Compat shim: exposto globalmente após carregamento
    window._pdfjsReady = false;
    window._pdfjsLib   = null;
  </script>
  <style>
    /* ── Abas ── */
    .tabs-bar {
      display: flex;
      gap: 0;
      border-bottom: 2px solid var(--border);
      margin-bottom: 1.75rem;
    }
    .tab-btn {
      padding: .65rem 1.35rem;
      font-family: inherit;
      font-size: .875rem;
      font-weight: 600;
      color: var(--text-muted);
      background: none;
      border: none;
      border-bottom: 2.5px solid transparent;
      margin-bottom: -2px;
      cursor: pointer;
      transition: color var(--transition), border-color var(--transition);
      display: flex;
      align-items: center;
      gap: .45rem;
    }
    .tab-btn:hover { color: var(--blue); }
    .tab-btn.active { color: var(--blue); border-bottom-color: var(--blue); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Status badge ── */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .3rem .9rem;
      border-radius: 999px;
      font-size: .8rem;
      font-weight: 700;
      letter-spacing: .2px;
      border: 1.5px solid;
    }

    /* ── Checklist cards ── */
    .checklist-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.1rem 1.4rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      cursor: pointer;
      transition: box-shadow var(--transition), border-color var(--transition);
    }
    .checklist-card:hover {
      box-shadow: var(--shadow);
      border-color: var(--blue-mid);
    }
    .checklist-card-info { flex: 1; }
    .checklist-card-title { font-weight: 600; color: var(--text); font-size: .95rem; }
    .checklist-card-sub   { font-size: .8rem; color: var(--text-muted); margin-top:.2rem; }

    /* ── Progresso ── */
    .progress-bar-wrap {
      background: var(--bg);
      border-radius: 999px;
      height: 7px;
      overflow: hidden;
      margin-top: .5rem;
    }
    .progress-bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--blue), #038aef);
      transition: width .4s ease;
    }

    /* ── Modal checklist ── */
    .cl-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(10,20,40,.5);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 1.5rem 1rem;
      z-index: 950;
      opacity: 0;
      pointer-events: none;
      transition: opacity .22s ease;
      overflow-y: auto;
    }
    .cl-modal-overlay.open { opacity: 1; pointer-events: all; }
    .cl-modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: 0 24px 64px rgba(0,0,0,.2);
      width: 100%;
      max-width: 720px;
      transform: scale(.93) translateY(16px);
      transition: transform .24s cubic-bezier(.34,1.56,.64,1), opacity .22s ease;
      opacity: 0;
      margin: auto;
    }
    .cl-modal-overlay.open .cl-modal { transform: scale(1) translateY(0); opacity: 1; }
    .cl-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: var(--surface);
      z-index: 2;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
    .cl-modal-header h3 { font-size: 1rem; font-weight: 700; color: var(--text); }
    .cl-modal-body { padding: 1.25rem 1.5rem; max-height: 65vh; overflow-y: auto; }
    .cl-modal-footer {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: .6rem;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      position: sticky;
      bottom: 0;
      background: var(--surface);
      border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    }
    .modal-close-btn {
      background: none; border: none; font-size: 1.2rem;
      cursor: pointer; color: var(--text-muted); line-height: 1;
    }
    .modal-close-btn:hover { color: var(--danger); }

    /* ── Tabela de checklist ── */
    .cl-secao { margin-bottom: 2rem; }
    .cl-secao-title {
      font-size: .8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--text-muted);
      padding: .4rem 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: .5rem;
    }
    .cl-secao-desc {
      font-size: .78rem;
      color: var(--text-muted);
      font-style: italic;
      margin-bottom: .75rem;
    }

    /* Tabela por seção */
    .cl-table {
      width: 100%;
      border-collapse: collapse;
      font-size: .85rem;
    }
    .cl-table thead th {
      padding: .5rem .6rem;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .4px;
      text-transform: uppercase;
      color: var(--text-muted);
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      text-align: center;
      white-space: nowrap;
    }
    .cl-table thead th.th-pergunta { text-align: left; }
    .cl-table thead th.th-obs      { text-align: left; min-width: 140px; }

    .cl-table tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background var(--transition);
    }
    .cl-table tbody tr:last-child { border-bottom: none; }
    .cl-table tbody tr:hover { background: var(--blue-light); }

    .cl-table tbody td {
      padding: .65rem .6rem;
      vertical-align: middle;
    }
    .cl-table tbody td.td-pergunta {
      color: var(--text);
      font-weight: 500;
      line-height: 1.45;
    }
    .cl-table tbody td.td-ajuda {
      font-size: .75rem;
      color: var(--text-muted);
      font-style: italic;
    }
    .cl-table tbody td.td-dot { text-align: center; }

    /* Radio como ponto/bolinha */
    .cl-radio { display: none; }
    .cl-dot-label {
      display: inline-block;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid var(--border);
      background: var(--surface);
      cursor: pointer;
      transition: border-color .15s, background .15s, transform .12s;
      position: relative;
    }
    .cl-dot-label::after {
      content: '';
      position: absolute;
      inset: 4px;
      border-radius: 50%;
      background: transparent;
      transition: background .15s;
    }
    /* Hover */
    .cl-dot-label:hover { border-color: var(--blue-mid); transform: scale(1.1); }

    /* Checked states — dot fill por coluna */
    .cl-radio[data-col="CONFORME"]:checked     + .cl-dot-label { border-color:#16a34a; }
    .cl-radio[data-col="CONFORME"]:checked     + .cl-dot-label::after { background:#16a34a; }
    .cl-radio[data-col="NAO_CONFORME"]:checked  + .cl-dot-label { border-color:#dc2626; }
    .cl-radio[data-col="NAO_CONFORME"]:checked  + .cl-dot-label::after { background:#dc2626; }
    .cl-radio[data-col="NAO_APLICAVEL"]:checked + .cl-dot-label { border-color:#ca8a04; }
    .cl-radio[data-col="NAO_APLICAVEL"]:checked + .cl-dot-label::after { background:#ca8a04; }
    .cl-radio[data-col="NAO_AVALIADO"]:checked  + .cl-dot-label { border-color:var(--text-light); }
    .cl-radio[data-col="NAO_AVALIADO"]:checked  + .cl-dot-label::after { background:var(--text-light); }

    /* Observação inline */
    .cl-obs-inline {
      width: 100%;
      min-width: 120px;
      padding: .35rem .6rem;
      font-family: inherit;
      font-size: .8rem;
      color: var(--text);
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      outline: none;
      resize: none;
      transition: border-color var(--transition);
      height: 36px;
    }
    .cl-obs-inline:focus { border-color: var(--blue); height: 60px; }

    /* ── Formulário rótulo ── */
    .rotulo-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @media(max-width:640px){ .rotulo-grid { grid-template-columns: 1fr; } }

    /* ── Upload de arquivos ── */
    .upload-zone {
      border: 2.5px dashed var(--border);
      border-radius: var(--radius-lg);
      padding: 2.25rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: border-color .2s, background .2s;
      background: var(--bg);
      position: relative;
    }
    .upload-zone:hover, .upload-zone.drag-over {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    .upload-zone input[type=file] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }
    .upload-zone-icon { font-size: 2.2rem; margin-bottom: .5rem; }
    .upload-zone-text { font-size: .9rem; font-weight: 600; color: var(--text); }
    .upload-zone-sub  { font-size: .78rem; color: var(--text-muted); margin-top: .25rem; }

    /* Grid de arquivos */
    .arquivo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .arquivo-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: box-shadow .18s, border-color .18s;
      position: relative;
    }
    .arquivo-card:hover {
      box-shadow: var(--shadow);
      border-color: var(--blue-mid);
    }
    .arquivo-thumb {
      width: 100%;
      height: 110px;
      object-fit: cover;
      display: block;
      cursor: pointer;
    }
    .arquivo-pdf-thumb {
      width: 100%;
      height: 110px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fef2f2;
      font-size: 2.5rem;
      cursor: pointer;
    }
    .arquivo-info {
      padding: .5rem .6rem;
      font-size: .75rem;
    }
    .arquivo-nome {
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .arquivo-meta { color: var(--text-muted); margin-top: .1rem; }
    .arquivo-del {
      position: absolute;
      top: .35rem;
      right: .35rem;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: rgba(220,38,38,.85);
      color: #fff;
      border: none;
      font-size: .8rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity .15s;
    }
    .arquivo-card:hover .arquivo-del { opacity: 1; }

    /* Nome renomeável */
    .arquivo-nome-wrap { position: relative; }
    .arquivo-nome {
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      cursor: pointer;
      display: block;
    }
    .arquivo-nome:hover { color: var(--blue); text-decoration: underline dotted; }
    .arquivo-nome-input {
      width: 100%;
      padding: .2rem .35rem;
      font-family: inherit;
      font-size: .75rem;
      font-weight: 600;
      color: var(--text);
      background: var(--white);
      border: 1.5px solid var(--blue);
      border-radius: var(--radius);
      outline: none;
    }

    /* Lightbox */
    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.88);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      transition: opacity .22s;
    }
    .lightbox.open { opacity: 1; pointer-events: all; }
    .lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      border-radius: var(--radius);
      box-shadow: 0 20px 60px rgba(0,0,0,.5);
    }
    .lightbox-close {
      position: fixed;
      top: 1rem;
      right: 1.25rem;
      background: none;
      border: none;
      color: #fff;
      font-size: 2rem;
      cursor: pointer;
      line-height: 1;
    }

    /* Upload progress */
    .upload-progress {
      margin-top: 1rem;
      display: none;
    }
    .upload-progress.visible { display: block; }
    .upload-progress-bar {
      height: 6px;
      background: var(--blue-light);
      border-radius: 999px;
      overflow: hidden;
    }
    .upload-progress-fill {
      height: 100%;
      background: var(--blue);
      border-radius: 999px;
      width: 0%;
      transition: width .3s ease;
    }

    /* ── Cards de rótulo ── */
    .rotulo-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      margin-bottom: .85rem;
      overflow: hidden;
      transition: box-shadow .18s;
    }
    .rotulo-card:hover { box-shadow: var(--shadow); }
    .rcard-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: .9rem 1.25rem;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      gap: .75rem;
    }
    .rcard-title {
      display: flex;
      align-items: center;
      gap: .55rem;
      flex: 1;
      flex-wrap: wrap;
    }
    .rcard-num {
      font-size: .7rem;
      font-weight: 700;
      color: var(--text-muted);
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: .1rem .4rem;
    }
    .rcard-badge {
      background: var(--blue-light);
      color: var(--blue);
      border: 1px solid var(--blue-mid);
      border-radius: 999px;
      font-size: .72rem;
      font-weight: 700;
      padding: .15rem .65rem;
    }
    .rcard-body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .5rem 1rem;
      padding: .9rem 1.25rem;
    }
    .rcard-field span {
      display: block;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .5px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: .2rem;
    }
    .rcard-field p { font-size: .875rem; color: var(--text); }
    .rcard-fotos {
      padding: .75rem 1.25rem;
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    .rcard-fotos-label {
      font-size: .68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--text-muted);
      margin-bottom: .5rem;
    }
    /* Foto selecionada no picker */
    .rf-foto-item.selected { border-color: var(--blue) !important; }
    .rf-foto-item.selected .rf-foto-check { display: flex !important; }
  </style>
</head>
<body>

<%- include('../partials/_user-layout', { currentPage: 'produtos', username: username }) %>

<div class="app-content">

  <!-- Breadcrumb + cabeçalho -->
  <div class="page-header fade-up" style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
    <div>
      <p style="font-size:.8rem; color:var(--text-muted); margin-bottom:.3rem;">
        <a href="/produtos" style="color:var(--blue);">← Produtos</a>
      </p>
      <h1><%= produto.marca %></h1>
      <p><%= produto.denominacaoVenda %></p>
    </div>
    <%
      const sl = statusLabels[produto.statusAnalise] || statusLabels['CHECKLIST_EM_ANDAMENTO'];
    %>
    <span class="status-badge" style="color:<%= sl.color %>; background:<%= sl.bg %>; border-color:<%= sl.border %>;">
      ● <%= sl.label %>
    </span>
  </div>

  <!-- Alertas -->
  <% if (sucesso) { %>
  <div class="alert alert-success fade-up" id="alert-box">
    <span>✅</span>
    <% if (sucesso === 'rotulo_salvo') { %> Dados do rótulo salvos com sucesso! <% } %>
  </div>
  <% } %>
  <% if (erro) { %>
  <div class="alert alert-error fade-up" id="alert-box">
    <span>❌</span> Erro ao salvar. Tente novamente.
  </div>
  <% } %>

  <!-- Card principal com abas -->
  <div class="card fade-up d1">
    <div class="card-body" style="padding-bottom:0;">
      <nav class="tabs-bar" role="tablist">
        <button class="tab-btn <%= tab === 'identificacao' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('identificacao')">
          📋 Dados de Identificação Geral
        </button>
        <button class="tab-btn <%= tab === 'rotulo' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('rotulo')">
          🏷️ Dados Rótulo
        </button>
        <button class="tab-btn <%= tab === 'arquivos' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('arquivos')">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          Rótulo
          <% if (arquivos && arquivos.length > 0) { %>
          <span style="background:var(--blue);color:#fff;border-radius:999px;font-size:.65rem;padding:.1rem .45rem;font-weight:700;margin-left:.2rem;"><%= arquivos.length %></span>
          <% } %>
        </button>
        <button class="tab-btn <%= tab === 'analise' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('analise')">
          🔍 Análise
        </button>
      </nav>
    </div>

    <!-- ══ ABA 1: IDENTIFICAÇÃO GERAL ══ -->
    <div id="aba-identificacao" class="tab-panel card-body <%= tab === 'identificacao' ? 'active' : '' %>">
      <div class="rotulo-grid">
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Marca</p>
          <p style="font-weight:600;color:var(--text);"><%= produto.marca %></p>
        </div>
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Denominação de venda</p>
          <p style="color:var(--text);"><%= produto.denominacaoVenda %></p>
        </div>
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Categoria</p>
          <p style="color:var(--text);"><%= produto.categoria ? produto.categoria.nome : '—' %></p>
        </div>
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Subcategoria</p>
          <p style="color:var(--text);"><%= produto.subcategoria ? produto.subcategoria.nome : '—' %></p>
        </div>
        <% if (produto.descricao) { %>
        <div style="grid-column:1/-1;">
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Descrição</p>
          <p style="color:var(--text-muted);line-height:1.6;"><%= produto.descricao %></p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- ══ ABA 2: DADOS RÓTULO ══ -->
    <div id="aba-rotulo" class="tab-panel card-body <%= tab === 'rotulo' ? 'active' : '' %>">

      <!-- Cabeçalho da seção -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.6rem;">
        <div>
          <p style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.2rem;">Rótulos cadastrados</p>
          <p style="font-size:.82rem;color:var(--text-muted);">Cada entrada representa um rótulo/embalagem diferente deste produto.</p>
        </div>
        <div style="display:flex;gap:.5rem;">
          <button class="btn btn-secondary btn-sm" id="btn-exportar" onclick="exportarRotulos()">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Exportar
          </button>
          <button class="btn btn-primary btn-sm" onclick="abrirFormRotulo(null)">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Novo rótulo
          </button>
        </div>
      </div>

      <!-- Formulário de adicionar/editar (oculto por padrão) -->
      <div id="rotulo-form-wrap" style="display:none;margin-bottom:1.5rem;">
        <div style="background:var(--bg);border:1.5px solid var(--blue-mid);border-radius:var(--radius-lg);padding:1.25rem 1.4rem;">
          <p style="font-size:.75rem;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--blue);margin-bottom:1rem;" id="rotulo-form-titulo">Novo rótulo</p>
          <input type="hidden" id="rf-id" value="">
          <div class="rotulo-grid">
            <div class="form-group">
              <label for="rf-conteudo">Conteúdo líquido</label>
              <input type="text" id="rf-conteudo" placeholder="Ex: 1000">
            </div>
            <div class="form-group">
              <label for="rf-unidade">Unidade de medida</label>
              <select id="rf-unidade">
                <option value="">Selecione...</option>
                <% ['ml','L','g','kg','mg','un','pç','cx'].forEach(u => { %>
                <option value="<%= u %>"><%= u %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="grid-column:1/-1;">
              <label for="rf-fabricante">Fabricante</label>
              <input type="text" id="rf-fabricante" placeholder="Razão social do fabricante">
            </div>
            <div class="form-group">
              <label for="rf-cnpj">CNPJ do fabricante</label>
              <input type="text" id="rf-cnpj" placeholder="00.000.000/0000-00">
            </div>
            <div class="form-group">
              <label for="rf-inspecao">Serviço de inspeção</label>
              <input type="text" id="rf-inspecao" placeholder="Ex: SIF 1234, SISBI">
            </div>
            <div class="form-group" style="grid-column:1/-1;">
              <label for="rf-conservacao">Condições de conservação</label>
              <textarea id="rf-conservacao" rows="2" style="width:100%;padding:.65rem .9rem;font-family:inherit;font-size:.875rem;color:var(--text);background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);outline:none;resize:vertical;" placeholder="Ex: Manter refrigerado entre 2°C e 8°C"></textarea>
            </div>
          </div>

          <!-- Seletor de fotos -->
          <% if (arquivos && arquivos.filter(a => a.tipo === 'image').length > 0) { %>
          <div style="margin-top:1rem;">
            <p style="font-size:.75rem;font-weight:700;letter-spacing:.4px;text-transform:uppercase;color:var(--text-muted);margin-bottom:.6rem;">Fotos referentes a este rótulo</p>
            <div style="display:flex;flex-wrap:wrap;gap:.5rem;" id="rf-foto-picker">
              <% arquivos.filter(a => a.tipo === 'image').forEach(arq => { %>
              <div class="rf-foto-item" data-id="<%= arq.id %>"
                onclick="toggleFotoSelect(<%= arq.id %>)"
                style="position:relative;cursor:pointer;border-radius:var(--radius);overflow:hidden;border:2.5px solid transparent;transition:border-color .15s;width:80px;">
                <img src="/uploads/produtos/<%= arq.nomeSalvo %>"
                  style="width:80px;height:72px;object-fit:cover;display:block;"
                  title="<%= arq.nomeOriginal %>">
                <div style="padding:.25rem .3rem;background:var(--surface);font-size:.65rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3;">
                  <%= arq.nomeOriginal %>
                </div>
                <div class="rf-foto-check" style="position:absolute;top:3px;right:3px;width:18px;height:18px;border-radius:50%;background:var(--blue);color:#fff;font-size:.65rem;display:none;align-items:center;justify-content:center;">✓</div>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>

          <div style="display:flex;gap:.6rem;justify-content:flex-end;margin-top:1.1rem;">
            <span id="rotulo-form-status" style="font-size:.8rem;color:var(--text-muted);align-self:center;margin-right:auto;"></span>
            <button class="btn btn-ghost btn-sm" onclick="fecharFormRotulo()">Cancelar</button>
            <button class="btn btn-primary btn-sm" onclick="salvarRotulo()">💾 Salvar rótulo</button>
          </div>
        </div>
      </div>

      <!-- Lista de rótulos -->
      <div id="rotulo-lista">
        <% if (!rotulos || rotulos.length === 0) { %>
        <div id="rotulo-empty" style="text-align:center;padding:2rem 1rem;color:var(--text-muted);">
          <div style="font-size:1.8rem;margin-bottom:.5rem;">🏷️</div>
          <p style="font-weight:600;color:var(--text);margin-bottom:.2rem;">Nenhum rótulo cadastrado</p>
          <p style="font-size:.85rem;">Clique em "Novo rótulo" para adicionar.</p>
        </div>
        <% } else { %>
        <div id="rotulo-empty" style="display:none;"></div>
        <% } %>

        <% (rotulos || []).forEach((r, i) => { %>
        <div class="rotulo-card" id="rcard-<%= r.id %>">
          <div class="rcard-header">
            <div class="rcard-title">
              <span class="rcard-num">#<%= i+1 %></span>
              <strong><%= r.fabricante || 'Sem fabricante' %></strong>
              <% if (r.conteudoLiquido) { %>
              <span class="rcard-badge"><%= r.conteudoLiquido %><%= r.unidadeMedida ? ' '+r.unidadeMedida : '' %></span>
