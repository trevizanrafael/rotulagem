            </div>
            <div style="display:flex;gap:.4rem;">
              <button class="btn btn-secondary btn-sm"
                onclick="abrirFormRotulo(<%= JSON.stringify(r) %>)">✏️ Editar</button>
              <button class="btn btn-danger btn-sm"
                onclick="deletarRotulo(<%= r.id %>)">🗑️</button>
            </div>
          </div>
          <div class="rcard-body">
            <% if (r.cnpjFabricante) { %><div class="rcard-field"><span>CNPJ</span><p><%= r.cnpjFabricante %></p></div><% } %>
            <% if (r.servicoInspecao) { %><div class="rcard-field"><span>Inspeção</span><p><%= r.servicoInspecao %></p></div><% } %>
            <% if (r.condicoesConservacao) { %><div class="rcard-field" style="grid-column:1/-1;"><span>Conservação</span><p><%= r.condicoesConservacao %></p></div><% } %>
          </div>
          <% if (r.fotos && r.fotos.length > 0) { %>
          <div class="rcard-fotos">
            <p class="rcard-fotos-label">Fotos do rótulo</p>
            <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
              <% r.fotos.forEach(f => { %>
              <div style="display:flex;align-items:center;gap:.4rem;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:.3rem .5rem;">
                <img src="/uploads/produtos/<%= f.nomeSalvo %>" style="width:36px;height:36px;object-fit:cover;border-radius:4px;cursor:pointer;"
                  onclick="abrirLightbox('/uploads/produtos/<%= f.nomeSalvo %>')" title="<%= f.nomeOriginal %>">
                <span style="font-size:.75rem;color:var(--text);max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= f.nomeOriginal %></span>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>
        </div>
        <% }) %>
      </div>
    </div>


    <!-- ══ ABA 3: RÓTULO (arquivos) ══ -->
    <div id="aba-arquivos" class="tab-panel card-body <%= tab === 'arquivos' ? 'active' : '' %>">

      <!-- Zona de upload -->
      <div class="upload-zone" id="upload-zone">
        <input type="file" id="upload-input" multiple accept="image/*,.pdf"
          onchange="processarArquivos(this.files)">
        <div class="upload-zone-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"
            style="color:var(--blue-dark);">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
        </div>
        <div class="upload-zone-text">Arraste os arquivos aqui ou clique para selecionar</div>
        <div class="upload-zone-sub">Imagens (JPG, PNG, WEBP) e PDF · Máx. 20 MB · PDFs são convertidos em imagens</div>
      </div>

      <!-- Barra de progresso -->
      <div class="upload-progress" id="upload-progress">
        <div style="display:flex;justify-content:space-between;font-size:.78rem;color:var(--text-muted);margin-bottom:.3rem;">
          <span id="upload-msg">Enviando...</span>
          <span id="upload-pct">0%</span>
        </div>
        <div class="upload-progress-bar">
          <div class="upload-progress-fill" id="upload-progress-fill"></div>
        </div>
      </div>

      <!-- Grid de arquivos -->
      <div class="arquivo-grid" id="arquivo-grid">
        <% (arquivos || []).forEach(arq => { %>
        <div class="arquivo-card" id="arq-<%= arq.id %>">
          <% if (arq.tipo === 'image') { %>
          <img class="arquivo-thumb" src="/uploads/produtos/<%= arq.nomeSalvo %>"
            alt="<%= arq.nomeOriginal %>" title="Clique para ampliar"
            onclick="abrirLightbox('/uploads/produtos/<%= arq.nomeSalvo %>')">
          <% } else { %>
          <div class="arquivo-pdf-thumb"
            onclick="window.open('/uploads/produtos/<%= arq.nomeSalvo %>','_blank')"
            title="Abrir PDF">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none"
              stroke="#dc2626" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <% } %>
          <div class="arquivo-info">
            <div class="arquivo-nome-wrap">
              <span class="arquivo-nome" id="nome-txt-<%= arq.id %>"
                title="Clique para renomear"
                onclick="iniciarRename(<%= arq.id %>)"><%= arq.nomeOriginal %></span>
              <input class="arquivo-nome-input" id="nome-inp-<%= arq.id %>"
                style="display:none;" value="<%= arq.nomeOriginal %>"
                onblur="salvarRename(<%= arq.id %>)"
                onkeydown="if(event.key==='Enter')salvarRename(<%= arq.id %>);if(event.key==='Escape')cancelarRename(<%= arq.id %>);">
            </div>
            <div class="arquivo-meta"><%= Math.round((arq.tamanho||0)/1024) %> KB</div>
          </div>
          <button class="arquivo-del" onclick="deletarArquivo(<%= arq.id %>)" title="Remover">✕</button>
        </div>
        <% }) %>
      </div>

      <% if (!arquivos || arquivos.length === 0) { %>
      <div id="empty-arquivos" class="empty-state" style="padding:1.5rem 0;">
        <div class="empty-state-icon" style="font-size:1.8rem;">📎</div>
        <p style="font-weight:600;color:var(--text);margin-bottom:.25rem;">Nenhum arquivo enviado</p>
        <p>Arraste imagens ou PDFs do rótulo para começar.</p>
      </div>
      <% } else { %>
      <div id="empty-arquivos" style="display:none;"></div>
      <% } %>

    </div>

    <!-- ══ ABA 4: ANÁLISE ══ -->
    <div id="aba-analise" class="tab-panel card-body <%= tab === 'analise' ? 'active' : '' %>">

      <!-- Status -->
      <div style="margin-bottom:1.75rem;">
        <p style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.6rem;">Status da análise</p>
        <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
          <% const statusOrdem = ['CHECKLIST_EM_ANDAMENTO','CHECKLIST_CONCLUIDA','PRONTO_PARA_IA','AVALIADO_POR_IA']; %>
          <% statusOrdem.forEach(s => { %>
          <%   const sl2 = statusLabels[s]; %>
          <%   const isAtual = produto.statusAnalise === s; %>
          <span class="status-badge"
            style="color:<%= sl2.color %>; background:<%= sl2.bg %>; border-color:<%= sl2.border %>; opacity:<%= isAtual ? 1 : 0.35 %>; font-size:.78rem;">
            <%= isAtual ? '●' : '○' %> <%= sl2.label %>
          </span>
          <% }) %>
        </div>
      </div>

      <!-- Lista de checklists -->
      <p style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.85rem;">Checklists aplicáveis</p>

      <% if (checklists.length === 0) { %>
      <div class="empty-state" style="padding:2rem 1rem;">
        <div class="empty-state-icon">📋</div>
        <p style="font-weight:600;color:var(--text);margin-bottom:.3rem;">Nenhum checklist vinculado</p>
        <p>Contate o administrador para vincular checklists à subcategoria deste produto.</p>
      </div>
      <% } else { %>
      <div style="display:flex;flex-direction:column;gap:.75rem;">
        <% checklists.forEach(cl => {
            let totalItens = 0, totalRespondidos = 0;
            (cl.secoes || []).forEach(s => {
              (s.itens || []).forEach(it => {
                totalItens++;
                const r = respostasMap[it.id];
                if (r && r.resultado !== 'NAO_AVALIADO') totalRespondidos++;
              });
            });
            const pct = totalItens > 0 ? Math.round(totalRespondidos/totalItens*100) : 0;
        %>
        <div class="checklist-card" onclick="abrirChecklist(<%= JSON.stringify(cl) %>, <%= JSON.stringify(respostasMap) %>)">
          <div class="checklist-card-info">
            <div class="checklist-card-title">📋 <%= cl.codigo %> — <%= cl.nome %></div>
            <div class="checklist-card-sub"><%= totalItens %> item<%= totalItens !== 1 ? 's' : '' %> · <%= pct %>% respondido<%= pct !== 1 ? 's' : '' %></div>
            <div class="progress-bar-wrap" style="max-width:260px;">
              <div class="progress-bar-fill" style="width:<%= pct %>%;"></div>
            </div>
          </div>
          <span class="btn btn-primary btn-sm">Preencher →</span>
        </div>
        <% }) %>
