<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/_head') %>
  <title><%= produto.marca %> — FoodTech</title>
  <style>
    /* ── Abas ── */
    .tabs-bar {
      display: flex;
      gap: 0;
      border-bottom: 2px solid var(--border);
      margin-bottom: 1.75rem;
    }
    .tab-btn {
      padding: .65rem 1.35rem;
      font-family: inherit;
      font-size: .875rem;
      font-weight: 600;
      color: var(--text-muted);
      background: none;
      border: none;
      border-bottom: 2.5px solid transparent;
      margin-bottom: -2px;
      cursor: pointer;
      transition: color var(--transition), border-color var(--transition);
      display: flex;
      align-items: center;
      gap: .45rem;
    }
    .tab-btn:hover { color: var(--blue); }
    .tab-btn.active { color: var(--blue); border-bottom-color: var(--blue); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Status badge ── */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .3rem .9rem;
      border-radius: 999px;
      font-size: .8rem;
      font-weight: 700;
      letter-spacing: .2px;
      border: 1.5px solid;
    }

    /* ── Checklist cards ── */
    .checklist-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.1rem 1.4rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      cursor: pointer;
      transition: box-shadow var(--transition), border-color var(--transition);
    }
    .checklist-card:hover {
      box-shadow: var(--shadow);
      border-color: var(--blue-mid);
    }
    .checklist-card-info { flex: 1; }
    .checklist-card-title { font-weight: 600; color: var(--text); font-size: .95rem; }
    .checklist-card-sub   { font-size: .8rem; color: var(--text-muted); margin-top:.2rem; }

    /* ── Progresso ── */
    .progress-bar-wrap {
      background: var(--bg);
      border-radius: 999px;
      height: 7px;
      overflow: hidden;
      margin-top: .5rem;
    }
    .progress-bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--blue), #038aef);
      transition: width .4s ease;
    }

    /* ── Modal checklist ── */
    .cl-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(10,20,40,.5);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 1.5rem 1rem;
      z-index: 950;
      opacity: 0;
      pointer-events: none;
      transition: opacity .22s ease;
      overflow-y: auto;
    }
    .cl-modal-overlay.open { opacity: 1; pointer-events: all; }
    .cl-modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: 0 24px 64px rgba(0,0,0,.2);
      width: 100%;
      max-width: 720px;
      transform: scale(.93) translateY(16px);
      transition: transform .24s cubic-bezier(.34,1.56,.64,1), opacity .22s ease;
      opacity: 0;
      margin: auto;
    }
    .cl-modal-overlay.open .cl-modal { transform: scale(1) translateY(0); opacity: 1; }
    .cl-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: var(--surface);
      z-index: 2;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
    .cl-modal-header h3 { font-size: 1rem; font-weight: 700; color: var(--text); }
    .cl-modal-body { padding: 1.25rem 1.5rem; max-height: 65vh; overflow-y: auto; }
    .cl-modal-footer {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: .6rem;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      position: sticky;
      bottom: 0;
      background: var(--surface);
      border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    }
    .modal-close-btn {
      background: none; border: none; font-size: 1.2rem;
      cursor: pointer; color: var(--text-muted); line-height: 1;
    }
    .modal-close-btn:hover { color: var(--danger); }

    /* ── Tabela de checklist ── */
    .cl-secao { margin-bottom: 2rem; }
    .cl-secao-title {
      font-size: .8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--text-muted);
      padding: .4rem 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: .5rem;
    }
    .cl-secao-desc {
      font-size: .78rem;
      color: var(--text-muted);
      font-style: italic;
      margin-bottom: .75rem;
    }

    /* Tabela por seção */
    .cl-table {
      width: 100%;
      border-collapse: collapse;
      font-size: .85rem;
    }
    .cl-table thead th {
      padding: .5rem .6rem;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .4px;
      text-transform: uppercase;
      color: var(--text-muted);
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      text-align: center;
      white-space: nowrap;
    }
    .cl-table thead th.th-pergunta { text-align: left; }
    .cl-table thead th.th-obs      { text-align: left; min-width: 140px; }

    .cl-table tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background var(--transition);
    }
    .cl-table tbody tr:last-child { border-bottom: none; }
    .cl-table tbody tr:hover { background: var(--blue-light); }

    .cl-table tbody td {
      padding: .65rem .6rem;
      vertical-align: middle;
    }
    .cl-table tbody td.td-pergunta {
      color: var(--text);
      font-weight: 500;
      line-height: 1.45;
    }
    .cl-table tbody td.td-ajuda {
      font-size: .75rem;
      color: var(--text-muted);
      font-style: italic;
    }
    .cl-table tbody td.td-dot { text-align: center; }

    /* Radio como ponto/bolinha */
    .cl-radio { display: none; }
    .cl-dot-label {
      display: inline-block;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid var(--border);
      background: var(--surface);
      cursor: pointer;
      transition: border-color .15s, background .15s, transform .12s;
      position: relative;
    }
    .cl-dot-label::after {
      content: '';
      position: absolute;
      inset: 4px;
      border-radius: 50%;
      background: transparent;
      transition: background .15s;
    }
    /* Hover */
    .cl-dot-label:hover { border-color: var(--blue-mid); transform: scale(1.1); }

    /* Checked states — dot fill por coluna */
    .cl-radio[data-col="CONFORME"]:checked     + .cl-dot-label { border-color:#16a34a; }
    .cl-radio[data-col="CONFORME"]:checked     + .cl-dot-label::after { background:#16a34a; }
    .cl-radio[data-col="NAO_CONFORME"]:checked  + .cl-dot-label { border-color:#dc2626; }
    .cl-radio[data-col="NAO_CONFORME"]:checked  + .cl-dot-label::after { background:#dc2626; }
    .cl-radio[data-col="NAO_APLICAVEL"]:checked + .cl-dot-label { border-color:#ca8a04; }
    .cl-radio[data-col="NAO_APLICAVEL"]:checked + .cl-dot-label::after { background:#ca8a04; }
    .cl-radio[data-col="NAO_AVALIADO"]:checked  + .cl-dot-label { border-color:var(--text-light); }
    .cl-radio[data-col="NAO_AVALIADO"]:checked  + .cl-dot-label::after { background:var(--text-light); }

    /* Observação inline */
    .cl-obs-inline {
      width: 100%;
      min-width: 120px;
      padding: .35rem .6rem;
      font-family: inherit;
      font-size: .8rem;
      color: var(--text);
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      outline: none;
      resize: none;
      transition: border-color var(--transition);
      height: 36px;
    }
    .cl-obs-inline:focus { border-color: var(--blue); height: 60px; }

    /* ── Formulário rótulo ── */
    .rotulo-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @media(max-width:640px){ .rotulo-grid { grid-template-columns: 1fr; } }

    /* ── Upload de arquivos ── */
    .upload-zone {
      border: 2.5px dashed var(--border);
      border-radius: var(--radius-lg);
      padding: 2.25rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: border-color .2s, background .2s;
      background: var(--bg);
      position: relative;
    }
    .upload-zone:hover, .upload-zone.drag-over {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    .upload-zone input[type=file] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }
    .upload-zone-icon { font-size: 2.2rem; margin-bottom: .5rem; }
    .upload-zone-text { font-size: .9rem; font-weight: 600; color: var(--text); }
    .upload-zone-sub  { font-size: .78rem; color: var(--text-muted); margin-top: .25rem; }

    /* Grid de arquivos */
    .arquivo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .arquivo-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: box-shadow .18s, border-color .18s;
      position: relative;
    }
    .arquivo-card:hover {
      box-shadow: var(--shadow);
      border-color: var(--blue-mid);
    }
    .arquivo-thumb {
      width: 100%;
      height: 110px;
      object-fit: cover;
      display: block;
      cursor: pointer;
    }
    .arquivo-pdf-thumb {
      width: 100%;
      height: 110px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fef2f2;
      font-size: 2.5rem;
      cursor: pointer;
    }
    .arquivo-info {
      padding: .5rem .6rem;
      font-size: .75rem;
    }
    .arquivo-nome {
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .arquivo-meta { color: var(--text-muted); margin-top: .1rem; }
    .arquivo-del {
      position: absolute;
      top: .35rem;
      right: .35rem;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: rgba(220,38,38,.85);
      color: #fff;
      border: none;
      font-size: .8rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity .15s;
    }
    .arquivo-card:hover .arquivo-del { opacity: 1; }

    /* Lightbox */
    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.88);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      transition: opacity .22s;
    }
    .lightbox.open { opacity: 1; pointer-events: all; }
    .lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      border-radius: var(--radius);
      box-shadow: 0 20px 60px rgba(0,0,0,.5);
    }
    .lightbox-close {
      position: fixed;
      top: 1rem;
      right: 1.25rem;
      background: none;
      border: none;
      color: #fff;
      font-size: 2rem;
      cursor: pointer;
      line-height: 1;
    }

    /* Upload progress */
    .upload-progress {
      margin-top: 1rem;
      display: none;
    }
    .upload-progress.visible { display: block; }
    .upload-progress-bar {
      height: 6px;
      background: var(--blue-light);
      border-radius: 999px;
      overflow: hidden;
    }
    .upload-progress-fill {
      height: 100%;
      background: var(--blue);
      border-radius: 999px;
      width: 0%;
      transition: width .3s ease;
    }
  </style>
</head>
<body>

<%- include('../partials/_user-layout', { currentPage: 'produtos', username: username }) %>

<div class="app-content">

  <!-- Breadcrumb + cabeçalho -->
  <div class="page-header fade-up" style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
    <div>
      <p style="font-size:.8rem; color:var(--text-muted); margin-bottom:.3rem;">
        <a href="/produtos" style="color:var(--blue);">← Produtos</a>
      </p>
      <h1><%= produto.marca %></h1>
      <p><%= produto.denominacaoVenda %></p>
    </div>
    <%
      const sl = statusLabels[produto.statusAnalise] || statusLabels['CHECKLIST_EM_ANDAMENTO'];
    %>
    <span class="status-badge" style="color:<%= sl.color %>; background:<%= sl.bg %>; border-color:<%= sl.border %>;">
      ● <%= sl.label %>
    </span>
  </div>

  <!-- Alertas -->
  <% if (sucesso) { %>
  <div class="alert alert-success fade-up" id="alert-box">
    <span>✅</span>
    <% if (sucesso === 'rotulo_salvo') { %> Dados do rótulo salvos com sucesso! <% } %>
  </div>
  <% } %>
  <% if (erro) { %>
  <div class="alert alert-error fade-up" id="alert-box">
    <span>❌</span> Erro ao salvar. Tente novamente.
  </div>
  <% } %>

  <!-- Card principal com abas -->
  <div class="card fade-up d1">
    <div class="card-body" style="padding-bottom:0;">
      <nav class="tabs-bar" role="tablist">
        <button class="tab-btn <%= tab === 'identificacao' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('identificacao')">
          📋 Dados de Identificação Geral
        </button>
        <button class="tab-btn <%= tab === 'rotulo' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('rotulo')">
          🏷️ Dados Rótulo
        </button>
        <button class="tab-btn <%= tab === 'arquivos' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('arquivos')">
          📎 Rótulo
          <% if (arquivos && arquivos.length > 0) { %>
          <span style="background:var(--blue);color:#fff;border-radius:999px;font-size:.65rem;padding:.1rem .45rem;font-weight:700;margin-left:.2rem;"><%= arquivos.length %></span>
          <% } %>
        </button>
        <button class="tab-btn <%= tab === 'analise' ? 'active' : '' %>"
          role="tab" onclick="trocarAba('analise')">
          🔍 Análise
        </button>
      </nav>
    </div>

    <!-- ══ ABA 1: IDENTIFICAÇÃO GERAL ══ -->
    <div id="aba-identificacao" class="tab-panel card-body <%= tab === 'identificacao' ? 'active' : '' %>">
      <div class="rotulo-grid">
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Marca</p>
          <p style="font-weight:600;color:var(--text);"><%= produto.marca %></p>
        </div>
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Denominação de venda</p>
          <p style="color:var(--text);"><%= produto.denominacaoVenda %></p>
        </div>
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Categoria</p>
          <p style="color:var(--text);"><%= produto.categoria ? produto.categoria.nome : '—' %></p>
        </div>
        <div>
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Subcategoria</p>
          <p style="color:var(--text);"><%= produto.subcategoria ? produto.subcategoria.nome : '—' %></p>
        </div>
        <% if (produto.descricao) { %>
        <div style="grid-column:1/-1;">
          <p class="section-label" style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.35rem;">Descrição</p>
          <p style="color:var(--text-muted);line-height:1.6;"><%= produto.descricao %></p>
        </div>
        <% } %>
      </div>
    </div>

    <!-- ══ ABA 2: DADOS RÓTULO ══ -->
    <div id="aba-rotulo" class="tab-panel card-body <%= tab === 'rotulo' ? 'active' : '' %>">
      <form action="/produtos/<%= produto.id %>/rotulo" method="POST">
        <div class="rotulo-grid">

          <div class="form-group">
            <label for="conteudoLiquido">Conteúdo líquido</label>
            <input type="text" id="conteudoLiquido" name="conteudoLiquido"
              value="<%= produto.conteudoLiquido || '' %>"
              placeholder="Ex: 1000">
          </div>

          <div class="form-group">
            <label for="unidadeMedida">Unidade de medida</label>
            <select id="unidadeMedida" name="unidadeMedida">
              <option value="">Selecione...</option>
              <% ['ml','L','g','kg','mg','un','pç','cx'].forEach(u => { %>
              <option value="<%= u %>" <%= produto.unidadeMedida === u ? 'selected' : '' %>><%= u %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group" style="grid-column:1/-1;">
            <label for="fabricante">Fabricante</label>
            <input type="text" id="fabricante" name="fabricante"
              value="<%= produto.fabricante || '' %>"
              placeholder="Razão social do fabricante">
          </div>

          <div class="form-group">
            <label for="cnpjFabricante">CNPJ do fabricante</label>
            <input type="text" id="cnpjFabricante" name="cnpjFabricante"
              value="<%= produto.cnpjFabricante || '' %>"
              placeholder="00.000.000/0000-00">
          </div>

          <div class="form-group">
            <label for="servicoInspecao">Serviço de inspeção</label>
            <input type="text" id="servicoInspecao" name="servicoInspecao"
              value="<%= produto.servicoInspecao || '' %>"
              placeholder="Ex: SIF 1234, SISP, SISBI">
          </div>

          <div class="form-group" style="grid-column:1/-1;">
            <label for="condicoesConservacao">Condições de conservação</label>
            <textarea id="condicoesConservacao" name="condicoesConservacao" rows="3"
              style="width:100%;padding:.65rem .9rem;font-family:inherit;font-size:.925rem;color:var(--text);background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);outline:none;resize:vertical;"
              placeholder="Ex: Manter refrigerado entre 2°C e 8°C"><%= produto.condicoesConservacao || '' %></textarea>
          </div>

        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:1rem;">
          <button type="submit" class="btn btn-primary">💾 Salvar dados do rótulo</button>
        </div>
      </form>
    </div>

    <!-- ══ ABA 3: RÓTULO (arquivos) ══ -->
    <div id="aba-arquivos" class="tab-panel card-body <%= tab === 'arquivos' ? 'active' : '' %>">

      <!-- Zona de upload -->
      <div class="upload-zone" id="upload-zone">
        <input type="file" id="upload-input" multiple accept="image/*,.pdf"
          onchange="processarArquivos(this.files)">
        <div class="upload-zone-icon">📎</div>
        <div class="upload-zone-text">Arraste os arquivos aqui ou clique para selecionar</div>
        <div class="upload-zone-sub">Imagens (JPG, PNG, WEBP) e PDF · Máx. 20 MB por arquivo</div>
      </div>

      <!-- Barra de progresso -->
      <div class="upload-progress" id="upload-progress">
        <div style="display:flex;justify-content:space-between;font-size:.78rem;color:var(--text-muted);margin-bottom:.3rem;">
          <span id="upload-msg">Enviando...</span>
          <span id="upload-pct">0%</span>
        </div>
        <div class="upload-progress-bar">
          <div class="upload-progress-fill" id="upload-progress-fill"></div>
        </div>
      </div>

      <!-- Grid de arquivos -->
      <div class="arquivo-grid" id="arquivo-grid">
        <% (arquivos || []).forEach(arq => { %>
        <div class="arquivo-card" id="arq-<%= arq.id %>">
          <% if (arq.tipo === 'image') { %>
          <img class="arquivo-thumb" src="/uploads/produtos/<%= arq.nomeSalvo %>"
            alt="<%= arq.nomeOriginal %>"
            onclick="abrirLightbox('/uploads/produtos/<%= arq.nomeSalvo %>')"
            title="<%= arq.nomeOriginal %>">
          <% } else { %>
          <div class="arquivo-pdf-thumb"
            onclick="window.open('/uploads/produtos/<%= arq.nomeSalvo %>','_blank')"
            title="Abrir PDF">
            📄
          </div>
          <% } %>
          <div class="arquivo-info">
            <div class="arquivo-nome" title="<%= arq.nomeOriginal %>"><%= arq.nomeOriginal %></div>
            <div class="arquivo-meta"><%= Math.round((arq.tamanho||0)/1024) %> KB</div>
          </div>
          <button class="arquivo-del" onclick="deletarArquivo(<%= arq.id %>)" title="Remover">✕</button>
        </div>
        <% }) %>
      </div>

      <% if (!arquivos || arquivos.length === 0) { %>
      <div id="empty-arquivos" class="empty-state" style="padding:1.5rem 0;">
        <div class="empty-state-icon" style="font-size:1.8rem;">📎</div>
        <p style="font-weight:600;color:var(--text);margin-bottom:.25rem;">Nenhum arquivo enviado</p>
        <p>Arraste imagens ou PDFs do rótulo para começar.</p>
      </div>
      <% } else { %>
      <div id="empty-arquivos" style="display:none;"></div>
      <% } %>

    </div>

    <!-- ══ ABA 4: ANÁLISE ══ -->
    <div id="aba-analise" class="tab-panel card-body <%= tab === 'analise' ? 'active' : '' %>">

      <!-- Status -->
      <div style="margin-bottom:1.75rem;">
        <p style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.6rem;">Status da análise</p>
        <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
          <% const statusOrdem = ['CHECKLIST_EM_ANDAMENTO','CHECKLIST_CONCLUIDA','PRONTO_PARA_IA','AVALIADO_POR_IA']; %>
          <% statusOrdem.forEach(s => { %>
          <%   const sl2 = statusLabels[s]; %>
          <%   const isAtual = produto.statusAnalise === s; %>
          <span class="status-badge"
            style="color:<%= sl2.color %>; background:<%= sl2.bg %>; border-color:<%= sl2.border %>; opacity:<%= isAtual ? 1 : 0.35 %>; font-size:.78rem;">
            <%= isAtual ? '●' : '○' %> <%= sl2.label %>
          </span>
          <% }) %>
        </div>
      </div>

      <!-- Lista de checklists -->
      <p style="font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--text-light);margin-bottom:.85rem;">Checklists aplicáveis</p>

      <% if (checklists.length === 0) { %>
      <div class="empty-state" style="padding:2rem 1rem;">
        <div class="empty-state-icon">📋</div>
        <p style="font-weight:600;color:var(--text);margin-bottom:.3rem;">Nenhum checklist vinculado</p>
        <p>Contate o administrador para vincular checklists à subcategoria deste produto.</p>
      </div>
      <% } else { %>
      <div style="display:flex;flex-direction:column;gap:.75rem;">
        <% checklists.forEach(cl => {
            let totalItens = 0, totalRespondidos = 0;
            (cl.secoes || []).forEach(s => {
              (s.itens || []).forEach(it => {
                totalItens++;
                const r = respostasMap[it.id];
                if (r && r.resultado !== 'NAO_AVALIADO') totalRespondidos++;
              });
            });
            const pct = totalItens > 0 ? Math.round(totalRespondidos/totalItens*100) : 0;
        %>
        <div class="checklist-card" onclick="abrirChecklist(<%= JSON.stringify(cl) %>, <%= JSON.stringify(respostasMap) %>)">
          <div class="checklist-card-info">
            <div class="checklist-card-title">📋 <%= cl.codigo %> — <%= cl.nome %></div>
            <div class="checklist-card-sub"><%= totalItens %> item<%= totalItens !== 1 ? 's' : '' %> · <%= pct %>% respondido<%= pct !== 1 ? 's' : '' %></div>
            <div class="progress-bar-wrap" style="max-width:260px;">
              <div class="progress-bar-fill" style="width:<%= pct %>%;"></div>
            </div>
          </div>
          <span class="btn btn-primary btn-sm">Preencher →</span>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ══════════════════════════════
     MODAL — Checklist
══════════════════════════════ -->
<div class="cl-modal-overlay" id="cl-modal-overlay">
  <div class="cl-modal" id="cl-modal">
    <div class="cl-modal-header">
      <h3 id="cl-modal-title">Checklist</h3>
      <button class="modal-close-btn" onclick="fecharChecklist()">✕</button>
    </div>
    <div class="cl-modal-body" id="cl-modal-body">
      <!-- renderizado via JS -->
    </div>
    <div class="cl-modal-footer">
      <span id="cl-save-status" style="font-size:.8rem;color:var(--text-muted);margin-right:auto;"></span>
      <button class="btn btn-ghost" onclick="fecharChecklist()">Cancelar</button>
      <button class="btn btn-primary" onclick="salvarChecklist()">💾 Salvar respostas</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════
     SCRIPTS
══════════════════════════════ -->
<script>
const produtoId = <%= produto.id %>;
let clAtualId   = null;

/* ── Abas ── */
function trocarAba(id) {
  const ids = ['identificacao','rotulo','arquivos','analise'];
  document.querySelectorAll('.tab-btn').forEach((b, i) => b.classList.toggle('active', ids[i] === id));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('aba-' + id).classList.add('active');
  history.replaceState(null, '', `?tab=${id}`);
}

/* ── Upload de arquivos ── */
const produtoIdArq = <%= produto.id %>;

function formatBytes(b) {
  return b < 1024*1024 ? `${Math.round(b/1024)} KB` : `${(b/1024/1024).toFixed(1)} MB`;
}

function buildArquivoCard(arq) {
  const div = document.createElement('div');
  div.className = 'arquivo-card';
  div.id = `arq-${arq.id}`;

  if (arq.tipo === 'image') {
    div.innerHTML = `
      <img class="arquivo-thumb" src="/uploads/produtos/${arq.nomeSalvo}"
        alt="${arq.nomeOriginal}" title="${arq.nomeOriginal}"
        onclick="abrirLightbox('/uploads/produtos/${arq.nomeSalvo}')">`;
  } else {
    div.innerHTML = `
      <div class="arquivo-pdf-thumb"
        onclick="window.open('/uploads/produtos/${arq.nomeSalvo}','_blank')"
        title="Abrir PDF">📄</div>`;
  }

  div.innerHTML += `
    <div class="arquivo-info">
      <div class="arquivo-nome" title="${arq.nomeOriginal}">${arq.nomeOriginal}</div>
      <div class="arquivo-meta">${formatBytes(arq.tamanho || 0)}</div>
    </div>
    <button class="arquivo-del" onclick="deletarArquivo(${arq.id})" title="Remover">✕</button>`;

  return div;
}

async function processarArquivos(files) {
  if (!files || files.length === 0) return;

  const progress  = document.getElementById('upload-progress');
  const fill      = document.getElementById('upload-progress-fill');
  const msg       = document.getElementById('upload-msg');
  const pct       = document.getElementById('upload-pct');
  const emptyDiv  = document.getElementById('empty-arquivos');
  const grid      = document.getElementById('arquivo-grid');

  progress.classList.add('visible');
  msg.textContent = `Enviando ${files.length} arquivo(s)...`;

  const fd = new FormData();
  Array.from(files).forEach(f => fd.append('arquivos', f));

  try {
    // Simula progresso visual durante o envio
    let fakeP = 0;
    const timer = setInterval(() => {
      fakeP = Math.min(fakeP + 8, 85);
      fill.style.width = fakeP + '%';
      pct.textContent  = fakeP + '%';
    }, 120);

    const resp = await fetch(`/produtos/${produtoIdArq}/arquivos`, {
      method: 'POST',
      body: fd,
    });
    clearInterval(timer);
    fill.style.width = '100%';
    pct.textContent  = '100%';

    const data = await resp.json();

    if (data.ok) {
      msg.textContent = `✅ ${data.arquivos.length} arquivo(s) enviado(s)!`;
      data.arquivos.forEach(arq => {
        grid.appendChild(buildArquivoCard(arq));
        emptyDiv.style.display = 'none';
      });
      // Atualiza badge da aba
      atualizarBadgeAba();
    } else {
      msg.textContent = `❌ ${data.erro || 'Erro no envio'}`;
    }
  } catch(e) {
    msg.textContent = '❌ Erro de conexão.';
  }

  setTimeout(() => {
    progress.classList.remove('visible');
    fill.style.width = '0%';
    document.getElementById('upload-input').value = '';
  }, 2500);
}

async function deletarArquivo(id) {
  if (!confirm('Remover este arquivo?')) return;
  try {
    const resp = await fetch(`/produtos/${produtoIdArq}/arquivos/${id}/deletar`, { method: 'POST' });
    const data = await resp.json();
    if (data.ok) {
      document.getElementById(`arq-${id}`)?.remove();
      atualizarBadgeAba();
      // Mostrar empty state se não houver mais arquivos
      const grid = document.getElementById('arquivo-grid');
      if (!grid.querySelector('.arquivo-card')) {
        document.getElementById('empty-arquivos').style.display = '';
      }
    }
  } catch(e) {
    alert('Erro ao remover arquivo.');
  }
}

function atualizarBadgeAba() {
  const count = document.querySelectorAll('#arquivo-grid .arquivo-card').length;
  // O badge está no 3º tab-btn (index 2)
  const btn = document.querySelectorAll('.tab-btn')[2];
  let badge = btn.querySelector('span[data-badge]');
  if (count > 0) {
    if (!badge) {
      badge = document.createElement('span');
      badge.dataset.badge = '1';
      badge.style.cssText = 'background:var(--blue);color:#fff;border-radius:999px;font-size:.65rem;padding:.1rem .45rem;font-weight:700;margin-left:.2rem;';
      btn.appendChild(badge);
    }
    badge.textContent = count;
  } else {
    badge?.remove();
  }
}

/* ── Drag & Drop ── */
const uploadZone = document.getElementById('upload-zone');
if (uploadZone) {
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
  uploadZone.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.classList.remove('drag-over');
    processarArquivos(e.dataTransfer.files);
  });
}

/* ── Lightbox ── */
function abrirLightbox(src) {
  const lb = document.getElementById('lightbox');
  lb.querySelector('img').src = src;
  lb.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function fecharLightbox() {
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { fecharLightbox(); fecharChecklist(); }
});

/* ── Modal Checklist ── */
function abrirChecklist(cl, respostasMap) {
  clAtualId = cl.id;
  document.getElementById('cl-modal-title').textContent = `📋 ${cl.codigo} — ${cl.nome}`;
  document.getElementById('cl-save-status').textContent = '';

  const body = document.getElementById('cl-modal-body');
  let html = '';

  (cl.secoes || []).forEach(s => {
    const itens = s.itens || [];

    // Verifica se algum item aceita N/A para saber se exibe coluna
    const temNA = itens.some(it => it.aceitaNaoAplicavel);

    html += `<div class="cl-secao">`;
    html += `<div class="cl-secao-title">📂 ${s.titulo}</div>`;
    if (s.descricao) html += `<p class="cl-secao-desc">${s.descricao}</p>`;

    if (itens.length === 0) {
      html += `<p style="font-size:.8rem;color:var(--text-muted);padding:.5rem 0;">Nenhum item nesta seção.</p>`;
    } else {
      html += `<div style="overflow-x:auto;">`;
      html += `<table class="cl-table">`;
      html += `<thead><tr>`;
      html += `<th class="th-pergunta">Pergunta</th>`;
      html += `<th title="Conforme">✅<br><span style="font-size:.65rem;font-weight:600;">Conforme</span></th>`;
      html += `<th title="Não conforme">❌<br><span style="font-size:.65rem;font-weight:600;">Não conf.</span></th>`;
      if (temNA) html += `<th title="Não aplicável">➖<br><span style="font-size:.65rem;font-weight:600;">N/A</span></th>`;
      html += `<th title="Não avaliado">⬜<br><span style="font-size:.65rem;font-weight:600;">N/Aval.</span></th>`;
      html += `<th class="th-obs">Observação</th>`;
      html += `</tr></thead><tbody>`;

      itens.forEach(it => {
        const r     = respostasMap[it.id] || {};
        const atual = r.resultado || 'NAO_AVALIADO';
        const obs   = r.observacao || '';
        const cols  = ['CONFORME','NAO_CONFORME', ...(temNA ? ['NAO_APLICAVEL'] : []), 'NAO_AVALIADO'];

        html += `<tr data-item-id="${it.id}">`;

        // Pergunta (+ ajuda)
        html += `<td class="td-pergunta">${it.pergunta}`;
        if (it.descricaoAjuda) html += `<br><span class="td-ajuda" style="font-size:.73rem;color:var(--text-muted);font-style:italic;">${it.descricaoAjuda}</span>`;
        html += `</td>`;

        // Bolinhas
        cols.forEach(col => {
          html += `<td class="td-dot">`;
          html += `<input class="cl-radio" type="radio" data-col="${col}"
            name="item_${it.id}" id="r_${it.id}_${col}"
            value="${col}" ${atual === col ? 'checked' : ''}>`;
          html += `<label class="cl-dot-label" for="r_${it.id}_${col}" title="${col.replace(/_/g,' ')}"></label>`;
          html += `</td>`;
        });

        // Observação inline
        html += `<td><textarea class="cl-obs-inline" id="obs_${it.id}" rows="1"
          placeholder="Obs...">${obs}</textarea></td>`;

        html += `</tr>`;
      });

      html += `</tbody></table></div>`;
    }
    html += `</div>`;
  });

  if (!html) html = '<p style="color:var(--text-muted);font-size:.9rem;">Nenhum item nesta checklist.</p>';
  body.innerHTML = html;

  document.getElementById('cl-modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function fecharChecklist() {
  document.getElementById('cl-modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
  clAtualId = null;
}

async function salvarChecklist() {
  const status = document.getElementById('cl-save-status');
  status.textContent = 'Salvando...';

  const respostas = {};
  // Itens agora estão em <tr data-item-id>
  document.querySelectorAll('tr[data-item-id]').forEach(row => {
    const itemId  = row.dataset.itemId;
    const radioEl = row.querySelector(`input[name="item_${itemId}"]:checked`);
    const obsEl   = document.getElementById(`obs_${itemId}`);
    respostas[itemId] = {
      resultado:  radioEl ? radioEl.value : 'NAO_AVALIADO',
      observacao: obsEl ? obsEl.value : '',
    };
  });

  try {
    const resp = await fetch(`/produtos/${produtoId}/checklist/${clAtualId}/respostas`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ respostas }),
    });
    const data = await resp.json();
    if (data.ok) {
      status.textContent = '✅ Salvo!';
      status.style.color = 'var(--success)';
      setTimeout(() => { fecharChecklist(); location.reload(); }, 900);
    } else {
      status.textContent = '❌ Erro ao salvar.';
      status.style.color = 'var(--danger)';
    }
  } catch(e) {
    status.textContent = '❌ Erro de conexão.';
    status.style.color = 'var(--danger)';
  }
}

/* ── Fechar modais com ESC / overlay ── */
document.getElementById('cl-modal-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('cl-modal-overlay')) fecharChecklist();
});
document.getElementById('lightbox').addEventListener('click', e => {
  if (e.target === document.getElementById('lightbox')) fecharLightbox();
});

/* ── Auto-esconder alertas ── */
setTimeout(() => {
  const a = document.getElementById('alert-box');
  if (a) { a.style.transition = 'opacity .4s'; a.style.opacity = '0'; }
}, 4000);
</script>
<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" onclick="fecharLightbox()">✕</button>
  <img src="" alt="Preview">
</div>

</body>
</html>
