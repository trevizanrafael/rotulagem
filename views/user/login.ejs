<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
</head>
<body>
  <h1>Login</h1>

  <% if (erro === 'usuario_nao_encontrado') { %>
    <p style="color:red;">Usuário não encontrado.</p>
  <% } else if (erro === 'senha_incorreta') { %>
    <p style="color:red;">Senha incorreta.</p>
  <% } else if (erro === 'erro_interno') { %>
    <p style="color:red;">Erro interno. Tente novamente.</p>
  <% } %>

  <form action="/login" method="POST">
    <div>
      <label for="username">Usuário:</label>
      <input type="text" id="username" name="username" required>
    </div>
    <div>
      <label for="password">Senha:</label>
      <input type="password" id="password" name="password" required>
    </div>
    <button type="submit">Entrar</button>
  </form>
</body>
</html>
