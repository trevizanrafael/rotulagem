<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <%- include('../partials/_head') %>
    <title>Login Admin — FoodTech</title>
</head>

<body>

  <div class="login-root">

    <!-- Painel esquerdo: identidade -->
    <div class="login-brand">
      <img class="login-brand-logo" src="/icons/logo.png" alt="">
      <h1>Sistema de Auditoria de Rótulos</h1>
      <p>Plataforma inteligente para análise e validação de rótulos de produtos lácteos com IA.</p>
      <p class="login-brand-tagline">FoodTech Consultoria · Área Restrita</p>
    </div>

    <!-- Painel direito: formulário -->
    <div class="login-panel">
      <div class="login-box fade-up">
        <h2>Acesso Administrativo</h2>
        <p class="login-subtitle">Entre com suas credenciais de administrador.</p>

        <% if (erro==='credenciais_invalidas' ) { %>
          <div class="alert alert-error">
            ⚠️ Usuário ou senha incorretos. Verifique e tente novamente.
          </div>
          <% } %>

            <form action="/admin/login" method="POST">
              <div class="form-group">
                <label for="username">Usuário</label>
                <input type="text" id="username" name="username" placeholder="ex: adrianasuper" required autofocus>
              </div>
              <div class="form-group">
                <label for="password">Senha</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
              </div>
              <button type="submit" class="btn btn-primary btn-primary-full" style="margin-top:.5rem;">
                Entrar no painel
              </button>
            </form>
      </div>
    </div>

  </div>

</body>

</html>