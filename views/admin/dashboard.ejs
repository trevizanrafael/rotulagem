<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/_head') %>
  <title>Painel — FoodTech</title>
</head>
<body>

<%- include('../partials/_admin-layout', { currentPage: 'dashboard' }) %>

<div class="app-content">
  <div class="page-header fade-up">
    <h1>Visão Geral</h1>
    <p>Bem-vindo ao painel administrativo da FoodTech.</p>
  </div>

  <div class="cards-grid fade-up d1">

    <div class="card">
      <div class="card-body" style="display:flex; align-items:center; gap:1rem;">
        <div style="font-size:2.5rem;">👥</div>
        <div>
          <p style="font-size:.8rem; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.5px;">Gestão</p>
          <p style="font-size:1rem; font-weight:600; color:var(--text); margin-top:.2rem;">Usuários cadastrados</p>
          <a href="/admin/usuarios" class="btn btn-primary btn-sm" style="margin-top:.75rem;">Gerenciar usuários</a>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-body" style="display:flex; align-items:center; gap:1rem;">
        <div style="font-size:2.5rem;">🏷️</div>
        <div>
          <p style="font-size:.8rem; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.5px;">Catálogo</p>
          <p style="font-size:1rem; font-weight:600; color:var(--text); margin-top:.2rem;">Categorias de produtos</p>
          <a href="/admin/categorias" class="btn btn-primary btn-sm" style="margin-top:.75rem;">Gerenciar categorias</a>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-body" style="display:flex; align-items:center; gap:1rem;">
        <div style="font-size:2.5rem;">📂</div>
        <div>
          <p style="font-size:.8rem; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.5px;">Catálogo</p>
          <p style="font-size:1rem; font-weight:600; color:var(--text); margin-top:.2rem;">Subcategorias de produtos</p>
          <a href="/admin/subcategorias" class="btn btn-primary btn-sm" style="margin-top:.75rem;">Gerenciar subcategorias</a>
        </div>
      </div>
    </div>

  </div>
</div>

</body>
</html>
