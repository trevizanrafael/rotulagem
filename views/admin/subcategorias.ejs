<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <%- include('../partials/_head') %>
    <title>Subcategorias de Produtos — FoodTech</title>
</head>

<body>

  <%- include('../partials/_admin-layout', { currentPage: 'subcategorias' }) %>

    <div class="app-content">
      <div class="page-header fade-up">
        <h1>Subcategorias de Produtos</h1>
        <p>Gerencie as subcategorias vinculadas às categorias de produtos.</p>
      </div>

      <div class="cols-2">

        <!-- ======================== FORMULÁRIO ======================== -->
        <div class="card fade-up d1">
          <div class="card-header">
            <% if (editando) { %>
              <h2>Editar subcategoria</h2>
            <% } else { %>
              <h2>Nova subcategoria</h2>
            <% } %>
          </div>
          <div class="card-body">

            <!-- Notificação automática via #page-notify -->
            <% let _type='', _title='', _msg='', _ac='true';
              if (sucesso==='subcategoria_criada')     { _type='success'; _title='Subcategoria criada';    _msg='Subcategoria criada com sucesso!'; }
              else if (sucesso==='subcategoria_atualizada') { _type='success'; _title='Atualizada'; _msg='Subcategoria atualizada com sucesso!'; }
              else if (sucesso==='subcategoria_deletada')   { _type='success'; _title='Removida';  _msg='Subcategoria removida com sucesso!'; }
              else if (sucesso==='status_alterado')    { _type='success'; _title='Status alterado'; _msg='O status da subcategoria foi atualizado.'; }
              else if (sucesso==='selecionados_deletados') { _type='success'; _title='Excluídas'; _msg=(count || 'As subcategorias') + ' selecionada(s) foram excluídas.'; }
              else if (erro==='nome_ja_existe')        { _type='error';   _title='Nome duplicado';  _msg='Já existe uma subcategoria com esse nome.'; _ac='false'; }
              else if (erro==='nao_encontrado')        { _type='error';   _title='Não encontrado';  _msg='Subcategoria não encontrada.'; _ac='false'; }
              else if (erro==='nenhum_selecionado')    { _type='warning'; _title='Nenhum selecionado'; _msg='Selecione ao menos uma subcategoria antes de prosseguir.'; _ac='false'; }
              else if (erro==='sem_categorias')        { _type='warning'; _title='Sem categorias';  _msg='Cadastre ao menos uma categoria ativa antes de criar subcategorias.'; _ac='false'; }
              else if (erro==='erro_interno')          { _type='error';   _title='Erro interno';    _msg='Ocorreu um erro inesperado. Tente novamente.'; _ac='false'; }
            %>
            <% if (_type) { %>
              <div id="page-notify" hidden
                data-type="<%= _type %>"
                data-title="<%= _title %>"
                data-message="<%= _msg %>"
                data-autoclose="<%= _ac %>"></div>
            <% } %>

            <% if (categorias.length === 0) { %>
              <div class="empty-state" style="padding: 2rem 0;">
                <div class="empty-state-icon">📂</div>
                <p>Nenhuma categoria ativa encontrada.<br>Cadastre uma categoria antes de criar subcategorias.</p>
                <a href="/admin/categorias" class="btn btn-primary" style="margin-top:1rem;">Ir para Categorias</a>
              </div>
            <% } else { %>

              <!-- Formulário CREATE -->
              <% if (!editando) { %>
                <form action="/admin/subcategorias" method="POST" id="form-criar">
                  <div class="form-group">
                    <label for="categoriaId">Categoria <span style="color:var(--danger);">*</span></label>
                    <select id="categoriaId" name="categoriaId" required>
                      <option value="" disabled selected>Selecione uma categoria...</option>
                      <% categorias.forEach(function(cat) { %>
                        <option value="<%= cat.id %>"><%= cat.nome %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="nome">Nome da subcategoria <span style="color:var(--danger);">*</span></label>
                    <input type="text" id="nome" name="nome" placeholder="ex: Queijos" required maxlength="100">
                  </div>
                  <div class="form-group">
                    <label for="descricao">Descrição</label>
                    <textarea id="descricao" name="descricao" rows="3"
                      placeholder="Descreva brevemente a subcategoria..."></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary" style="width:100%; margin-top:.25rem;">
                    ➕ Criar subcategoria
                  </button>
                </form>

              <!-- Formulário EDIT -->
              <% } else { %>
                <form action="/admin/subcategorias/<%= editando.id %>" method="POST" id="form-editar">
                  <div class="form-group">
                    <label for="categoriaId-edit">Categoria <span style="color:var(--danger);">*</span></label>
                    <select id="categoriaId-edit" name="categoriaId" required>
                      <% categorias.forEach(function(cat) { %>
                        <option value="<%= cat.id %>" <%= editando.categoriaId === cat.id ? 'selected' : '' %>><%= cat.nome %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="nome-edit">Nome da subcategoria <span style="color:var(--danger);">*</span></label>
                    <input type="text" id="nome-edit" name="nome" value="<%= editando.nome %>" required maxlength="100">
                  </div>
                  <div class="form-group">
                    <label for="descricao-edit">Descrição</label>
                    <textarea id="descricao-edit" name="descricao" rows="3"><%= editando.descricao || '' %></textarea>
                  </div>
                  <div class="form-group">
                    <label for="status-edit">Status</label>
                    <select id="status-edit" name="status">
                      <option value="ativo" <%= editando.status === 'ativo' ? 'selected' : '' %>>✅ Ativo</option>
                      <option value="inativo" <%= editando.status === 'inativo' ? 'selected' : '' %>>⛔ Inativo</option>
                    </select>
                  </div>
                  <div style="display:flex; gap:.75rem; margin-top:.25rem;">
                    <button type="submit" class="btn btn-primary" style="flex:1;">💾 Salvar alterações</button>
                    <a href="/admin/subcategorias" class="btn btn-secondary" style="flex:1; text-align:center;">Cancelar</a>
                  </div>
                </form>
              <% } %>

            <% } %>

          </div>
        </div>

        <!-- ======================== TABELA ======================== -->
        <div class="card fade-up d2">
          <div class="card-header">
            <h2>Subcategorias cadastradas</h2>
            <div class="header-actions">
              <span class="card-badge">
                <%= subcategorias.length %> no total
              </span>
              <button id="btn-del-sel" class="btn btn-danger btn-sm" style="display:none"
                onclick="deletarSelecionados()">
                🗑️ Excluir
              </button>
              <label class="btn btn-ghost btn-sm" style="cursor:pointer;" title="Importar subcategorias (JSON ou CSV)">
                📥 Importar
                <input type="file" id="import-file" accept=".json,.csv" style="display:none"
                  onchange="importarArquivo(this)">
              </label>
              <button class="btn btn-ghost btn-sm" onclick="exportarSelecionados()"
                title="Exportar subcategorias selecionadas">📤 Exportar</button>
            </div>
          </div>

          <% if (subcategorias.length === 0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">🏷️</div>
              <p>Nenhuma subcategoria cadastrada ainda.<br>Use o formulário ao lado para adicionar.</p>
            </div>
          <% } else { %>

            <!-- Form oculto para exclusão em massa -->
            <form id="form-del-sel" action="/admin/subcategorias/deletar-selecionados" method="POST"
              style="display:none;"></form>

            <div class="table-wrap">
              <table class="data-table">
                <thead>
                  <tr>
                    <th class="th-check">
                      <input type="checkbox" id="select-all" title="Selecionar todos"
                        onchange="toggleSelectAll(this)">
                    </th>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Descrição</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% subcategorias.forEach(function(sub) { %>
                    <tr>
                      <td class="td-check">
                        <input type="checkbox" class="row-check" value="<%= sub.id %>"
                          data-nome="<%= sub.nome %>"
                          data-descricao="<%= (sub.descricao || '').replace(/"/g, '&quot;') %>"
                          data-status="<%= sub.status %>"
                          data-categoria-id="<%= sub.categoriaId %>"
                          onchange="onCheckChange()">
                      </td>
                      <td class="td-id"><%= sub.id %></td>
                      <td style="font-weight:600; color:var(--text);"><%= sub.nome %></td>
                      <td>
                        <span class="categoria-badge">
                          <%= sub.categoria ? sub.categoria.nome : '—' %>
                        </span>
                      </td>
                      <td class="td-muted"
                        style="max-width:140px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
                        title="<%= sub.descricao || '' %>">
                        <%= sub.descricao || '—' %>
                      </td>
                      <td>
                        <form action="/admin/subcategorias/<%= sub.id %>/status" method="POST" style="display:inline;">
                          <button type="submit"
                            class="status-badge <%= sub.status === 'ativo' ? 'status-ativo' : 'status-inativo' %>"
                            title="Clique para alternar o status">
                            <%= sub.status === 'ativo' ? '✅ Ativo' : '⛔ Inativo' %>
                          </button>
                        </form>
                      </td>
                      <td>
                        <div class="action-btns">
                          <a href="/admin/subcategorias/<%= sub.id %>/editar" class="btn-icon btn-edit" title="Editar">✏️</a>
                          <form action="/admin/subcategorias/<%= sub.id %>/deletar" method="POST" style="display:inline;">
                            <button type="button" class="btn-icon btn-delete" title="Excluir"
                              data-nome="<%= sub.nome %>"
                              onclick="confirmDelete(this, this.dataset.nome)">🗑️</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div><!-- /.cols-2 -->
    </div><!-- /.app-content -->

    <style>
      /* ── Header com ações ── */
      .header-actions {
        display: flex;
        align-items: center;
        gap: .35rem;
        flex-wrap: nowrap;
        white-space: nowrap;
      }

      .header-actions .btn-sm {
        font-size: .75rem;
        padding: .3rem .6rem;
      }

      .header-actions .card-badge {
        font-size: .72rem;
        padding: .2rem .55rem;
      }

      /* ── Status badges ── */
      .status-badge {
        display: inline-block;
        padding: .25rem .65rem;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: opacity .2s, transform .1s;
      }

      .status-badge:hover { opacity: .8; transform: scale(.97); }

      .status-ativo  { background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }
      .status-inativo { background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5; }

      /* ── Badge de categoria ── */
      .categoria-badge {
        display: inline-block;
        padding: .2rem .6rem;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 600;
        background: var(--blue-light);
        color: var(--blue);
        border: 1px solid var(--blue-mid, #bfdbfe);
        white-space: nowrap;
      }

      /* ── Botões de ação ── */
      .action-btns { display: flex; gap: .4rem; align-items: center; }

      .btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: .4rem;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        background: transparent;
        transition: background .15s, transform .1s;
        text-decoration: none;
      }

      .btn-icon:hover { background: rgba(0,0,0,.06); transform: scale(1.1); }
      .btn-edit:hover  { background: #dbeafe; }
      .btn-delete:hover { background: #fee2e2; }

      /* ── Checkbox ── */
      .th-check, .td-check {
        width: 2.25rem;
        text-align: center;
        padding-left: 1rem !important;
      }

      input[type="checkbox"] {
        width: 1rem;
        height: 1rem;
        cursor: pointer;
        accent-color: var(--blue);
      }

      tr.row-selected { background: var(--blue-light) !important; }

      /* ── Select e textarea ── */
      .form-group select,
      .form-group textarea {
        width: 100%;
        padding: .65rem .9rem;
        font-size: .925rem;
        font-family: inherit;
        color: var(--text);
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        outline: none;
        transition: border-color var(--transition), box-shadow var(--transition);
        box-sizing: border-box;
      }

      .form-group select:focus,
      .form-group textarea:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(3, 110, 192, .12);
      }

      .form-group textarea { resize: vertical; }
    </style>

    <script>
      // ── Seleção ──────────────────────────────────────────────
      function getChecks() { return [...document.querySelectorAll('.row-check')]; }
      function getSelected() { return getChecks().filter(c => c.checked); }

      function onCheckChange() {
        const all = getChecks();
        const sel = getSelected();
        const sa = document.getElementById('select-all');
        if (sa) {
          sa.checked = sel.length > 0 && sel.length === all.length;
          sa.indeterminate = sel.length > 0 && sel.length < all.length;
        }
        all.forEach(c => c.closest('tr').classList.toggle('row-selected', c.checked));
        const btn = document.getElementById('btn-del-sel');
        if (btn) btn.style.display = sel.length > 0 ? 'inline-flex' : 'none';
      }

      function toggleSelectAll(el) {
        getChecks().forEach(c => { c.checked = el.checked; });
        onCheckChange();
      }

      // ── Excluir selecionados ─────────────────────────────────
      function deletarSelecionados() {
        const sel = getSelected();
        if (!sel.length) return;
        const nomes = sel.map(c => c.dataset.nome).join(', ');
        Modal.confirm({
          title: 'Excluir selecionados',
          message: 'Deseja excluir <strong>' + sel.length + '</strong> subcategoria(s)?<br><small style="color:var(--text-muted)">' + nomes + '</small>',
          confirmText: '🗑️ Excluir',
          onConfirm: () => {
            const form = document.getElementById('form-del-sel');
            form.innerHTML = '';
            sel.forEach(c => {
              const inp = document.createElement('input');
              inp.type = 'hidden'; inp.name = 'ids'; inp.value = c.value;
              form.appendChild(inp);
            });
            form.submit();
          }
        });
      }

      // ── Exportar (CSV) ───────────────────────────────────────
      function exportarSelecionados() {
        const alvo = getSelected().length ? getSelected() : getChecks();
        if (!alvo.length) {
          Modal.notify({ type: 'warning', title: 'Nada para exportar', message: 'Não há subcategorias para exportar.', autoClose: false });
          return;
        }
        const linhas = [['id', 'nome', 'descricao', 'status', 'categoriaId']];
        alvo.forEach(c => {
          const id    = c.value;
          const nome  = '"' + c.dataset.nome.replace(/"/g, '""') + '"';
          const desc  = '"' + (c.dataset.descricao || '').replace(/"/g, '""') + '"';
          const status = c.dataset.status;
          const catId  = c.dataset.categoriaId;
          linhas.push([id, nome, desc, status, catId]);
        });
        const csv = linhas.map(r => r.join(',')).join('\n');
        const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'subcategorias_' + new Date().toISOString().slice(0, 10) + '.csv';
        a.click();
        URL.revokeObjectURL(url);
      }

      // ── Importar (JSON ou CSV) ───────────────────────────────
      function importarArquivo(input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = async (e) => {
          let lista = [];
          const txt = e.target.result;
          try {
            if (file.name.endsWith('.json')) {
              const parsed = JSON.parse(txt);
              lista = Array.isArray(parsed) ? parsed : (parsed.subcategorias || []);
            } else {
              const rows = txt.trim().split(/\r?\n/);
              const head = rows[0].split(',').map(h => h.replace(/^"|"$/g, '').trim().toLowerCase());
              for (let i = 1; i < rows.length; i++) {
                const cols = rows[i].match(/(".*?"|[^,]+|(?<=,)(?=,)|^(?=,)|(?<=,)$)/g) || [];
                const obj = {};
                head.forEach((h, j) => { obj[h] = (cols[j] || '').replace(/^"|"$/g, '').trim(); });
                lista.push(obj);
              }
            }
          } catch (err) {
            Modal.notify({ type: 'error', title: 'Arquivo inválido', message: 'Não foi possível ler o arquivo. Verifique o formato.', autoClose: false });
            input.value = '';
            return;
          }

          if (!lista.length) {
            Modal.notify({ type: 'warning', title: 'Arquivo vazio', message: 'Nenhum registro encontrado no arquivo.', autoClose: false });
            input.value = ''; return;
          }

          try {
            const resp = await fetch('/admin/subcategorias/importar', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ subcategorias: lista }),
            });
            const data = await resp.json();
            if (data.ok) {
              Modal.confirm({
                title: 'Importação concluída',
                message: '✅ <strong>' + data.importados + '</strong> subcategoria(s) importada(s).<br>⏭️ <strong>' + data.ignorados + '</strong> ignorada(s) (já existiam, inválidas ou sem categoriaId).',
                confirmText: 'Recarregar',
                cancelText: 'Fechar',
                onConfirm: () => location.reload(),
              });
            } else {
              Modal.notify({ type: 'error', title: 'Erro na importação', message: data.mensagem || 'Erro desconhecido.', autoClose: false });
            }
          } catch (err) {
            Modal.notify({ type: 'error', title: 'Erro de rede', message: 'Não foi possível enviar o arquivo. Tente novamente.', autoClose: false });
          }
          input.value = '';
        };
        reader.readAsText(file, 'UTF-8');
      }
    </script>

</body>

</html>
