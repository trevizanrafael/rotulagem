<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <%- include('../partials/_head') %>
    <title>Subcategorias de Produtos — FoodTech</title>
</head>

<body>

  <%- include('../partials/_admin-layout', { currentPage: 'subcategorias' }) %>

    <div class="app-content">
      <div class="page-header fade-up">
        <h1>Subcategorias de Produtos</h1>
        <p>Gerencie as subcategorias vinculadas às categorias de produtos.</p>
      </div>

      <div class="sub-layout">

        <!-- ======================== FORMULÁRIO ======================== -->
        <div class="card fade-up d1">
          <div class="card-header">
            <% if (editando) { %>
              <h2>Editar subcategoria</h2>
            <% } else { %>
              <h2>Nova subcategoria</h2>
            <% } %>
          </div>
          <div class="card-body">

            <!-- Notificação automática via #page-notify -->
            <% let _type='', _title='', _msg='', _ac='true';
              if (sucesso==='subcategoria_criada')     { _type='success'; _title='Subcategoria criada';    _msg='Subcategoria criada com sucesso!'; }
              else if (sucesso==='subcategoria_atualizada') { _type='success'; _title='Atualizada'; _msg='Subcategoria atualizada com sucesso!'; }
              else if (sucesso==='subcategoria_deletada')   { _type='success'; _title='Removida';  _msg='Subcategoria removida com sucesso!'; }
              else if (sucesso==='status_alterado')    { _type='success'; _title='Status alterado'; _msg='O status da subcategoria foi atualizado.'; }
              else if (sucesso==='selecionados_deletados') { _type='success'; _title='Excluídas'; _msg=(count || 'As subcategorias') + ' selecionada(s) foram excluídas.'; }
              else if (erro==='nome_ja_existe')        { _type='error';   _title='Nome duplicado';  _msg='Já existe uma subcategoria com esse nome.'; _ac='false'; }
              else if (erro==='nao_encontrado')        { _type='error';   _title='Não encontrado';  _msg='Subcategoria não encontrada.'; _ac='false'; }
              else if (erro==='nenhum_selecionado')    { _type='warning'; _title='Nenhum selecionado'; _msg='Selecione ao menos uma subcategoria antes de prosseguir.'; _ac='false'; }
              else if (erro==='sem_categorias')        { _type='warning'; _title='Sem categorias';  _msg='Cadastre ao menos uma categoria ativa antes de criar subcategorias.'; _ac='false'; }
              else if (erro==='erro_interno')          { _type='error';   _title='Erro interno';    _msg='Ocorreu um erro inesperado. Tente novamente.'; _ac='false'; }
            %>
            <% if (_type) { %>
              <div id="page-notify" hidden
                data-type="<%= _type %>"
                data-title="<%= _title %>"
                data-message="<%= _msg %>"
                data-autoclose="<%= _ac %>"></div>
            <% } %>

            <% if (categorias.length === 0) { %>
              <div class="empty-state" style="padding: 2rem 0;">
                <div class="empty-state-icon">📂</div>
                <p>Nenhuma categoria ativa encontrada.<br>Cadastre uma categoria antes de criar subcategorias.</p>
                <a href="/admin/categorias" class="btn btn-primary" style="margin-top:1rem;">Ir para Categorias</a>
              </div>
            <% } else { %>

              <!-- ── Layout form + painel lado a lado dentro do card ── -->
              <div class="form-and-panel">

              <!-- Formulário CREATE -->
              <% if (!editando) { %>
                <div class="form-col">
                <form action="/admin/subcategorias" method="POST" id="form-criar">
                  <div class="form-group">
                    <label for="categoriaId">Categoria <span style="color:var(--danger);">*</span></label>
                    <select id="categoriaId" name="categoriaId" required>
                      <option value="" disabled selected>Selecione uma categoria...</option>
                      <% categorias.forEach(function(cat) { %>
                        <option value="<%= cat.id %>"><%= cat.nome %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="nome">Nome da subcategoria <span style="color:var(--danger);">*</span></label>
                    <input type="text" id="nome" name="nome" placeholder="ex: Queijos" required maxlength="100">
                  </div>
                  <div class="form-group">
                    <label for="descricao">Descrição</label>
                    <textarea id="descricao" name="descricao" rows="3"
                      placeholder="Descreva brevemente a subcategoria..."></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary" style="width:100%; margin-top:.25rem;">
                    ➕ Criar subcategoria
                  </button>
                </form>
                </div>

                <!-- Painel de checklists no modo CREATE (apenas informativo) -->
                <div class="panel-col">
                  <div class="chk-panel chk-panel-create">
                    <div class="chk-panel-header">
                      <span>🔗 Checklists vinculados</span>
                      <span class="chk-panel-count">0</span>
                    </div>
                    <div class="chk-panel-chips">
                      <div class="chk-panel-notice">
                        <span class="chk-panel-notice-icon">💡</span>
                        <p>Salve a subcategoria primeiro para poder vincular checklists a ela.</p>
                      </div>
                    </div>
                  </div>
                </div>

              <!-- Formulário EDIT -->
              <% } else { %>
                <div class="form-col">
                <form action="/admin/subcategorias/<%= editando.id %>" method="POST" id="form-editar">
                  <div class="form-group">
                    <label for="categoriaId-edit">Categoria <span style="color:var(--danger);">*</span></label>
                    <select id="categoriaId-edit" name="categoriaId" required>
                      <% categorias.forEach(function(cat) { %>
                        <option value="<%= cat.id %>" <%= editando.categoriaId === cat.id ? 'selected' : '' %>><%= cat.nome %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="nome-edit">Nome da subcategoria <span style="color:var(--danger);">*</span></label>
                    <input type="text" id="nome-edit" name="nome" value="<%= editando.nome %>" required maxlength="100">
                  </div>
                  <div class="form-group">
                    <label for="descricao-edit">Descrição</label>
                    <textarea id="descricao-edit" name="descricao" rows="3"><%= editando.descricao || '' %></textarea>
                  </div>
                  <div class="form-group">
                    <label for="status-edit">Status</label>
                    <select id="status-edit" name="status">
                      <option value="ativo" <%= editando.status === 'ativo' ? 'selected' : '' %>>✅ Ativo</option>
                      <option value="inativo" <%= editando.status === 'inativo' ? 'selected' : '' %>>⛔ Inativo</option>
                    </select>
                  </div>
                  <div style="display:flex; gap:.75rem; margin-top:.25rem;">
                    <button type="submit" class="btn btn-primary" style="flex:1;">💾 Salvar alterações</button>
                    <a href="/admin/subcategorias" class="btn btn-secondary" style="flex:1; text-align:center;">Cancelar</a>
                  </div>
                </form>
                </div>

                <!-- ── Painel de Checklists Vinculados (EDIT) ── -->
                <div class="panel-col">
                <div class="chk-panel" id="chk-panel" data-sub-id="<%= editando.id %>">
                  <div class="chk-panel-header">
                    <span>🔗 Checklists vinculados</span>
                    <span class="chk-panel-count" id="chk-panel-count"><%= editando.checklists ? editando.checklists.length : 0 %></span>
                  </div>

                  <!-- Chips dos vinculados -->
                  <div class="chk-panel-chips" id="chk-panel-chips">
                    <% if (editando.checklists && editando.checklists.length > 0) { %>
                      <% editando.checklists.forEach(function(chk) { %>
                        <div class="chk-panel-chip" data-id="<%= chk.id %>">
                          <span class="chk-chip chk-chip-<%= chk.tipo.toLowerCase() %>" style="pointer-events:none;">
                            <%= chk.codigo %>
                          </span>
                          <span class="chk-panel-chip-nome"><%= chk.nome %></span>
                          <button type="button" class="chk-panel-chip-remove btn-desvincular"
                            data-sub-id="<%= editando.id %>"
                            data-chk-id="<%= chk.id %>"
                            title="Desvincular">✕</button>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <p class="chk-panel-empty" id="chk-panel-empty">Nenhum checklist vinculado.</p>
                    <% } %>
                  </div>

                  <!-- Adicionar novo vínculo -->
                  <div class="chk-panel-add">
                    <select id="chk-select-add" class="chk-panel-select">
                      <option value="">Selecione um checklist para vincular...</option>
                      <% todosChecklists.forEach(function(chk) { %>
                        <option value="<%= chk.id %>"
                          data-codigo="<%= chk.codigo %>"
                          data-nome="<%= chk.nome %>"
                          data-tipo="<%= chk.tipo %>">
                          <%= chk.codigo %> — <%= chk.nome %> (<%= chk.tipo %>)
                        </option>
                      <% }) %>
                    </select>
                    <button type="button" class="btn btn-primary btn-sm" id="btn-vincular"
                      data-sub-id="<%= editando.id %>">➕ Vincular</button>
                  </div>
                </div>
                </div>

              <% } %>

              </div><!-- /.form-and-panel -->

            <% } %>

          </div>
        </div>

        <!-- ======================== TABELA ======================== -->
        <div class="card fade-up d2">
          <div class="card-header">
            <h2>Subcategorias cadastradas</h2>
            <div class="header-actions">
              <span class="card-badge">
                <%= subcategorias.length %> no total
              </span>
              <button id="btn-del-sel" class="btn btn-danger btn-sm" style="display:none"
                onclick="deletarSelecionados()">
                🗑️ Excluir
              </button>
              <label class="btn btn-ghost btn-sm" style="cursor:pointer;" title="Importar subcategorias (JSON ou CSV)">
                📥 Importar
                <input type="file" id="import-file" accept=".json,.csv" style="display:none"
                  onchange="importarArquivo(this)">
              </label>
              <button class="btn btn-ghost btn-sm" onclick="exportarSelecionados()"
                title="Exportar subcategorias selecionadas">📤 Exportar</button>
            </div>
          </div>

          <% if (subcategorias.length === 0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">🏷️</div>
              <p>Nenhuma subcategoria cadastrada ainda.<br>Use o formulário ao lado para adicionar.</p>
            </div>
          <% } else { %>

            <!-- Form oculto para exclusão em massa -->
            <form id="form-del-sel" action="/admin/subcategorias/deletar-selecionados" method="POST"
              style="display:none;"></form>

            <div class="table-wrap">
              <table class="data-table">
                <thead>
                  <tr>
                    <th class="th-check">
                      <input type="checkbox" id="select-all" title="Selecionar todos"
                        onchange="toggleSelectAll(this)">
                    </th>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Checklists</th>
                    <th>Descrição</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% subcategorias.forEach(function(sub) { %>
                    <tr>
                      <td class="td-check">
                        <input type="checkbox" class="row-check" value="<%= sub.id %>"
                          data-nome="<%= sub.nome %>"
                          data-descricao="<%= (sub.descricao || '').replace(/"/g, '&quot;') %>"
                          data-status="<%= sub.status %>"
                          data-categoria-id="<%= sub.categoriaId %>"
                          onchange="onCheckChange()">
                      </td>
                      <td class="td-id"><%= sub.id %></td>
                      <td style="font-weight:600; color:var(--text);"><%= sub.nome %></td>
                      <td>
                        <span class="categoria-badge">
                          <%= sub.categoria ? sub.categoria.nome : '—' %>
                        </span>
                      </td>
                      <td class="td-checklists">
                        <% if (sub.checklists && sub.checklists.length > 0) { %>
                          <div class="chk-chips">
                            <% sub.checklists.slice(0, 3).forEach(function(chk) { %>
                              <span class="chk-chip chk-chip-<%= chk.tipo.toLowerCase() %>" title="<%= chk.nome %>">
                                <%= chk.codigo %>
                              </span>
                            <% }) %>
                            <% if (sub.checklists.length > 3) { %>
                              <span class="chk-chip-more">+<%= sub.checklists.length - 3 %></span>
                            <% } %>
                          </div>
                        <% } else { %>
                          <span class="td-muted">—</span>
                        <% } %>
                      </td>
                      <td class="td-muted"
                        style="max-width:130px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
                        title="<%= sub.descricao || '' %>">
                        <%= sub.descricao || '—' %>
                      </td>
                      <td>
                        <form action="/admin/subcategorias/<%= sub.id %>/status" method="POST" style="display:inline;">
                          <button type="submit"
                            class="status-badge <%= sub.status === 'ativo' ? 'status-ativo' : 'status-inativo' %>"
                            title="Clique para alternar o status">
                            <%= sub.status === 'ativo' ? '✅ Ativo' : '⛔ Inativo' %>
                          </button>
                        </form>
                      </td>
                      <td>
                        <div class="action-btns">
                          <a href="/admin/subcategorias/<%= sub.id %>/editar" class="btn-icon btn-edit" title="Editar">✏️</a>
                          <form action="/admin/subcategorias/<%= sub.id %>/deletar" method="POST" style="display:inline;">
                            <button type="button" class="btn-icon btn-delete" title="Excluir"
                              data-nome="<%= sub.nome %>"
                              onclick="confirmDelete(this, this.dataset.nome)">🗑️</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div><!-- /.sub-layout -->
    </div><!-- /.app-content -->

    <style>
      /* ── Layout geral ── */
      .sub-layout {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      /* ── Form + painel lado a lado dentro do card ── */
      .form-and-panel {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        align-items: start;
      }
      @media (max-width: 768px) {
        .form-and-panel { grid-template-columns: 1fr; }
      }
      .form-col  { min-width: 0; }
      .panel-col { min-width: 0; }

      /* ── Notice no painel de checklists (modo criar) ── */
      .chk-panel-create .chk-panel-chips {
        min-height: 5rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .chk-panel-notice {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        text-align: center;
      }
      .chk-panel-notice-icon { font-size: 1.5rem; line-height: 1; }
      .chk-panel-notice p {
        margin: 0;
        font-size: .85rem;
        color: var(--text-muted);
        font-style: italic;
        line-height: 1.5;
      }

      /* ── Header com ações ── */
      .header-actions {
        display: flex;
        align-items: center;
        gap: .35rem;
        flex-wrap: nowrap;
        white-space: nowrap;
      }

      .header-actions .btn-sm {
        font-size: .75rem;
        padding: .3rem .6rem;
      }

      .header-actions .card-badge {
        font-size: .72rem;
        padding: .2rem .55rem;
      }

      /* ── Status badges ── */
      .status-badge {
        display: inline-block;
        padding: .25rem .65rem;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: opacity .2s, transform .1s;
      }

      .status-badge:hover { opacity: .8; transform: scale(.97); }

      .status-ativo  { background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }
      .status-inativo { background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5; }

      /* ── Badge de categoria ── */
      .categoria-badge {
        display: inline-block;
        padding: .2rem .6rem;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 600;
        background: var(--blue-light);
        color: var(--blue);
        border: 1px solid var(--blue-mid, #bfdbfe);
        white-space: nowrap;
      }

      /* ── Botões de ação ── */
      .action-btns { display: flex; gap: .4rem; align-items: center; }

      .btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: .4rem;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        background: transparent;
        transition: background .15s, transform .1s;
        text-decoration: none;
      }

      .btn-icon:hover { background: rgba(0,0,0,.06); transform: scale(1.1); }
      .btn-edit:hover  { background: #dbeafe; }
      .btn-delete:hover { background: #fee2e2; }

      /* ── Checkbox ── */
      .th-check, .td-check {
        width: 2.25rem;
        text-align: center;
        padding-left: 1rem !important;
      }

      input[type="checkbox"] {
        width: 1rem;
        height: 1rem;
        cursor: pointer;
        accent-color: var(--blue);
      }

      tr.row-selected { background: var(--blue-light) !important; }

      /* ── Select e textarea ── */
      .form-group select,
      .form-group textarea {
        width: 100%;
        padding: .65rem .9rem;
        font-size: .925rem;
        font-family: inherit;
        color: var(--text);
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        outline: none;
        transition: border-color var(--transition), box-shadow var(--transition);
        box-sizing: border-box;
      }

      .form-group select:focus,
      .form-group textarea:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(3, 110, 192, .12);
      }

      .form-group textarea { resize: vertical; }
      /* ── Chips de checklists na tabela ── */
      .td-checklists { min-width: 140px; }
      .chk-chips { display: flex; flex-wrap: wrap; gap: .3rem; }
      .chk-chip {
        display: inline-block;
        padding: .15rem .5rem;
        border-radius: 999px;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .03em;
        white-space: nowrap;
      }
      .chk-chip-geral     { background:#ede9fe; color:#7c3aed; border:1px solid #c4b5fd; }
      .chk-chip-especifica { background:#fef9c3; color:#a16207; border:1px solid #fde68a; }
      .chk-chip-more {
        font-size: .7rem;
        color: var(--text-muted);
        font-weight: 600;
        padding: .15rem .3rem;
      }

      /* ── Painel de checklists vinculados (edição) ── */
      .chk-panel {
        margin-top: 1.5rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
      }
      .chk-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .65rem 1rem;
        background: var(--surface, #f8fafc);
        border-bottom: 1.5px solid var(--border);
        font-weight: 600;
        font-size: .875rem;
        color: var(--text);
      }
      .chk-panel-count {
        background: var(--blue);
        color: #fff;
        font-size: .7rem;
        font-weight: 700;
        padding: .1rem .5rem;
        border-radius: 999px;
        min-width: 1.4rem;
        text-align: center;
      }
      .chk-panel-chips {
        padding: .85rem 1rem;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        min-height: 3rem;
      }
      .chk-panel-chip {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .35rem .65rem;
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        transition: border-color .15s;
      }
      .chk-panel-chip:hover { border-color: var(--blue); }
      .chk-panel-chip-nome {
        flex: 1;
        font-size: .85rem;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .chk-panel-chip-remove {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-size: .85rem;
        padding: .1rem .3rem;
        border-radius: .3rem;
        transition: background .15s, color .15s;
        flex-shrink: 0;
      }
      .chk-panel-chip-remove:hover { background: #fee2e2; color: #dc2626; }
      .chk-panel-empty {
        font-size: .85rem;
        color: var(--text-muted);
        margin: 0;
        font-style: italic;
      }
      .chk-panel-add {
        display: flex;
        gap: .6rem;
        padding: .75rem 1rem;
        border-top: 1.5px solid var(--border);
        background: var(--surface, #f8fafc);
      }
      .chk-panel-select {
        flex: 1;
        padding: .5rem .75rem;
        font-size: .85rem;
        font-family: inherit;
        color: var(--text);
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box;
      }
      .chk-panel-select:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(3,110,192,.12);
      }
    </style>

    <script>
      // ── Vinculação de checklists (painel de edição) ───────────
      const _btnVincular = document.getElementById('btn-vincular');
      if (_btnVincular) {
        _btnVincular.addEventListener('click', function () {
          vincularChecklist(Number(this.dataset.subId));
        });
      }

      async function vincularChecklist(subId) {
        const sel = document.getElementById('chk-select-add');
        const chkId = sel.value;
        if (!chkId) {
          Modal.notify({ type: 'warning', title: 'Selecione um checklist', message: 'Escolha um checklist na lista antes de vincular.', autoClose: false });
          return;
        }
        const opt = sel.options[sel.selectedIndex];
        const codigo = opt.dataset.codigo;
        const nome   = opt.dataset.nome;
        const tipo   = (opt.dataset.tipo || 'GERAL').toLowerCase();

        // Verifica se já está vinculado
        if (document.querySelector('#chk-panel-chips .chk-panel-chip[data-id="' + chkId + '"]')) {
          Modal.notify({ type: 'warning', title: 'Já vinculado', message: 'Este checklist já está vinculado a esta subcategoria.', autoClose: false });
          return;
        }

        const btn = document.getElementById('btn-vincular');
        btn.disabled = true;
        btn.textContent = 'Vinculando...';
        try {
          const resp = await fetch('/admin/subcategorias/' + subId + '/checklists/vincular', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ checklistId: Number(chkId) }),
          });
          const data = await resp.json();
          if (!data.ok) {
            Modal.notify({ type: 'error', title: 'Erro', message: data.mensagem || 'Não foi possível vincular.', autoClose: false });
            return;
          }
          // Adiciona chip na UI (sem onclick inline)
          const chips = document.getElementById('chk-panel-chips');
          const empty = document.getElementById('chk-panel-empty');
          if (empty) empty.remove();

          const chip = document.createElement('div');
          chip.className = 'chk-panel-chip';
          chip.dataset.id = chkId;

          const spanCodigo = document.createElement('span');
          spanCodigo.className = 'chk-chip chk-chip-' + tipo;
          spanCodigo.style.pointerEvents = 'none';
          spanCodigo.textContent = codigo;

          const spanNome = document.createElement('span');
          spanNome.className = 'chk-panel-chip-nome';
          spanNome.textContent = nome;

          const btnRemover = document.createElement('button');
          btnRemover.type = 'button';
          btnRemover.className = 'chk-panel-chip-remove btn-desvincular';
          btnRemover.title = 'Desvincular';
          btnRemover.textContent = '✕';
          btnRemover.dataset.subId = String(subId);
          btnRemover.dataset.chkId = String(chkId);

          chip.appendChild(spanCodigo);
          chip.appendChild(spanNome);
          chip.appendChild(btnRemover);
          chips.appendChild(chip);

          atualizarContador();
          sel.value = '';
          Modal.notify({ type: 'success', title: 'Vinculado', message: 'Checklist <strong>' + codigo + '</strong> vinculado com sucesso.' });
        } catch (err) {
          console.error(err);
          Modal.notify({ type: 'error', title: 'Erro de rede', message: 'Não foi possível conectar ao servidor.', autoClose: false });
        } finally {
          btn.disabled = false;
          btn.textContent = '➕ Vincular';
        }
      }

      // Event delegation para botões de desvincular (estticos e dinâmicos)
      document.addEventListener('click', function (e) {
        const btnDes = e.target.closest('.btn-desvincular');
        if (!btnDes) return;
        const subId = Number(btnDes.dataset.subId);
        const chkId = Number(btnDes.dataset.chkId);
        const chip  = btnDes.closest('.chk-panel-chip');
        const nome  = chip ? chip.querySelector('.chk-panel-chip-nome')?.textContent?.trim() : '';
        Modal.confirm({
          title: 'Desvincular checklist',
          message: 'Remover o vínculo com <strong>' + (nome || 'este checklist') + '</strong>?',
          confirmText: '✕ Desvincular',
          onConfirm: async () => {
            try {
              const resp = await fetch('/admin/subcategorias/' + subId + '/checklists/desvincular', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ checklistId: chkId }),
              });
              const data = await resp.json();
              if (!data.ok) {
                Modal.notify({ type: 'error', title: 'Erro', message: data.mensagem || 'Não foi possível desvincular.', autoClose: false });
                return;
              }
              if (chip) chip.remove();
              const chips = document.getElementById('chk-panel-chips');
              if (chips && chips.querySelectorAll('.chk-panel-chip').length === 0) {
                const p = document.createElement('p');
                p.className = 'chk-panel-empty';
                p.id = 'chk-panel-empty';
                p.textContent = 'Nenhum checklist vinculado.';
                chips.appendChild(p);
              }
              atualizarContador();
              Modal.notify({ type: 'success', title: 'Desvinculado', message: 'Checklist desvinculado com sucesso.' });
            } catch (err) {
              console.error(err);
              Modal.notify({ type: 'error', title: 'Erro de rede', message: 'Não foi possível conectar ao servidor.', autoClose: false });
            }
          }
        });
      });

      function atualizarContador() {
        const chips = document.querySelectorAll('#chk-panel-chips .chk-panel-chip');
        const el = document.getElementById('chk-panel-count');
        if (el) el.textContent = chips.length;
      }

      // Filtra o select de checklists removendo os que já estão vinculados
      (function filtrarSelectChecklists() {
        const panel = document.getElementById('chk-panel');
        if (!panel) return;
        const vinculados = [...panel.querySelectorAll('.chk-panel-chip')].map(c => String(c.dataset.id));
        const sel = document.getElementById('chk-select-add');
        if (!sel) return;
        [...sel.options].forEach(opt => {
          if (opt.value && vinculados.includes(opt.value)) opt.style.display = 'none';
        });
      })();

      // ── Seleção ──────────────────────────────────────────────
      function getChecks() { return [...document.querySelectorAll('.row-check')]; }
      function getSelected() { return getChecks().filter(c => c.checked); }

      function onCheckChange() {
        const all = getChecks();
        const sel = getSelected();
        const sa = document.getElementById('select-all');
        if (sa) {
          sa.checked = sel.length > 0 && sel.length === all.length;
          sa.indeterminate = sel.length > 0 && sel.length < all.length;
        }
        all.forEach(c => c.closest('tr').classList.toggle('row-selected', c.checked));
        const btn = document.getElementById('btn-del-sel');
        if (btn) btn.style.display = sel.length > 0 ? 'inline-flex' : 'none';
      }

      function toggleSelectAll(el) {
        getChecks().forEach(c => { c.checked = el.checked; });
        onCheckChange();
      }

      // ── Excluir selecionados ─────────────────────────────────
      function deletarSelecionados() {
        const sel = getSelected();
        if (!sel.length) return;
        const nomes = sel.map(c => c.dataset.nome).join(', ');
        Modal.confirm({
          title: 'Excluir selecionados',
          message: 'Deseja excluir <strong>' + sel.length + '</strong> subcategoria(s)?<br><small style="color:var(--text-muted)">' + nomes + '</small>',
          confirmText: '🗑️ Excluir',
          onConfirm: () => {
            const form = document.getElementById('form-del-sel');
            form.innerHTML = '';
            sel.forEach(c => {
              const inp = document.createElement('input');
              inp.type = 'hidden'; inp.name = 'ids'; inp.value = c.value;
              form.appendChild(inp);
            });
            form.submit();
          }
        });
      }

      // ── Exportar (CSV) ───────────────────────────────────────
      function exportarSelecionados() {
        const alvo = getSelected().length ? getSelected() : getChecks();
        if (!alvo.length) {
          Modal.notify({ type: 'warning', title: 'Nada para exportar', message: 'Não há subcategorias para exportar.', autoClose: false });
          return;
        }
        const linhas = [['id', 'nome', 'descricao', 'status', 'categoriaId']];
        alvo.forEach(c => {
          const id    = c.value;
          const nome  = '"' + c.dataset.nome.replace(/"/g, '""') + '"';
          const desc  = '"' + (c.dataset.descricao || '').replace(/"/g, '""') + '"';
          const status = c.dataset.status;
          const catId  = c.dataset.categoriaId;
          linhas.push([id, nome, desc, status, catId]);
        });
        const csv = linhas.map(r => r.join(',')).join('\n');
        const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'subcategorias_' + new Date().toISOString().slice(0, 10) + '.csv';
        a.click();
        URL.revokeObjectURL(url);
      }

      // ── Importar (JSON ou CSV) ───────────────────────────────
      function importarArquivo(input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = async (e) => {
          let lista = [];
          const txt = e.target.result;
          try {
            if (file.name.endsWith('.json')) {
              const parsed = JSON.parse(txt);
              lista = Array.isArray(parsed) ? parsed : (parsed.subcategorias || []);
            } else {
              const rows = txt.trim().split(/\r?\n/);
              const head = rows[0].split(',').map(h => h.replace(/^"|"$/g, '').trim().toLowerCase());
              for (let i = 1; i < rows.length; i++) {
                const cols = rows[i].match(/(".*?"|[^,]+|(?<=,)(?=,)|^(?=,)|(?<=,)$)/g) || [];
                const obj = {};
                head.forEach((h, j) => { obj[h] = (cols[j] || '').replace(/^"|"$/g, '').trim(); });
                lista.push(obj);
              }
            }
          } catch (err) {
            Modal.notify({ type: 'error', title: 'Arquivo inválido', message: 'Não foi possível ler o arquivo. Verifique o formato.', autoClose: false });
            input.value = '';
            return;
          }

          if (!lista.length) {
            Modal.notify({ type: 'warning', title: 'Arquivo vazio', message: 'Nenhum registro encontrado no arquivo.', autoClose: false });
            input.value = ''; return;
          }

          try {
            const resp = await fetch('/admin/subcategorias/importar', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ subcategorias: lista }),
            });
            const data = await resp.json();
            if (data.ok) {
              Modal.confirm({
                title: 'Importação concluída',
                message: '✅ <strong>' + data.importados + '</strong> subcategoria(s) importada(s).<br>⏭️ <strong>' + data.ignorados + '</strong> ignorada(s) (já existiam, inválidas ou sem categoriaId).',
                confirmText: 'Recarregar',
                cancelText: 'Fechar',
                onConfirm: () => location.reload(),
              });
            } else {
              Modal.notify({ type: 'error', title: 'Erro na importação', message: data.mensagem || 'Erro desconhecido.', autoClose: false });
            }
          } catch (err) {
            Modal.notify({ type: 'error', title: 'Erro de rede', message: 'Não foi possível enviar o arquivo. Tente novamente.', autoClose: false });
          }
          input.value = '';
        };
        reader.readAsText(file, 'UTF-8');
      }
    </script>

</body>

