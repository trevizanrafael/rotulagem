<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/_head') %>
  <title>Seções — <%= checklist.codigo %> — FoodTech</title>
</head>
<body>

  <%- include('../partials/_admin-layout', { currentPage: 'checklist-secoes' }) %>

  <div class="app-content">

    <!-- ── Breadcrumb ── -->
    <div class="breadcrumb fade-up">
      <a href="/admin/checklists">Checklists</a>
      <span class="bc-sep">›</span>
      <span><%= checklist.codigo %> — <%= checklist.nome %></span>
    </div>

    <div class="page-header fade-up">
      <div>
        <h1>Seções do Checklist</h1>
        <p>Organize as seções de <strong><%= checklist.nome %></strong>. Arraste para reordenar.</p>
      </div>
      <div style="display:flex;gap:.5rem;align-items:center;">
        <span class="chk-codigo"><%= checklist.codigo %></span>
        <span class="chk-tipo chk-tipo-<%= checklist.tipo.toLowerCase() %>"><%= checklist.tipo %></span>
      </div>
    </div>

    <%
      let _type='', _title='', _msg='', _ac='true';
      if      (sucesso==='secao_criada')    { _type='success'; _title='Criada';     _msg='Seção criada com sucesso!'; }
      else if (sucesso==='secao_atualizada'){ _type='success'; _title='Atualizada'; _msg='Seção atualizada com sucesso!'; }
      else if (sucesso==='secao_deletada')  { _type='success'; _title='Removida';   _msg='Seção removida com sucesso!'; }
      else if (erro==='nao_encontrado')     { _type='error';   _title='Não encontrado'; _msg='Seção não encontrada.'; _ac='false'; }
      else if (erro==='erro_interno')       { _type='error';   _title='Erro interno';   _msg='Erro inesperado. Tente novamente.'; _ac='false'; }
    %>
    <% if (_type) { %>
      <div id="page-notify" hidden
        data-type="<%= _type %>"
        data-title="<%= _title %>"
        data-message="<%= _msg %>"
        data-autoclose="<%= _ac %>"></div>
    <% } %>

    <div class="cols-secoes fade-up d1">

      <!-- ── Formulário de criação ── -->
      <div class="card">
        <div class="card-header"><h2>Nova Seção</h2></div>
        <div class="card-body">
          <form action="/admin/checklists/<%= checklist.id %>/secoes" method="POST">
            <div class="form-group">
              <label for="titulo">Título <span class="req">*</span></label>
              <input type="text" id="titulo" name="titulo" placeholder="ex: Informações Gerais" required maxlength="200">
            </div>
            <div class="form-group">
              <label for="descricao">Descrição</label>
              <textarea id="descricao" name="descricao" rows="3" placeholder="Descreva o objetivo desta seção..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; margin-top:.25rem;">
              ➕ Adicionar Seção
            </button>
          </form>
        </div>
      </div>

      <!-- ── Lista de seções (drag-and-drop) ── -->
      <div class="card">
        <div class="card-header">
          <h2>Seções cadastradas</h2>
          <span class="card-badge"><%= secoes.length %> seção<%= secoes.length !== 1 ? 'ões' : '' %></span>
        </div>

        <% if (secoes.length === 0) { %>
          <div class="empty-state" style="padding:2.5rem 1rem;">
            <div class="empty-state-icon">📑</div>
            <p>Nenhuma seção ainda.<br>Use o formulário ao lado para começar.</p>
          </div>
        <% } else { %>
          <div class="secoes-hint">
            <span>🖱️ Arraste as seções para definir a ordem</span>
          </div>
          <ul id="secoes-list" class="secoes-list">
            <% secoes.forEach(function(sec) { %>
              <li class="secao-item" data-id="<%= sec.id %>">
                <div class="drag-handle" title="Arrastar para reordenar">
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="17" x2="21" y2="17"/>
                  </svg>
                </div>
                <div class="secao-info">
                  <div class="secao-titulo-row">
                    <span class="secao-num">Seção <%= sec.ordem + 1 %></span>
                    <span class="secao-status-dot <%= sec.status === 'ativo' ? 'dot-ativo' : 'dot-inativo' %>"></span>
                  </div>
                  <strong class="secao-titulo"><%= sec.titulo %></strong>
                  <% if (sec.descricao) { %>
                    <p class="secao-desc"><%= sec.descricao %></p>
                  <% } %>
                </div>
                <div class="secao-actions">
                  <a href="/admin/checklists/<%= checklist.id %>/secoes/<%= sec.id %>/itens"
                     class="btn btn-primary btn-xs" title="Ver itens">
                    📋 Itens
                  </a>
                  <button class="btn btn-ghost btn-xs btn-editar-secao"
                    data-id="<%= sec.id %>"
                    data-titulo="<%= (sec.titulo || '').replace(/"/g, '&quot;') %>"
                    data-descricao="<%= (sec.descricao || '').replace(/"/g, '&quot;') %>"
                    data-status="<%= sec.status %>"
                    title="Editar seção">✏️</button>
                  <button class="btn btn-danger btn-xs btn-excluir-secao"
                    data-id="<%= sec.id %>"
                    data-titulo="<%= (sec.titulo || '').replace(/"/g, '&quot;') %>"
                    title="Excluir seção">🗑️</button>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

    </div><!-- /.cols-secoes -->
  </div><!-- /.app-content -->

  <!-- ── Modal de Edição ── -->
  <div id="modal-editar" class="chk-modal-overlay" style="display:none;" onclick="fecharFora(event)">
    <div class="chk-modal">
      <div class="chk-modal-header">
        <h3>✏️ Editar Seção</h3>
        <button class="chk-modal-close" onclick="fecharModal()">✕</button>
      </div>
      <form id="form-editar" method="POST">
        <div class="chk-modal-body">
          <div class="form-group">
            <label>Título <span class="req">*</span></label>
            <input type="text" id="edit-titulo" name="titulo" required maxlength="200">
          </div>
          <div class="form-group">
            <label>Descrição</label>
            <textarea id="edit-descricao" name="descricao" rows="3"></textarea>
          </div>
          <div class="form-group">
            <label>Status</label>
            <select id="edit-status" name="status">
              <option value="ativo">✅ Ativo</option>
              <option value="inativo">⛔ Inativo</option>
            </select>
          </div>
        </div>
        <div class="chk-modal-footer">
          <button type="button" class="btn btn-secondary" onclick="fecharModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary">💾 Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <form id="form-deletar" method="POST" style="display:none;"></form>

  <style>
    /* ── Breadcrumb ── */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: .4rem;
      font-size: .85rem;
      margin-bottom: 1rem;
      color: var(--text-muted);
    }
    .breadcrumb a { color: var(--blue); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .bc-sep { color: var(--border); font-size:1.1rem; }

    /* ── Layout ── */
    .cols-secoes {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 1.5rem;
      align-items: start;
    }
    @media (max-width: 768px) { .cols-secoes { grid-template-columns: 1fr; } }

    /* ── Hint ── */
    .secoes-hint {
      padding: .5rem 1.25rem;
      font-size: .8rem;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
    }

    /* ── Lista drag ── */
    .secoes-list {
      list-style: none;
      margin: 0;
      padding: .75rem 1rem;
      display: flex;
      flex-direction: column;
      gap: .6rem;
    }

    .secao-item {
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      padding: .9rem 1rem;
      background: var(--surface, #f8fafd);
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      transition: box-shadow .2s, background .15s;
      cursor: default;
    }
    .secao-item:hover { box-shadow: 0 3px 12px rgba(3,110,192,.1); }
    .secao-item.dragging {
      opacity: .5;
      box-shadow: 0 8px 24px rgba(3,110,192,.2);
    }
    .secao-item.drag-over {
      border-color: var(--blue);
      background: var(--blue-light);
    }

    .drag-handle {
      color: var(--text-muted);
      cursor: grab;
      padding: .2rem;
      flex-shrink: 0;
      margin-top: .15rem;
    }
    .drag-handle:active { cursor: grabbing; }

    .secao-info { flex: 1; min-width: 0; }
    .secao-titulo-row { display:flex; align-items:center; gap:.5rem; margin-bottom:.2rem; }
    .secao-num { font-size:.72rem; font-weight:700; color:var(--blue); background:var(--blue-light); border-radius:999px; padding:.1rem .45rem; }
    .secao-status-dot { width:.55rem; height:.55rem; border-radius:50%; flex-shrink:0; }
    .dot-ativo   { background:#22c55e; }
    .dot-inativo { background:#ef4444; }
    .secao-titulo { font-size:.95rem; font-weight:600; color:var(--text); display:block; }
    .secao-desc { font-size:.82rem; color:var(--text-muted); margin:.25rem 0 0; line-height:1.4;
      display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }

    .secao-actions { display:flex; flex-direction:column; gap:.35rem; flex-shrink:0; }
    .btn-xs { font-size:.75rem; padding:.25rem .6rem; white-space:nowrap; }

    /* ── Badges ── */
    .chk-codigo { font-size:.72rem; font-weight:700; background:var(--blue-light); color:var(--blue);
      border:1px solid var(--blue-mid,#bfdbfe); border-radius:999px; padding:.15rem .55rem; letter-spacing:.04em; }
    .chk-tipo { font-size:.7rem; font-weight:700; border-radius:999px; padding:.15rem .55rem; }
    .chk-tipo-geral     { background:#ede9fe; color:#7c3aed; border:1px solid #c4b5fd; }
    .chk-tipo-especifica { background:#fef9c3; color:#a16207; border:1px solid #fde68a; }

    /* ── Modal ── */
    .chk-modal-overlay {
      position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:1000;
      display:flex; align-items:center; justify-content:center;
      backdrop-filter:blur(3px); animation:fadeIn .15s ease;
    }
    @keyframes fadeIn { from{opacity:0} to{opacity:1} }
    .chk-modal {
      background:var(--white); border-radius:var(--radius-lg,.75rem); width:100%; max-width:520px;
      box-shadow:0 20px 60px rgba(0,0,0,.2); animation:slideUp .2s ease; overflow:hidden;
    }
    @keyframes slideUp { from{transform:translateY(16px);opacity:0} to{transform:none;opacity:1} }
    .chk-modal-header { display:flex; align-items:center; justify-content:space-between;
      padding:1.1rem 1.5rem; border-bottom:1px solid var(--border); }
    .chk-modal-header h3 { margin:0; font-size:1.05rem; }
    .chk-modal-close { background:none; border:none; font-size:1.1rem; cursor:pointer;
      color:var(--text-muted); padding:.2rem .4rem; border-radius:.3rem; transition:background .15s; }
    .chk-modal-close:hover { background:var(--surface); }
    .chk-modal-body  { padding:1.25rem 1.5rem; }
    .chk-modal-footer { padding:1rem 1.5rem; border-top:1px solid var(--border);
      display:flex; justify-content:flex-end; gap:.75rem; }

    .req { color:var(--danger); }

    select, .form-group textarea {
      width:100%; padding:.65rem .9rem; font-size:.925rem; font-family:inherit;
      color:var(--text); background:var(--white); border:1.5px solid var(--border);
      border-radius:var(--radius); outline:none;
      transition:border-color var(--transition),box-shadow var(--transition); box-sizing:border-box;
    }
    select:focus, .form-group textarea:focus {
      border-color:var(--blue); box-shadow:0 0 0 3px rgba(3,110,192,.12);
    }
    .form-group textarea { resize:vertical; }
  </style>

  <script>
    /* ─── Drag & Drop (nativo) ───────────────────────────── */
    const list = document.getElementById('secoes-list');
    let dragged = null;

    if (list) {
      list.querySelectorAll('.secao-item').forEach(item => {
        item.setAttribute('draggable', 'true');

        item.addEventListener('dragstart', () => {
          dragged = item;
          setTimeout(() => item.classList.add('dragging'), 0);
        });
        item.addEventListener('dragend', () => {
          item.classList.remove('dragging');
          list.querySelectorAll('.secao-item').forEach(i => i.classList.remove('drag-over'));
          salvarOrdem();
        });
        item.addEventListener('dragover', e => {
          e.preventDefault();
          list.querySelectorAll('.secao-item').forEach(i => i.classList.remove('drag-over'));
          if (item !== dragged) item.classList.add('drag-over');
        });
        item.addEventListener('drop', e => {
          e.preventDefault();
          if (item !== dragged) {
            const items = [...list.querySelectorAll('.secao-item')];
            const fromIdx = items.indexOf(dragged);
            const toIdx   = items.indexOf(item);
            if (fromIdx < toIdx) list.insertBefore(dragged, item.nextSibling);
            else                 list.insertBefore(dragged, item);
            atualizarNumeracao();
          }
        });
      });
    }

    function atualizarNumeracao() {
      if (!list) return;
      list.querySelectorAll('.secao-num').forEach((el, idx) => {
        el.textContent = 'Seção ' + (idx + 1);
      });
    }

    async function salvarOrdem() {
      const ids = [...list.querySelectorAll('.secao-item')].map(el => el.dataset.id);
      try {
        await fetch('/admin/checklists/<%= checklist.id %>/secoes/reordenar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ordem: ids }),
        });
      } catch (e) { console.error('Erro ao salvar ordem:', e); }
    }

    /* ─── Modal editar ───────────────────────────────────── */
    function abrirModalEditar(id, titulo, descricao, status) {
      document.getElementById('edit-titulo').value    = titulo    || '';
      document.getElementById('edit-descricao').value = descricao || '';
      document.getElementById('edit-status').value    = status    || 'ativo';
      document.getElementById('form-editar').action   =
        '/admin/checklists/<%= checklist.id %>/secoes/' + id + '/editar';
      document.getElementById('modal-editar').style.display = 'flex';
    }
    function fecharModal() { document.getElementById('modal-editar').style.display = 'none'; }
    function fecharFora(e) { if (e.target.id === 'modal-editar') fecharModal(); }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') fecharModal(); });

    /* ─── Confirmar exclusão ─────────────────────────────── */
    function confirmarExclusao(id, titulo) {
      Modal.confirm({
        title: 'Excluir Secao',
        message: 'Deseja excluir a secao <strong>' + titulo + '</strong>?<br><small style="color:var(--text-muted)">Todos os itens desta secao serao removidos.</small>',
        confirmText: 'Excluir',
        onConfirm: () => {
          const form = document.getElementById('form-deletar');
          form.action = '/admin/checklists/<%= checklist.id %>/secoes/' + id + '/deletar';
          form.submit();
        }
      });
    }

    /* ─── Delegacao: botoes com data-* ─────────────────── */
    document.addEventListener('click', function (e) {
      const btnEdit = e.target.closest('.btn-editar-secao');
      if (btnEdit) {
        const d = btnEdit.dataset;
        abrirModalEditar(d.id, d.titulo, d.descricao, d.status);
        return;
      }
      const btnDel = e.target.closest('.btn-excluir-secao');
      if (btnDel) {
        const d = btnDel.dataset;
        confirmarExclusao(d.id, d.titulo);
      }
    });
  </script>

</body>
</html>
