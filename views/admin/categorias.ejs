<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <%- include('../partials/_head') %>
    <title>Categorias de Produtos — FoodTech</title>
</head>

<body>

  <%- include('../partials/_admin-layout', { currentPage: 'categorias' }) %>

    <div class="app-content">
      <div class="page-header fade-up">
        <h1>Categorias de Produtos</h1>
        <p>Gerencie as categorias disponíveis para classificação de produtos.</p>
      </div>

      <div class="cols-2">

        <!-- ======================== FORMULÁRIO ======================== -->
        <div class="card fade-up d1">
          <div class="card-header">
            <% if (editando) { %>
              <h2>Editar categoria</h2>
              <% } else { %>
                <h2>Nova categoria</h2>
                <% } %>
          </div>
          <div class="card-body">

            <!-- Notificação automática via #page-notify (lido por modal.js) -->
            <% let _type='' , _title='' , _msg='' , _ac='true' ; if (sucesso==='categoria_criada' ) { _type='success' ;
              _title='Categoria criada' ; _msg='Categoria criada com sucesso!' ; } else if
              (sucesso==='categoria_atualizada' ) { _type='success' ; _title='Atualizada' ;
              _msg='Categoria atualizada com sucesso!' ; } else if (sucesso==='categoria_deletada' ) { _type='success' ;
              _title='Removida' ; _msg='Categoria removida com sucesso!' ; } else if (sucesso==='status_alterado' ) {
              _type='success' ; _title='Status alterado' ; _msg='O status da categoria foi atualizado.' ; } else if
              (sucesso==='selecionados_deletados' ) { _type='success' ; _title='Excluídas' ; _msg=`${count
              || 'As categorias' } selecionada(s) foram excluídas.`; } else if (erro==='nome_ja_existe' ) {
              _type='error' ; _title='Nome duplicado' ; _msg='Já existe uma categoria com esse nome.' ; _ac='false' ; }
              else if (erro==='nao_encontrado' ) { _type='error' ; _title='Não encontrado' ;
              _msg='Categoria não encontrada.' ; _ac='false' ; } else if (erro==='nenhum_selecionado' ) {
              _type='warning' ; _title='Nenhum selecionado' ;
              _msg='Selecione ao menos uma categoria antes de prosseguir.' ; _ac='false' ; } else if
              (erro==='erro_interno' ) { _type='error' ; _title='Erro interno' ;
              _msg='Ocorreu um erro inesperado. Tente novamente.' ; _ac='false' ; } %>
              <% if (_type) { %>
                <div id="page-notify" hidden data-type="<%= _type %>" data-title="<%= _title %>"
                  data-message="<%= _msg %>" data-autoclose="<%= _ac %>"></div>
                <% } %>

                  <!-- Formulário CREATE -->
                  <% if (!editando) { %>
                    <form action="/admin/categorias" method="POST" id="form-criar">
                      <div class="form-group">
                        <label for="nome">Nome da categoria <span style="color:var(--danger);">*</span></label>
                        <input type="text" id="nome" name="nome" placeholder="ex: Laticínios" required maxlength="100">
                      </div>
                      <div class="form-group">
                        <label for="descricao">Descrição</label>
                        <textarea id="descricao" name="descricao" rows="3"
                          placeholder="Descreva brevemente a categoria..." style="resize:vertical;"></textarea>
                      </div>
                      <button type="submit" class="btn btn-primary" style="width:100%; margin-top:.25rem;">
                        ➕ Criar categoria
                      </button>
                    </form>

                    <!-- Formulário EDIT -->
                    <% } else { %>
                      <form action="/admin/categorias/<%= editando.id %>" method="POST" id="form-editar">
                        <div class="form-group">
                          <label for="nome-edit">Nome da categoria <span style="color:var(--danger);">*</span></label>
                          <input type="text" id="nome-edit" name="nome" value="<%= editando.nome %>" required
                            maxlength="100">
                        </div>
                        <div class="form-group">
                          <label for="descricao-edit">Descrição</label>
                          <textarea id="descricao-edit" name="descricao" rows="3"
                            style="resize:vertical;"><%= editando.descricao || '' %></textarea>
                        </div>
                        <div class="form-group">
                          <label for="status-edit">Status</label>
                          <select id="status-edit" name="status">
                            <option value="ativo" <%=editando.status==='ativo' ? 'selected' : '' %>>✅ Ativo</option>
                            <option value="inativo" <%=editando.status==='inativo' ? 'selected' : '' %>>⛔ Inativo
                            </option>
                          </select>
                        </div>
                        <div style="display:flex; gap:.75rem; margin-top:.25rem;">
                          <button type="submit" class="btn btn-primary" style="flex:1;">💾 Salvar alterações</button>
                          <a href="/admin/categorias" class="btn btn-secondary"
                            style="flex:1; text-align:center;">Cancelar</a>
                        </div>
                      </form>
                      <% } %>

          </div>
        </div>

        <!-- ======================== TABELA ======================== -->
        <div class="card fade-up d2">
          <div class="card-header">
            <h2>Categorias cadastradas</h2>
            <div class="header-actions">
              <span class="card-badge">
                <%= categorias.length %> no total
              </span>
              <button id="btn-del-sel" class="btn btn-danger btn-sm" style="display:none"
                onclick="deletarSelecionados()">
                🗑️ Excluir
              </button>
              <label class="btn btn-ghost btn-sm" style="cursor:pointer;" title="Importar categorias (JSON ou CSV)">
                📥 Importar
                <input type="file" id="import-file" accept=".json,.csv" style="display:none"
                  onchange="importarArquivo(this)">
              </label>
              <button class="btn btn-ghost btn-sm" onclick="exportarSelecionados()"
                title="Exportar categorias selecionadas">📤 Exportar</button>
            </div>
          </div>

          <% if (categorias.length===0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">🏷️</div>
              <p>Nenhuma categoria cadastrada ainda.<br>Use o formulário ao lado para adicionar.</p>
            </div>
            <% } else { %>

              <!-- Form oculto para exclusão em massa (submit via JS) -->
              <form id="form-del-sel" action="/admin/categorias/deletar-selecionados" method="POST"
                style="display:none;">
              </form>

              <div class="table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th class="th-check">
                        <input type="checkbox" id="select-all" title="Selecionar todos"
                          onchange="toggleSelectAll(this)">
                      </th>
                      <th>#</th>
                      <th>Nome</th>
                      <th>Descrição</th>
                      <th>Status</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% categorias.forEach(function(cat) { %>
                      <tr>
                        <td class="td-check">
                          <input type="checkbox" class="row-check" value="<%= cat.id %>" data-nome="<%= cat.nome %>"
                            data-descricao="<%= (cat.descricao || '').replace(/" /g, '&quot;' ) %>"
                          data-status="<%= cat.status %>"
                            onchange="onCheckChange()">
                        </td>
                        <td class="td-id">
                          <%= cat.id %>
                        </td>
                        <td style="font-weight:600; color:var(--text);">
                          <%= cat.nome %>
                        </td>
                        <td class="td-muted"
                          style="max-width:160px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
                          title="<%= cat.descricao || '' %>">
                          <%= cat.descricao || '—' %>
                        </td>
                        <td>
                          <form action="/admin/categorias/<%= cat.id %>/status" method="POST" style="display:inline;">
                            <button type="submit"
                              class="status-badge <%= cat.status === 'ativo' ? 'status-ativo' : 'status-inativo' %>"
                              title="Clique para alternar o status">
                              <%= cat.status==='ativo' ? '✅ Ativo' : '⛔ Inativo' %>
                            </button>
                          </form>
                        </td>
                        <td>
                          <div class="action-btns">
                            <a href="/admin/categorias/<%= cat.id %>/editar" class="btn-icon btn-edit"
                              title="Editar">✏️</a>
                            <form action="/admin/categorias/<%= cat.id %>/deletar" method="POST"
                              style="display:inline;">
                              <button type="button" class="btn-icon btn-delete" title="Excluir"
                                data-nome="<%= cat.nome %>"
                                onclick="confirmDelete(this, this.dataset.nome)">🗑️</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
              <% } %>
        </div>

      </div><!-- /.cols-2 -->
    </div><!-- /.app-content -->

    <style>
      /* ── Header com ações ── */
      .header-actions {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
      }

      /* ── Status badges ── */
      .status-badge {
        display: inline-block;
        padding: .25rem .65rem;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: opacity .2s, transform .1s;
      }

      .status-badge:hover {
        opacity: .8;
        transform: scale(.97);
      }

      .status-ativo {
        background: #dcfce7;
        color: #16a34a;
        border: 1px solid #bbf7d0;
      }

      .status-inativo {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fca5a5;
      }

      /* ── Botões de ação ── */
      .action-btns {
        display: flex;
        gap: .4rem;
        align-items: center;
      }

      .btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: .4rem;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        background: transparent;
        transition: background .15s, transform .1s;
        text-decoration: none;
      }

      .btn-icon:hover {
        background: rgba(0, 0, 0, .06);
        transform: scale(1.1);
      }

      .btn-edit:hover {
        background: #dbeafe;
      }

      .btn-delete:hover {
        background: #fee2e2;
      }

      /* ── Coluna de checkbox ── */
      .th-check,
      .td-check {
        width: 2.25rem;
        text-align: center;
        padding-left: 1rem !important;
      }

      input[type="checkbox"] {
        width: 1rem;
        height: 1rem;
        cursor: pointer;
        accent-color: var(--blue);
      }

      /* ── Linha selecionada ── */
      tr.row-selected {
        background: var(--blue-light) !important;
      }

      /* ── Select e textarea ── */
      .form-group select,
      .form-group textarea {
        width: 100%;
        padding: .65rem .9rem;
        font-size: .925rem;
        font-family: inherit;
        color: var(--text);
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        outline: none;
        transition: border-color var(--transition), box-shadow var(--transition);
        box-sizing: border-box;
      }

      .form-group select:focus,
      .form-group textarea:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(3, 110, 192, .12);
      }

      .form-group textarea {
        resize: vertical;
      }
    </style>

    <script>
      // ── Seleção ──────────────────────────────────────────────
      function getChecks() { return [...document.querySelectorAll('.row-check')]; }
      function getSelected() { return getChecks().filter(c => c.checked); }

      function onCheckChange() {
        const all = getChecks();
        const sel = getSelected();
        const sa = document.getElementById('select-all');
        if (sa) {
          sa.checked = sel.length > 0 && sel.length === all.length;
          sa.indeterminate = sel.length > 0 && sel.length < all.length;
        }
        // Highlight linha
        all.forEach(c => c.closest('tr').classList.toggle('row-selected', c.checked));
        // Botão excluir selecionados
        const btn = document.getElementById('btn-del-sel');
        if (btn) btn.style.display = sel.length > 0 ? 'inline-flex' : 'none';
      }

      function toggleSelectAll(el) {
        getChecks().forEach(c => { c.checked = el.checked; });
        onCheckChange();
      }

      // ── Excluir selecionados ─────────────────────────────────
      function deletarSelecionados() {
        const sel = getSelected();
        if (!sel.length) return;
        const nomes = sel.map(c => c.dataset.nome).join(', ');
        Modal.confirm({
          title: 'Excluir selecionados',
          message: `Deseja excluir <strong>${sel.length}</strong> categoria(s)?<br><small style="color:var(--text-muted)">${nomes}</small>`,
          confirmText: '🗑️ Excluir',
          onConfirm: () => {
            const form = document.getElementById('form-del-sel');
            // Limpa inputs anteriores
            form.innerHTML = '';
            sel.forEach(c => {
              const inp = document.createElement('input');
              inp.type = 'hidden'; inp.name = 'ids'; inp.value = c.value;
              form.appendChild(inp);
            });
            form.submit();
          }
        });
      }

      // ── Exportar (CSV) ───────────────────────────────────────
      function exportarSelecionados() {
        const alvo = getSelected().length ? getSelected() : getChecks();
        if (!alvo.length) {
          Modal.notify({ type: 'warning', title: 'Nada para exportar', message: 'Não há categorias para exportar.', autoClose: false });
          return;
        }
        const linhas = [['id', 'nome', 'descricao', 'status']];
        alvo.forEach(c => {
          const id = c.value;
          const nome = `"${c.dataset.nome.replace(/"/g, '""')}"`;
          const desc = `"${(c.dataset.descricao || '').replace(/"/g, '""')}"`;
          const status = c.dataset.status;
          linhas.push([id, nome, desc, status]);
        });
        const csv = linhas.map(r => r.join(',')).join('\n');
        const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `categorias_${new Date().toISOString().slice(0, 10)}.csv`;
        a.click();
        URL.revokeObjectURL(url);
      }

      // ── Importar (JSON ou CSV) ───────────────────────────────
      function importarArquivo(input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = async (e) => {
          let lista = [];
          const txt = e.target.result;
          try {
            if (file.name.endsWith('.json')) {
              const parsed = JSON.parse(txt);
              lista = Array.isArray(parsed) ? parsed : (parsed.categorias || []);
            } else {
              // CSV: primeira linha = header
              const rows = txt.trim().split(/\r?\n/);
              const head = rows[0].split(',').map(h => h.replace(/^"|"$/g, '').trim().toLowerCase());
              for (let i = 1; i < rows.length; i++) {
                const cols = rows[i].match(/(".*?"|[^,]+|(?<=,)(?=,)|^(?=,)|(?<=,)$)/g) || [];
                const obj = {};
                head.forEach((h, j) => { obj[h] = (cols[j] || '').replace(/^"|"$/g, '').trim(); });
                lista.push(obj);
              }
            }
          } catch (err) {
            Modal.notify({ type: 'error', title: 'Arquivo inválido', message: 'Não foi possível ler o arquivo. Verifique o formato.', autoClose: false });
            input.value = '';
            return;
          }

          if (!lista.length) {
            Modal.notify({ type: 'warning', title: 'Arquivo vazio', message: 'Nenhum registro encontrado no arquivo.', autoClose: false });
            input.value = ''; return;
          }

          try {
            const resp = await fetch('/admin/categorias/importar', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ categorias: lista }),
            });
            const data = await resp.json();
            if (data.ok) {
              Modal.confirm({
                title: 'Importação concluída',
                message: `✅ <strong>${data.importados}</strong> categoria(s) importada(s).<br>⏭️ <strong>${data.ignorados}</strong> ignorada(s) (já existiam ou inválidas).`,
                confirmText: 'Recarregar',
                cancelText: 'Fechar',
                onConfirm: () => location.reload(),
              });
            } else {
              Modal.notify({ type: 'error', title: 'Erro na importação', message: data.mensagem || 'Erro desconhecido.', autoClose: false });
            }
          } catch (err) {
            Modal.notify({ type: 'error', title: 'Erro de rede', message: 'Não foi possível enviar o arquivo. Tente novamente.', autoClose: false });
          }
          input.value = '';
        };
        reader.readAsText(file, 'UTF-8');
      }
    </script>

</body>

</html>