<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/_head') %>
  <title>Usuários — FoodTech</title>
</head>
<body>

<%- include('../partials/_admin-layout', { currentPage: 'usuarios' }) %>

<div class="app-content">
  <div class="page-header fade-up">
    <h1>Usuários</h1>
    <p>Cadastre e visualize os usuários com acesso ao sistema.</p>
  </div>

  <div class="cols-2">

    <!-- Card: formulário de cadastro -->
    <div class="card fade-up d1">
      <div class="card-header">
        <h2>Novo usuário</h2>
      </div>
      <div class="card-body">

        <% if (sucesso === 'usuario_criado') { %>
          <div class="alert alert-success">✅ Usuário cadastrado com sucesso!</div>
        <% } %>
        <% if (erro === 'usuario_ja_existe') { %>
          <div class="alert alert-error">⚠️ Esse nome de usuário já existe.</div>
        <% } else if (erro === 'erro_interno') { %>
          <div class="alert alert-error">⚠️ Erro interno. Tente novamente.</div>
        <% } %>

        <form action="/admin/usuarios" method="POST">
          <div class="form-group">
            <label for="username">Nome de usuário</label>
            <input type="text" id="username" name="username" placeholder="ex: joao.silva" required>
          </div>
          <div class="form-group">
            <label for="password">Senha</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%; margin-top:.25rem;">
            Cadastrar usuário
          </button>
        </form>

      </div>
    </div>

    <!-- Card: tabela de usuários -->
    <div class="card fade-up d2">
      <div class="card-header">
        <h2>Usuários cadastrados</h2>
        <span class="card-badge"><%= usuarios.length %> no total</span>
      </div>

      <% if (usuarios.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">👤</div>
          <p>Nenhum usuário cadastrado ainda.<br>Use o formulário ao lado para adicionar.</p>
        </div>
      <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Usuário</th>
                <th>Criado em</th>
                <th>Atualizado em</th>
              </tr>
            </thead>
            <tbody>
              <% usuarios.forEach(function(u) { %>
                <tr>
                  <td class="td-id"><%= u.id %></td>
                  <td>
                    <div class="user-cell">
                      <div class="user-avatar"><%= u.username.charAt(0) %></div>
                      <span class="user-name"><%= u.username %></span>
                    </div>
                  </td>
                  <td class="td-muted"><%= new Date(u.createdAt).toLocaleString('pt-BR') %></td>
                  <td class="td-muted"><%= new Date(u.updatedAt).toLocaleString('pt-BR') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</div>

</body>
</html>
