<!-- Header fixo -->
<header class="app-header">
  <div class="header-brand">
    <img class="header-brand-logo" src="/icons/logo.png" alt="FoodTech">
    <span>FoodTech</span>
  </div>

  <div class="header-spacer"></div>

  <div class="header-user">
    <div class="header-avatar"><%= username ? username.charAt(0).toUpperCase() : 'U' %></div>
    <span><%= username %></span>
  </div>
</header>

<!-- Sidebar -->
<aside class="app-sidebar">
  <p class="sidebar-section-label">Menu</p>
  <ul class="sidebar-nav">
    <li>
      <a href="/home" class="<%= currentPage === 'inicio' ? 'active' : '' %>">
        <span class="nav-icon">🏠</span> Início
      </a>
    </li>
    <li>
      <a href="/produtos" class="<%= currentPage === 'produtos' ? 'active' : '' %>">
        <span class="nav-icon">📦</span> Produtos
      </a>
    </li>
    <li>
      <a href="/avaliacao-ia" class="<%= currentPage === 'avaliacao-ia' ? 'active' : '' %>">
        <span class="nav-icon">🤖</span> Avaliação IA rótulo
      </a>
    </li>
  </ul>

  <div class="sidebar-footer">
    <form action="/logout" method="POST">
      <button type="submit">
        <span class="nav-icon">🚪</span> Sair
      </button>
    </form>
  </div>
</aside>

<%- include('./_modal') %>
