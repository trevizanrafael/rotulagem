<!-- ══════════════════════════════════════════════
     Modal universal — incluído pelo _admin-layout
     Controlado por modal.js (Modal.confirm / Modal.notify)
     ══════════════════════════════════════════════ -->
<div id="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div id="modal-box">
    <div id="modal-header">
      <span id="modal-icon"></span>
      <h3 id="modal-title"></h3>
    </div>
    <div id="modal-message"></div>
    <div id="modal-actions">
      <button id="modal-cancel-btn"  class="btn btn-ghost"   type="button">Cancelar</button>
      <button id="modal-confirm-btn" class="btn btn-primary" type="button">OK</button>
    </div>
  </div>
</div>
